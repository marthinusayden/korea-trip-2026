        function selectUserTrack(userName) {
            loadUserTrack(userName);
        }

        function saveCurrentItinerary() {
            localStorage.setItem(`itinerary_track_${currentTrackUser}`, JSON.stringify(activeItinerary));
        }

        function resetItinerary() {
            if (confirm(`Are you sure you want to reset ${currentTrackUser}'s itinerary to the default plan?`)) {
                activeItinerary = normalizeItinerary({ ...defaultItineraries[currentTrackUser] });
                saveCurrentItinerary();
                renderPlannerCanvas();
                showToast("Itinerary Reset", `Restored default entries for ${currentTrackUser}.`, "warning");
            }
        }

        function getActivityWishlistTag(activityId) {
            const a = activityById(activityId);
            return a ? a.wish : undefined;
        }

                // --- Menu Render (survey-aware, sorted by match) ---
        const INTEREST_LABELS = { fashion: 'Fashion', culture: 'Culture', thrills: 'Thrills', foodie: 'Foodie' };

        function renderPrefStrip(survey) {
            const strip = document.getElementById('prefStrip');
            if (!strip) return;
            if (!survey) {
                strip.innerHTML = '<span class="pref-empty">No survey yet — <a href="#" onclick="openQuestionnaire();return false;">personalise this menu</a></span>';
                return;
            }
            const bits = [];
            (survey.interests || []).forEach(i => bits.push(`<span class="pref-chip${i === survey.priority ? ' pri' : ''}">${INTEREST_LABELS[i] || i}</span>`));
            (survey.exclusions || []).forEach(e => bits.push(`<span class="pref-chip excl">no ${e === 'vegetarian' ? 'meat' : e}</span>`));
            bits.push(`<span class="pref-chip budget">≤ R${(survey.budget || 12000).toLocaleString()}</span>`);
            strip.innerHTML = bits.join('') + '<button class="pref-edit" onclick="openQuestionnaire()" title="Edit survey"><i class="fa-solid fa-pen"></i></button>';
        }

        function sidebarSectionLabel(text) {
            const el = document.createElement('div');
            el.className = 'sidebar-section-label';
            el.textContent = text;
            return el;
        }

        function buildActivityCard(item, score, otherPicks) {
            const card = document.createElement('div');
            card.className = 'draggable-card' + (score >= 60 ? ' match-strong' : score >= 30 ? ' match-good' : '');
            card.draggable = true;
            card.id = `activity-${item.id}`;
            card.setAttribute('data-activity-id', item.id);

            const regionClass = item.region === 'Busan' ? 'rg-busan' : item.region === 'Seoul 3' ? 'rg-seoul2' : item.region === 'Any' ? 'rg-any' : 'rg-seoul1';
            const startCost = (item.cost || '').split('–')[0].split('·')[0].trim();
            const chips = [`<span class="dc-chip ${regionClass}">${item.region}</span>`];
            if (startCost) chips.push(`<span class="dc-cost">${startCost}</span>`);
            if (item.needsBooking) chips.push('<span class="dc-chip dc-book">Book</span>');
            if (otherPicks && otherPicks.has(item.id)) chips.push('<span class="dc-chip dc-group" title="A family member has planned this too"><i class="fa-solid fa-user-group"></i></span>');

            const favs = getFavoritesFor(currentTrackUser);
            const isFav = favs.includes(item.id);
            const favStar = `<button class="dc-fav-btn no-print" title="Toggle Favorite" style="background:none; border:none; padding:2px 6px; cursor:pointer; color:${isFav ? 'var(--accent)' : 'var(--text-muted)'}; font-size:0.9rem;"><i class="${isFav ? 'fa-solid' : 'fa-regular'} fa-star"></i></button>`;

            card.innerHTML = `
                ${score >= 30 ? `<span class="dc-match" title="Match with ${currentTrackUser}'s survey answers">${score >= 60 ? '★ ' : ''}${score}% match</span>` : ''}
                <div class="dc-title">
                    <span class="dc-emoji">${item.emoji}</span>
                    <span class="dc-name-link" style="text-decoration: underline; cursor: pointer; color: var(--primary-light);">${item.name}</span>
                    <div style="display:inline-flex; align-items:center; gap:2px; margin-left:auto;">
                        ${favStar}
                        <button class="dc-info-btn no-print" style="background: none; border: none; padding: 2px 6px; cursor: pointer; color: var(--text-muted); font-size: 0.85rem;" title="View details"><i class="fa-solid fa-circle-info"></i></button>
                    </div>
                </div>
                <div class="dc-meta">${chips.join('')}</div>
            `;

            card.addEventListener('dragstart', (e) => {
                if (itineraryLocked) {
                    e.preventDefault();
                    showToast("Itinerary Locked", "Unlock your itinerary to move activities.", "warning");
                    return;
                }
                draggedActivityId = item.id;
                card.classList.add('dragging');
                e.dataTransfer.setData('text/plain', item.id);
            });
            card.addEventListener('dragend', () => {
                card.classList.remove('dragging');
                draggedActivityId = null;
                document.querySelectorAll('.time-slot').forEach(el => el.classList.remove('drag-over', 'drag-invalid'));
            });

            // Click listener only on name, info icon, and favorite star
            card.querySelector('.dc-name-link').addEventListener('click', (e) => {
                e.stopPropagation();
                openDetailsModal(item);
            });
            card.querySelector('.dc-info-btn').addEventListener('click', (e) => {
                e.stopPropagation();
                openDetailsModal(item);
            });
            card.querySelector('.dc-fav-btn').addEventListener('click', (e) => {
                e.stopPropagation();
                toggleFavorite(item.id);
            });

            return card;
        }

        function renderActivityMenu() {
            const activityList = document.getElementById('activityList');
            activityList.innerHTML = '';
            const searchTerm = document.getElementById('activitySearch').value.toLowerCase();

            const survey = getSurveyFor(currentTrackUser);
            const userBudget = survey ? (survey.budget || 12000) : 12000;
            const exclusions = survey ? (survey.exclusions || []) : [];
            const otherPicks = getOtherMembersPicks();

            renderPrefStrip(survey);

            let hiddenDiet = 0, hiddenBudget = 0;
            const visible = [];
            activities.forEach(item => {
                if (isDietExcluded(item, exclusions)) { hiddenDiet++; return; }
                if (isOverBudget(item, userBudget)) { hiddenBudget++; return; }
                if (searchTerm && !(item.name + ' ' + item.teaser + ' ' + item.desc).toLowerCase().includes(searchTerm)) return;
                const score = matchScore(item, survey, otherPicks);
                if (activeCategoryFilter === 'top') { if (score < 30) return; }
                else if (activeCategoryFilter === 'favorites') {
                    const favs = getFavoritesFor(currentTrackUser);
                    if (!favs.includes(item.id)) return;
                }
                else if (activeCategoryFilter !== 'all' && !categoryMatches(item, activeCategoryFilter)) return;
                visible.push({ item, score });
            });

            // Highest match first, then A–Z
            visible.sort((a, b) => b.score - a.score || a.item.name.localeCompare(b.item.name));

            const countEl = document.getElementById('sidebarCount');
            if (countEl) countEl.textContent = `(${visible.length})`;

            let bestLabelDone = false, restLabelDone = false;
            visible.forEach(({ item, score }) => {
                if (survey && activeCategoryFilter === 'all' && !searchTerm) {
                    if (score >= 30 && !bestLabelDone) {
                        activityList.appendChild(sidebarSectionLabel(`✨ Best matches for ${currentTrackUser}`));
                        bestLabelDone = true;
                    }
                    if (score < 30 && bestLabelDone && !restLabelDone) {
                        activityList.appendChild(sidebarSectionLabel('Everything else'));
                        restLabelDone = true;
                    }
                }
                activityList.appendChild(buildActivityCard(item, score, otherPicks));
            });

            if (!visible.length) {
                const empty = document.createElement('div');
                empty.className = 'sidebar-hidden-note';
                empty.textContent = 'Nothing matches this filter or search.';
                activityList.appendChild(empty);
            }
            if (hiddenDiet || hiddenBudget) {
                const note = document.createElement('div');
                note.className = 'sidebar-hidden-note';
                const parts = [];
                if (hiddenDiet) parts.push(`${hiddenDiet} hidden by dietary preferences`);
                if (hiddenBudget) parts.push(`${hiddenBudget} hidden by budget`);
                note.innerHTML = '<i class="fa-solid fa-filter"></i> ' + parts.join(' · ');
                activityList.appendChild(note);
            }
        }

                function filterActivities() {
            renderActivityMenu();
        }

        function setCategoryFilter(categoryName) {
            activeCategoryFilter = categoryName;
            const filterBtns = document.querySelectorAll('.filter-btn');
            filterBtns.forEach(btn => {
                btn.classList.toggle('active', btn.id === `filterBtn-${categoryName}`);
            });
            renderActivityMenu();
        }

        // --- Day Canvas Render ---
        function renderPlannerCanvas() {
            const canvas = document.getElementById('dayCanvasList');
            canvas.innerHTML = '';

            // Load active user's wishlist
            const savedSurvey = localStorage.getItem(`itinerary_survey_${currentTrackUser}`);
            let wishlist = [];
            if (savedSurvey) {
                wishlist = JSON.parse(savedSurvey).wishlist || [];
            }

            // Load all member itineraries
            const memberItineraries = {};
            familyMembers.forEach(member => {
                const data = localStorage.getItem(`itinerary_track_${member}`);
                memberItineraries[member] = normalizeItinerary(data ? JSON.parse(data) : (defaultItineraries[member] || {}));
            });

            // ── Smart suggestions for empty slots (dynamic: recomputed on every
            //    render, aware of the user's survey AND what family members planned) ──
            const cSurvey = getSurveyFor(currentTrackUser);
            const cOtherPicks = getOtherMembersPicks();
            const usedIds = new Set();
            Object.values(activeItinerary).forEach(val => {
                if (val) {
                    val.split(';').forEach(id => {
                        if (id.trim()) usedIds.add(id.trim());
                    });
                }
            });
            const suggestedIds = new Set();
            const TIME_TYPE_PREF = {
                morning:   { activity: 8, shopping: 4, food: 0 },
                afternoon: { activity: 6, shopping: 6, food: 2 },
                evening:   { food: 8, activity: 4, shopping: 0 }
            };
            function suggestFor(day, time) {
                if (!cSurvey || itineraryLocked) return null;
                let best = null, bestScore = -1;
                activities.forEach(item => {
                    if (usedIds.has(item.id) || suggestedIds.has(item.id)) return;
                    if (isDietExcluded(item, cSurvey.exclusions || [])) return;
                    if (isOverBudget(item, cSurvey.budget)) return;
                    if (!regionOk(item.region, day.region)) return;
                    const s = matchScore(item, cSurvey, cOtherPicks) + (TIME_TYPE_PREF[time][item.type] || 0);
                    if (s > bestScore) { bestScore = s; best = item; }
                });
                if (!best || bestScore < 30) return null;
                suggestedIds.add(best.id);
                return best;
            }

            days.forEach(day => {
                const dayCard = document.createElement('div');
                dayCard.className = 'agenda-day';
                dayCard.id = `day-${day.dayNum}`;

                const regionClass = day.region === 'Busan' ? 'leg-busan' : day.region === 'Any' ? 'leg-flight' : '';
                
                let dayHeaderHtml = `
                    <div class="agenda-header" onclick="toggleDay(this)">
                        <div class="agenda-title">
                            <span class="day-badge" style="background-color:${day.region === 'Busan' ? '#3A6B8A' : day.region === 'Seoul 3' ? '#8A5A3A' : '#4A6B53'}">Day ${day.dayNum}</span>
                            <span class="day-date">${day.dateStr} — ${day.summary} <span class="leg-badge ${regionClass}">${day.region}</span></span>
                        </div>
                        <i class="chevron-icon fa-solid fa-chevron-down"></i>
                    </div>
                `;

                let slotsHtml = '<div class="agenda-content"><div class="day-slots-container">';

                const times = ['morning', 'afternoon', 'evening'];
                let splitRegionsList = [];
                
                times.forEach(time => {
                    let slotClass = 'time-slot';
                    let slotContent = '';
                    
                    if (day.locked && day.locked[time]) {
                        slotClass += ' locked-slot';
                        slotContent = `
                            <div class="slot-card" style="background:none; border:none; box-shadow:none; padding:0;">
                                <div class="slot-card-text" style="color:var(--accent); font-weight:700;"><i class="fa-solid fa-lock" style="margin-right:6px;"></i>${day.locked[time]}</div>
                            </div>
                        `;
                    } else {
                        const savedActivityId = activeItinerary[`day-${day.dayNum}-${time}`];
                        let totalMinutes = 0;
                        if (savedActivityId) {
                            const ids = savedActivityId.split(';').filter(id => id.trim() !== '');
                            ids.forEach((id) => {
                                const act = activityById(id);
                                if (act) {
                                    totalMinutes += parseDuration(act.duration);

                                    let sameActivityCount = 0;
                                    let differentActivitySameRegionCount = 0;
                                    let differentRegionCount = 0;
                                    let totalOtherScheduled = 0;

                                    familyMembers.forEach(m => {
                                        if (m === currentTrackUser) return;
                                        const otherItin = memberItineraries[m];
                                        const otherActVal = otherItin[`day-${day.dayNum}-${time}`] || '';
                                        const otherIds = otherActVal.split(';').filter(oid => oid.trim() !== '');
                                        if (otherIds.length > 0) {
                                            totalOtherScheduled++;
                                            if (otherIds.includes(act.id)) {
                                                sameActivityCount++;
                                            } else {
                                                let inSameRegion = false;
                                                otherIds.forEach(oid => {
                                                    const otherAct = activities.find(a => a.id === oid);
                                                    if (otherAct) {
                                                        if (act.region === 'Any' || otherAct.region === 'Any' || act.region === otherAct.region) {
                                                            inSameRegion = true;
                                                        }
                                                    }
                                                });
                                                if (inSameRegion) {
                                                    differentActivitySameRegionCount++;
                                                } else {
                                                    differentRegionCount++;
                                                    const otherAct = activities.find(a => a.id === otherIds[0]);
                                                    if (otherAct) {
                                                        const desc = `${m} is in ${otherAct.region} (${otherAct.name}) while you are in ${act.region} (${act.name})`;
                                                        if (!splitRegionsList.includes(desc)) splitRegionsList.push(desc);
                                                    }
                                                }
                                            }
                                        }
                                    });

                                    let borderStyle = '';
                                    let badgeText = '';
                                    if (totalOtherScheduled > 0) {
                                        if (sameActivityCount === familyMembers.length - 1) {
                                            borderStyle = 'border: 2px solid #2e7d32;';
                                            badgeText = `<span class="coor-badge green" title="Everyone is doing this activity!"><i class="fa-solid fa-users"></i> Fully Synced</span>`;
                                        } else if (differentRegionCount > 0) {
                                            borderStyle = 'border: 2px solid #d84315;';
                                            badgeText = `<span class="coor-badge orange" title="Warning: Members are in different regions entirely in this slot!"><i class="fa-solid fa-triangle-exclamation"></i> Split Region</span>`;
                                        } else {
                                            borderStyle = 'border: 2px solid #1565c0;';
                                            badgeText = `<span class="coor-badge blue" title="Members are in the same region, but doing different things."><i class="fa-solid fa-street-view"></i> Same Region</span>`;
                                        }
                                    }

                                    const wishlistTag = getActivityWishlistTag(act.id);
                                    const isWishlistMatch = wishlistTag && wishlist.includes(wishlistTag);
                                    if (isWishlistMatch) {
                                        if (!borderStyle) borderStyle = 'border: 2px dashed var(--accent); background-color: rgba(200, 150, 62, 0.04);';
                                        badgeText += `<span class="coor-badge" style="background:var(--accent); color:white; border:none; margin-left:4px;" title="Wishlist Match"><i class="fa-solid fa-fire"></i> Wishlist</span>`;
                                    }

                                    slotContent += `
                                        <div class="slot-card" style="${borderStyle}" data-activity-id="${act.id}">
                                            <div class="slot-card-text" style="display: flex; align-items: center; gap: 4px; ${isWishlistMatch ? 'font-weight: 700; color: var(--accent);' : ''}">
                                                <i class="fa-solid fa-circle" style="color:${act.region === 'Busan' ? '#3A6B8A' : act.region === 'Seoul 3' ? '#8A5A3A' : '#4A6B53'}; font-size:0.5rem; flex-shrink: 0;"></i>
                                                <span class="slot-card-name-link" style="text-decoration: underline; cursor: pointer; color: var(--primary-light);" onclick="event.stopPropagation(); showActivityById('${act.id}')">${act.name}</span>
                                                <button class="slot-card-info-btn no-print" style="background: none; border: none; padding: 2px; cursor: pointer; color: var(--text-muted); display: inline-flex; align-items: center; font-size: 0.82rem;" onclick="event.stopPropagation(); showActivityById('${act.id}')" title="View details"><i class="fa-solid fa-circle-info"></i></button>
                                                ${badgeText}
                                            </div>
                                            <i class="fa-solid fa-circle-xmark slot-card-remove no-print" onclick="event.stopPropagation(); removeActivityFromSlot(${day.dayNum}, '${time}', '${act.id}')" title="Remove activity"></i>
                                        </div>
                                    `;
                                }
                            });
                        }
                        
                        if (totalMinutes > 0) {
                            slotContent += `
                                <div class="slot-duration-pill" style="margin-top: 4px; font-size: 0.65rem; color: var(--text-muted); opacity: 0.85; align-self: flex-start; display: inline-flex; align-items: center; gap: 4px; padding: 2px 6px; background: rgba(255,255,255,0.05); border-radius: 4px;">
                                    <i class="fa-regular fa-clock"></i> Est. Time: ${formatDuration(totalMinutes)}
                                </div>
                            `;
                            if (totalMinutes > 300) {
                                slotContent += `
                                    <div style="font-size: 0.65rem; color: var(--accent); display: flex; align-items: center; gap: 4px; margin-top: 2px; font-weight: 600;">
                                        <i class="fa-solid fa-triangle-exclamation"></i> Packed Slot (>5 hrs)!
                                    </div>
                                `;
                            }
                            if (!itineraryLocked) {
                                const timeLabel = time.charAt(0).toUpperCase() + time.slice(1);
                                const dayLabel = day.dateStr;
                                slotContent += `<button class="slot-add-btn no-print" style="margin-top: 6px;" onclick="event.stopPropagation(); openSlotPicker(${day.dayNum}, '${time}', '${timeLabel} · ${dayLabel}')"><i class="fa-solid fa-plus"></i> Add more options</button>`;
                            }
                        } else if (!itineraryLocked) {
                            const sug = suggestFor(day, time);
                            const timeLabel = time.charAt(0).toUpperCase() + time.slice(1);
                            const dayLabel = day.dateStr;
                            if (sug) {
                                slotContent = `
                                    <div class="ghost-suggestion no-print">
                                        <span class="ghost-label"><i class="fa-solid fa-wand-magic-sparkles"></i></span>
                                        <span class="ghost-name" onclick="event.stopPropagation(); showActivityById('${sug.id}')" title="Suggested from your survey — click to view">${sug.emoji} ${sug.name}</span>
                                        <button class="ghost-add" onclick="event.stopPropagation(); acceptSuggestion(${day.dayNum}, '${time}', '${sug.id}')" title="Add to this slot"><i class="fa-solid fa-plus"></i></button>
                                    </div>
                                    <button class="slot-add-btn no-print" onclick="event.stopPropagation(); openSlotPicker(${day.dayNum}, '${time}', '${timeLabel} · ${dayLabel}')"><i class="fa-solid fa-plus"></i> Browse all options</button>`;
                            } else {
                                slotContent = `<button class="slot-add-btn no-print" onclick="event.stopPropagation(); openSlotPicker(${day.dayNum}, '${time}', '${timeLabel} · ${dayLabel}')"><i class="fa-solid fa-plus"></i> Browse all options</button>`;
                            }
                        }
                    }

                    slotsHtml += `
                        <div class="${slotClass}" 
                             data-day-num="${day.dayNum}" 
                             data-time-slot="${time}" 
                             data-slot-name="${time}"
                             id="slot-${day.dayNum}-${time}">
                            ${slotContent}
                        </div>
                    `;
                });

                slotsHtml += '</div>'; // close day-slots-container

                // Render dynamic warning badges inside each Day
                let warningsHtml = '<div class="day-advisory-container">';
                
                // Weather check (Monsoon)
                let hasOutdoor = false;
                let hasBookings = [];
                let colocatedPeople = {};

                times.forEach(time => {
                    const savedId = activeItinerary[`day-${day.dayNum}-${time}`];
                    if (savedId) {
                        savedId.split(';').forEach(id => {
                            const act = activities.find(a => a.id === id);
                            if (act) {
                                if (!act.isIndoor) hasOutdoor = true;
                                if (act.needsBooking) hasBookings.push(act.name);
                                
                                // Check other family members for coordination
                                familyMembers.forEach(otherUser => {
                                    if (otherUser === currentTrackUser) return;
                                    const otherItin = memberItineraries[otherUser];
                                    if (otherItin) {
                                        const otherVal = otherItin[`day-${day.dayNum}-${time}`] || '';
                                        if (otherVal.split(';').includes(id)) {
                                            if (!colocatedPeople[act.name]) colocatedPeople[act.name] = [];
                                            colocatedPeople[act.name].push(otherUser);
                                        }
                                    }
                                });
                            }
                        });
                    }
                });

                // Neighbourhood conflict detection
                let hoodConflicts = [];
                let hoodsSeen = [];
                times.forEach(time => {
                  const savedId = activeItinerary[`day-${day.dayNum}-${time}`];
                  if (savedId) {
                    savedId.split(';').forEach(id => {
                      const act = activities.find(a => a.id === id);
                      if (act && act.neighbourhood) hoodsSeen.push({ time, name: act.name, hood: act.neighbourhood });
                    });
                  }
                });
                // Compare all pairs of scheduled items
                for (let i = 0; i < hoodsSeen.length; i++) {
                  for (let j = i + 1; j < hoodsSeen.length; j++) {
                    const a = hoodsSeen[i], b = hoodsSeen[j];
                    if (a.hood !== b.hood && !CLOSE_PAIRS.has(`${a.hood}|${b.hood}`)) {
                      const labelA = HOOD_LABELS[a.hood] || a.hood;
                      const labelB = HOOD_LABELS[b.hood] || b.hood;
                      hoodConflicts.push(`${a.name} (${labelA}) → ${b.name} (${labelB})`);
                    }
                  }
                }

                if (hasOutdoor) {
                    warningsHtml += `
                        <span class="advisory-badge adv-monsoon" title="Late June/July is Korean Monsoon. Stash an indoor alternate plan (like COEX Mall) in case of rainy weather.">
                            <i class="fa-solid fa-cloud-rain"></i> Monsoon Swap Ready
                        </span>
                    `;
                }
                hasBookings.forEach(bookName => {
                    warningsHtml += `
                        <span class="advisory-badge adv-booking" title="'${bookName}' requires booking in advance!">
                            <i class="fa-solid fa-calendar-check"></i> Reservation Needed
                        </span>
                    `;
                });

                if (hoodConflicts.length > 0) {
                    warningsHtml += `
                        <span class="advisory-badge" style="background-color:rgba(230,126,34,0.12); color:#a04000; cursor:default;" title="Far neighbourhoods on the same day — consider grouping nearby spots.\n${hoodConflicts.join('\n')}">
                            <i class="fa-solid fa-route"></i> Neighbourhood Spread (${hoodConflicts.length})
                        </span>
                    `;
                }

                if (splitRegionsList.length > 0) {
                    warningsHtml += `
                        <span class="advisory-badge" style="background-color: rgba(216, 67, 21, 0.1); color: #d84315;" title="${splitRegionsList.join('\n')}">
                            <i class="fa-solid fa-triangle-exclamation"></i> Split Region Warning
                        </span>
                    `;
                }

                for (let actName in colocatedPeople) {
                    warningsHtml += `
                        <span class="advisory-badge adv-coord" title="${colocatedPeople[actName].join(', ')} scheduled this too!">
                            <i class="fa-solid fa-user-group"></i> Coordinated with ${colocatedPeople[actName].join(', ')}
                        </span>
                    `;
                }

                warningsHtml += '</div>'; // close day-advisory-container
                
                // Add timeline toggle button and container
                let timelineHtml = `
                    <div class="day-timeline-actions">
                        <button class="timeline-toggle-btn no-print" id="timeline-btn-${day.dayNum}" onclick="event.stopPropagation(); toggleTimeline(${day.dayNum})">
                            <i class="fa-solid fa-clock-rotate-left"></i> View Daily Timeline Breakdown
                        </button>
                    </div>
                    <div class="day-timeline-view" id="timeline-${day.dayNum}" style="display: none;"></div>
                `;

                slotsHtml += warningsHtml + timelineHtml + '</div>'; // close agenda-content

                dayCard.innerHTML = dayHeaderHtml + slotsHtml;
                canvas.appendChild(dayCard);
            });

            // Re-bind Drag & Drop drop-zone listeners
            setupDropZoneListeners();

            // Bind listeners to all draggable slot cards
            document.querySelectorAll('.slot-card').forEach(card => {
                const slotEl = card.closest('.time-slot');
                if (!slotEl) return;
                const dayNum = parseInt(slotEl.getAttribute('data-day-num'));
                const timeSlot = slotEl.getAttribute('data-time-slot');
                const activityId = card.getAttribute('data-activity-id');
                
                card.setAttribute('draggable', 'true');
                card.addEventListener('dragstart', (e) => {
                    if (itineraryLocked) {
                        e.preventDefault();
                        showToast("Itinerary Locked", "Unlock your itinerary to move activities.", "warning");
                        return;
                    }
                    draggedActivityId = activityId;
                    draggedSourceSlot = { dayNum, timeSlot };
                    card.classList.add('dragging');
                    e.dataTransfer.setData('text/plain', activityId);
                });
                
                card.addEventListener('dragend', () => {
                    card.classList.remove('dragging');
                    draggedActivityId = null;
                    draggedSourceSlot = null;
                    document.querySelectorAll('.time-slot').forEach(el => el.classList.remove('drag-over', 'drag-invalid'));
                });
            });

            if (itineraryLocked) {
                updateAITravelGuide();
            } else {
                const guideContent = document.getElementById('aiTravelGuideContent');
                if (guideContent) {
                    guideContent.innerHTML = `<p style="color: var(--text-muted); font-style: italic; text-align: center; padding: 20px 0;"><i class="fa-solid fa-lock" style="font-size: 1.5rem; margin-bottom: 8px; display: block; color: var(--accent);"></i> Please lock your itinerary using the "Lock Itinerary" button at the top to unlock and generate the AI Travel Guide walkthrough.</p>`;
                }
            }

            // Restore open timelines
            openTimelines.forEach(dayNum => {
                const timelineEl = document.getElementById(`timeline-${dayNum}`);
                const btn = document.getElementById(`timeline-btn-${dayNum}`);
                if (timelineEl && btn) {
                    timelineEl.innerHTML = buildDayTimelineHtml(dayNum);
                    timelineEl.style.display = 'block';
                    btn.innerHTML = `<i class="fa-solid fa-eye-slash"></i> Hide Daily Timeline`;
                    btn.style.background = 'var(--accent)';
                    btn.style.color = '#fff';
                }
            });
        }

        // ── Daily Timeline Breakdown Core Functions ──
        function formatMinsToTime(mins) {
            let h = Math.floor(mins / 60) % 24;
            let m = Math.floor(mins % 60);
            let ampm = h >= 12 ? 'PM' : 'AM';
            let displayH = h % 12;
            if (displayH === 0) displayH = 12;
            let displayM = m < 10 ? '0' + m : m;
            return `${displayH}:${displayM} ${ampm}`;
        }

        function getZarCost(act) {
            if (!act.costZAR) return 0;
            let match = act.costZAR.match(/R\s*([\d,]+)/);
            if (match) {
                return parseInt(match[1].replace(/,/g, ''));
            }
            return 0;
        }

        function getWonCost(act) {
            if (!act.cost) return 0;
            let match = act.cost.match(/[₩\s]*([\d,]+)/);
            if (match) {
                return parseInt(match[1].replace(/,/g, ''));
            }
            return 0;
        }

        function toggleTimeline(dayNum) {
            const timelineEl = document.getElementById(`timeline-${dayNum}`);
            const btn = document.getElementById(`timeline-btn-${dayNum}`);
            if (!timelineEl || !btn) return;

            if (openTimelines.has(dayNum)) {
                openTimelines.delete(dayNum);
                timelineEl.style.display = 'none';
                btn.innerHTML = `<i class="fa-solid fa-clock-rotate-left"></i> View Daily Timeline Breakdown`;
                btn.style.background = '';
                btn.style.color = '';
            } else {
                openTimelines.add(dayNum);
                timelineEl.innerHTML = buildDayTimelineHtml(dayNum);
                timelineEl.style.display = 'block';
                btn.innerHTML = `<i class="fa-solid fa-eye-slash"></i> Hide Daily Timeline`;
                btn.style.background = 'var(--accent)';
                btn.style.color = '#fff';
            }
        }

        function changeTimelineStartTime(dayNum, timeVal) {
            localStorage.setItem(`timeline_start_day_${dayNum}`, timeVal);
            const timelineEl = document.getElementById(`timeline-${dayNum}`);
            if (timelineEl) {
                timelineEl.innerHTML = buildDayTimelineHtml(dayNum);
            }
        }

        function buildDayTimelineHtml(dayNum) {
            const day = days.find(d => d.dayNum === dayNum);
            if (!day) return '';

            // Get starting time
            let startVal = localStorage.getItem(`timeline_start_day_${dayNum}`);
            if (!startVal) {
                startVal = (dayNum === 7 || dayNum === 10) ? '08:30' : '09:00';
            }
            
            let startH = parseInt(startVal.split(':')[0]);
            let startM = parseInt(startVal.split(':')[1]);
            let currentMins = startH * 60 + startM;

            // Fetch activities
            const morningVal = activeItinerary[`day-${dayNum}-morning`] || '';
            const afternoonVal = activeItinerary[`day-${dayNum}-afternoon`] || '';
            const eveningVal = activeItinerary[`day-${dayNum}-evening`] || '';

            const morningActs = morningVal.split(';').map(id => activityById(id)).filter(Boolean);
            const afternoonActs = afternoonVal.split(';').map(id => activityById(id)).filter(Boolean);
            const eveningActs = eveningVal.split(';').map(id => activityById(id)).filter(Boolean);

            let rawEvents = [];

            // 1. Morning Locked Constraint
            if (day.locked && day.locked.morning) {
                rawEvents.push({
                    type: 'lock',
                    name: day.locked.morning,
                    emoji: '🔒',
                    duration: 120,
                    desc: 'Trip constraint or travel lock scheduled for the morning.',
                    isLocked: true
                });
            }

            // 2. Morning Activities
            morningActs.forEach(act => {
                rawEvents.push({
                    type: act.type === 'food' ? 'food' : 'activity',
                    id: act.id,
                    name: act.name,
                    emoji: act.emoji || '📌',
                    duration: parseDuration(act.duration),
                    durationStr: act.duration,
                    cost: act.cost,
                    costValWon: getWonCost(act),
                    costValZar: getZarCost(act),
                    desc: act.desc || act.teaser || '',
                    tips: act.tips,
                    neighbourhood: act.neighbourhood,
                    mapLink: act.mapLink,
                    link: act.link
                });
            });

            // 3. Midday Lunch check
            const hasMorningFood = morningActs.some(a => a.type === 'food' || a.category === 'cafes' || a.category === 'dining');
            const hasAfternoonFood = afternoonActs.some(a => a.type === 'food' || a.category === 'cafes' || a.category === 'dining');
            
            // Insert suggested lunch if we have activities and no morning/afternoon food card is placed
            if ((morningActs.length > 0 || afternoonActs.length > 0) && !hasMorningFood && !hasAfternoonFood) {
                if (dayNum !== 7 && dayNum !== 10) {
                    rawEvents.push({
                        type: 'food',
                        name: 'Suggested Lunch Break 🍜',
                        emoji: '🍜',
                        duration: 60,
                        durationStr: '1 hr',
                        cost: '₩10,000 pp',
                        costValWon: 10000,
                        costValZar: 108,
                        desc: 'Take a break to eat lunch at a local restaurant or street food market nearby.',
                        tips: 'Check the Food Menu tab in the app for top nearby restaurants!'
                    });
                }
            }

            // 4. Afternoon Events
            // KTX Travel Day Special Constraints
            if (dayNum === 7) {
                rawEvents.push({
                    type: 'lock',
                    name: 'Check Out & Travel to Seoul Station 🧳',
                    emoji: '🧳',
                    duration: 45,
                    startMins: 720, // 12:00 PM
                    desc: 'Check out of your accommodation in Ahyeon/Mapo and take a taxi or subway to Seoul Station.',
                    isLocked: true
                });
                rawEvents.push({
                    type: 'lock',
                    name: 'KTX103 Train to Busan 🚄',
                    emoji: '🚄',
                    duration: 200, // 13:08 to 16:28 (3h 20m)
                    startMins: 788, // 1:08 PM
                    desc: 'Board the KTX high-speed train booked to Busan (13:08 → 16:28). Enjoy the scenic ride south!',
                    isLocked: true
                });
                rawEvents.push({
                    type: 'lock',
                    name: 'Transit to Bonathree Hotel, Busan 🏨',
                    emoji: '🏨',
                    duration: 45,
                    startMins: 988, // 4:28 PM
                    desc: 'Arrive at Busan Station, grab your bags, and take taxi or subway to your hotel (Bonathree Hotel near Daeyeon). Check in and settle in.',
                    isLocked: true
                });
            } else if (dayNum === 10) {
                rawEvents.push({
                    type: 'lock',
                    name: 'Check Out & Travel to Busan Station 🧳',
                    emoji: '🧳',
                    duration: 45,
                    startMins: 720, // 12:00 PM
                    desc: 'Check out of your Busan hotel and take a taxi or subway to Busan Station.',
                    isLocked: true
                });
                rawEvents.push({
                    type: 'lock',
                    name: 'KTX124 Train to Seoul 🚄',
                    emoji: '🚄',
                    duration: 197, // 13:17 to 16:34 (3h 17m)
                    startMins: 797, // 1:17 PM
                    desc: 'Board the KTX high-speed train booked back to Seoul (13:17 → 16:34).',
                    isLocked: true
                });
                rawEvents.push({
                    type: 'lock',
                    name: 'Transit to Seodaemun Hotel, Seoul 🏨',
                    emoji: '🏨',
                    duration: 45,
                    startMins: 994, // 4:34 PM
                    desc: 'Arrive at Seoul Station and transit to your Leg 3 accommodation in Seodaemun. Check in and refresh.',
                    isLocked: true
                });
            } else if (day.locked && day.locked.afternoon) {
                rawEvents.push({
                    type: 'lock',
                    name: day.locked.afternoon,
                    emoji: '🔒',
                    duration: 120,
                    desc: 'Trip constraint or travel lock scheduled for the afternoon.',
                    isLocked: true
                });
            }

            // Afternoon activities
            afternoonActs.forEach(act => {
                rawEvents.push({
                    type: act.type === 'food' ? 'food' : 'activity',
                    id: act.id,
                    name: act.name,
                    emoji: act.emoji || '📌',
                    duration: parseDuration(act.duration),
                    durationStr: act.duration,
                    cost: act.cost,
                    costValWon: getWonCost(act),
                    costValZar: getZarCost(act),
                    desc: act.desc || act.teaser || '',
                    tips: act.tips,
                    neighbourhood: act.neighbourhood,
                    mapLink: act.mapLink,
                    link: act.link
                });
            });

            // 5. Return to Hotel / Clean Up Buffer
            if ((afternoonActs.length > 0 || dayNum === 7 || dayNum === 10) && (eveningActs.length > 0 || (day.locked && day.locked.evening))) {
                rawEvents.push({
                    type: 'rest',
                    name: 'Rest, Clean Up & Refresh at Hotel 🏨',
                    emoji: '🏨',
                    duration: 90,
                    durationStr: '1.5 hrs',
                    desc: 'Return to the hotel to take a shower, change clothes, drop off shopping bags, and rest before heading out for the evening.',
                    tips: 'Essential pacing step to keep your energy high!'
                });
            }

            // 6. Evening Events
            if (day.locked && day.locked.evening) {
                rawEvents.push({
                    type: 'lock',
                    name: day.locked.evening,
                    emoji: '🔒',
                    duration: 120,
                    desc: 'Trip constraint or travel lock scheduled for the evening.',
                    isLocked: true
                });
            }

            // Evening dinner check
            const hasEveningFood = eveningActs.some(a => a.type === 'food' || a.category === 'cafes' || a.category === 'dining');
            if (eveningActs.length > 0 && !hasEveningFood) {
                rawEvents.push({
                    type: 'food',
                    name: 'Suggested Dinner Break 🥩',
                    emoji: '🥩',
                    duration: 90,
                    durationStr: '1.5 hrs',
                    cost: '₩20,000 pp',
                    costValWon: 20000,
                    costValZar: 216,
                    desc: 'Enjoy K-BBQ, hot stews, traditional markets, or trendy local dinners.',
                    tips: 'Use the buzzer at the table to call for service, and remember banchan is free and refillable!'
                });
            }

            // Evening activities
            eveningActs.forEach(act => {
                rawEvents.push({
                    type: act.type === 'food' ? 'food' : 'activity',
                    id: act.id,
                    name: act.name,
                    emoji: act.emoji || '📌',
                    duration: parseDuration(act.duration),
                    durationStr: act.duration,
                    cost: act.cost,
                    costValWon: getWonCost(act),
                    costValZar: getZarCost(act),
                    desc: act.desc || act.teaser || '',
                    tips: act.tips,
                    neighbourhood: act.neighbourhood,
                    mapLink: act.mapLink,
                    link: act.link
                });
            });

            // If no events scheduled at all
            if (rawEvents.length === 0) {
                return `
                    <p style="text-align:center; color:var(--text-muted); padding:20px 0; font-size:0.8rem; font-style:italic;">
                        <i class="fa-solid fa-calendar-day" style="font-size:1.4rem; display:block; margin-bottom:8px;"></i>
                        No activities scheduled for this day yet. Drag and drop cards from the sidebar to populate!
                    </p>
                `;
            }

            // Compile Timeline with Transit Buffers
            let scheduledEvents = [];
            let totalBudgetWon = 0;
            let totalBudgetZar = 0;
            let totalActiveMins = 0;

            for (let i = 0; i < rawEvents.length; i++) {
                let ev = rawEvents[i];

                if (ev.type !== 'transit' && ev.type !== 'rest') {
                    totalBudgetWon += ev.costValWon || 0;
                    totalBudgetZar += ev.costValZar || 0;
                    totalActiveMins += ev.duration || 0;
                }

                if (ev.startMins !== undefined) {
                    if (currentMins > ev.startMins) {
                        ev.conflict = true;
                    } else {
                        let gap = ev.startMins - currentMins;
                        if (gap > 5) {
                            scheduledEvents.push({
                                type: 'transit',
                                name: 'Free Time / Station Transit 🚶',
                                emoji: '🚶',
                                duration: gap,
                                startMins: currentMins,
                                endMins: ev.startMins,
                                desc: 'Use this time to travel to the station, buy snacks, or grab a coffee.'
                            });
                        }
                        currentMins = ev.startMins;
                    }
                }

                ev.startMins = currentMins;
                ev.endMins = currentMins + ev.duration;
                scheduledEvents.push(ev);
                currentMins = ev.endMins;

                if (i < rawEvents.length - 1) {
                    let nextEv = rawEvents[i + 1];
                    if (nextEv.startMins !== undefined) continue;

                    let transitTime = 30; // default
                    let transitText = 'Transit';
                    let transitIcon = 'fa-solid fa-route';

                    if (ev.neighbourhood && nextEv.neighbourhood) {
                        if (ev.neighbourhood === nextEv.neighbourhood) {
                            transitTime = 15;
                            transitText = `Walk / short transit within ${HOOD_LABELS[ev.neighbourhood] || ev.neighbourhood}`;
                            transitIcon = 'fa-solid fa-person-walking';
                        } else {
                            const pair = `${ev.neighbourhood}|${nextEv.neighbourhood}`;
                            const reversePair = `${nextEv.neighbourhood}|${ev.neighbourhood}`;
                            if (CLOSE_PAIRS.has(pair) || CLOSE_PAIRS.has(reversePair)) {
                                transitTime = 25;
                                transitText = `Subway between adjacent areas`;
                                transitIcon = 'fa-solid fa-train-subway';
                            } else {
                                transitTime = 40;
                                transitText = `Subway / Taxi between far areas`;
                                transitIcon = 'fa-solid fa-route';
                            }
                        }
                    }

                    scheduledEvents.push({
                        type: 'transit',
                        name: transitText,
                        emoji: '🚇',
                        icon: transitIcon,
                        duration: transitTime,
                        startMins: currentMins,
                        endMins: currentMins + transitTime,
                        desc: 'Estimated travel time between different locations.'
                    });
                    currentMins += transitTime;
                }
            }

            // Final return
            scheduledEvents.push({
                type: 'transit',
                name: 'Return to Accommodation 💤',
                emoji: '💤',
                duration: 30,
                startMins: currentMins,
                endMins: currentMins + 30,
                desc: 'Head back to your base hotel for rest.'
            });

            // Build select options
            let timeOptions = '';
            for (let h = 8; h <= 11; h++) {
                for (let m = 0; m < 60; m += 30) {
                    let val = `${h < 10 ? '0' + h : h}:${m === 0 ? '00' : m}`;
                    let label = h >= 12 ? `${h === 12 ? 12 : h % 12}:${m === 0 ? '00' : m} PM` : `${h}:${m === 0 ? '00' : m} AM`;
                    let sel = val === startVal ? 'selected' : '';
                    timeOptions += `<option value="${val}" ${sel}>${label}</option>`;
                }
            }

            // Summary metrics
            let activeTimeStr = formatDuration(totalActiveMins);
            let budgetStrWon = totalBudgetWon > 0 ? `₩${totalBudgetWon.toLocaleString()}` : 'Free / In-Store';
            let budgetStrZar = totalBudgetZar > 0 ? `≈ R${totalBudgetZar.toLocaleString()}` : '';
            let budgetDisplay = budgetStrZar ? `${budgetStrWon} (${budgetStrZar})` : budgetStrWon;

            let timelineWarningHtml = '';
            if (totalActiveMins > 480) {
                timelineWarningHtml = `
                    <div style="font-size:0.68rem; color:var(--accent); font-weight:600; display:flex; align-items:center; gap:4px; margin-top:2px;">
                        <i class="fa-solid fa-triangle-exclamation"></i> Packed schedule! Pace yourself.
                    </div>
                `;
            }

            let html = `
                <div class="timeline-summary-bar">
                    <div class="timeline-summary-stats">
                        <div>Active Time: <span>${activeTimeStr}</span></div>
                        <div style="margin-left: 8px;">Est. Budget: <span>${budgetDisplay}</span></div>
                        ${timelineWarningHtml}
                    </div>
                    <div class="timeline-start-select-container">
                        <label for="start-select-${dayNum}">Start Day:</label>
                        <select class="timeline-start-select" id="start-select-${dayNum}" onchange="changeTimelineStartTime(${dayNum}, this.value)">
                            ${timeOptions}
                        </select>
                    </div>
                </div>
                <div class="timeline-track">
            `;

            html += scheduledEvents.map(ev => {
                let nodeClass = ev.type;
                let nodeIcon = ev.type === 'transit' ? '<i class="fa-solid fa-route"></i>' :
                               ev.type === 'rest' ? '<i class="fa-solid fa-bed"></i>' :
                               ev.type === 'lock' ? '<i class="fa-solid fa-lock"></i>' :
                               ev.type === 'food' ? '<i class="fa-solid fa-utensils"></i>' :
                               '<i class="fa-solid fa-star"></i>';
                
                if (ev.type === 'transit' && ev.icon) {
                    nodeIcon = `<i class="${ev.icon}"></i>`;
                }

                if (ev.type === 'transit') {
                    let conflictStyle = ev.conflict ? 'style="color:#d84315; font-weight:bold;"' : '';
                    return `
                        <div class="timeline-transit-buffer">
                            <div class="timeline-node transit">${nodeIcon}</div>
                            <span ${conflictStyle}>${ev.name} (${ev.duration} min) — ${formatMinsToTime(ev.startMins)} - ${formatMinsToTime(ev.endMins)}</span>
                        </div>
                    `;
                }

                let costChip = ev.cost ? `<span class="timeline-event-duration" style="background:rgba(200, 150, 62, 0.08); color:var(--accent); font-weight:700;"><i class="fa-solid fa-won-sign"></i> ${ev.cost}</span>` : '';
                let tipHtml = ev.tips ? `<div class="timeline-event-tip"><i class="fa-solid fa-lightbulb" style="color:var(--accent); margin-right:4px;"></i>${ev.tips}</div>` : '';
                
                let titleHtml = ev.id ? 
                    `<span class="timeline-event-name-link" onclick="showActivityById('${ev.id}')">${ev.emoji} ${ev.name}</span>` :
                    `<span>${ev.emoji} ${ev.name}</span>`;

                let mapBtn = ev.mapLink ? `<a href="${ev.mapLink}" target="_blank" style="text-decoration:none; color:var(--accent); font-weight:600;"><i class="fa-solid fa-map-location-dot"></i> Maps</a>` : '';
                let linkBtn = ev.link && ev.link !== '#' ? `<a href="${ev.link}" target="_blank" style="text-decoration:none; color:var(--primary-light); font-weight:600; margin-left:10px;"><i class="fa-solid fa-globe"></i> Details</a>` : '';
                
                let actionRow = (mapBtn || linkBtn) ? `
                    <div style="margin-top: 8px; font-size: 0.65rem; display: flex; align-items: center; justify-content: flex-end; border-top: 1px dashed var(--border); padding-top: 6px;">
                        ${mapBtn}
                        ${linkBtn}
                    </div>
                ` : '';

                let overlapWarning = ev.conflict ? `
                    <div style="color:#d84315; font-size:0.68rem; font-weight:700; display:flex; align-items:center; gap:4px; margin-bottom:4px;">
                        <i class="fa-solid fa-circle-exclamation"></i> Overlap Warning! Prior activities overrun this slot.
                    </div>
                ` : '';

                return `
                    <div class="timeline-event">
                        <div class="timeline-node ${nodeClass}">${nodeIcon}</div>
                        <div class="timeline-card">
                            ${overlapWarning}
                            <div class="timeline-time-badge">
                                <i class="fa-regular fa-clock"></i> ${formatMinsToTime(ev.startMins)} - ${formatMinsToTime(ev.endMins)}
                            </div>
                            <div class="timeline-event-title">
                                ${titleHtml}
                                <span class="timeline-event-duration">${ev.durationStr || formatDuration(ev.duration)}</span>
                            </div>
                            <div class="timeline-event-desc">${ev.desc}</div>
                            <div class="timeline-event-meta">
                                ${ev.neighbourhood ? `<span><i class="fa-solid fa-location-dot"></i> ${HOOD_LABELS[ev.neighbourhood] || ev.neighbourhood}</span>` : ''}
                                ${costChip}
                            </div>
                            ${tipHtml}
                            ${actionRow}
                        </div>
                    </div>
                `;
            }).join('');

            html += `
                </div>
            `;
            return html;
        }

        // --- Drag & Drop Core Handlers ---
        function setupDropZoneListeners() {
            const slots = document.querySelectorAll('.time-slot:not(.locked-slot)');
            
            slots.forEach(slot => {
                slot.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    if (itineraryLocked) return;
                    
                    const dayNum = parseInt(slot.getAttribute('data-day-num'));
                    const day = days.find(d => d.dayNum === dayNum);
                    const act = activityById(draggedActivityId);

                    if (act && day) {
                        // Region checking
                        const isValidRegion = regionOk(act.region, day.region);

                        if (isValidRegion) {
                            slot.classList.add('drag-over');
                            
                            // Highlight the specific target card if we are dragging over one
                            const targetCard = e.target.closest('.slot-card');
                            slot.querySelectorAll('.slot-card').forEach(c => {
                                if (c !== targetCard) {
                                    c.classList.remove('drag-target-highlight');
                                }
                            });
                            
                            if (targetCard && targetCard.getAttribute('data-activity-id') !== draggedActivityId) {
                                targetCard.classList.add('drag-target-highlight');
                            }
                        } else {
                            slot.classList.add('drag-invalid');
                        }
                    }
                });

                slot.addEventListener('dragleave', () => {
                    slot.classList.remove('drag-over', 'drag-invalid');
                    slot.querySelectorAll('.slot-card').forEach(c => c.classList.remove('drag-target-highlight'));
                });

                slot.addEventListener('drop', (e) => {
                    e.preventDefault();
                    slot.classList.remove('drag-over', 'drag-invalid');
                    slot.querySelectorAll('.slot-card').forEach(c => c.classList.remove('drag-target-highlight'));
                    if (itineraryLocked) return;
                    
                    const activityId = e.dataTransfer.getData('text/plain') || draggedActivityId;
                    const dayNum = parseInt(slot.getAttribute('data-day-num'));
                    const timeSlot = slot.getAttribute('data-time-slot');
                    
                    // Identify if drop target is a slot card or inside one
                    const targetCard = e.target.closest('.slot-card');
                    const targetCardId = targetCard ? targetCard.getAttribute('data-activity-id') : null;
                    
                    if (activityId) {
                        placeActivity(activityId, dayNum, timeSlot, draggedSourceSlot, targetCardId);
                    }
                });
            });
        }

        function acceptSuggestion(dayNum, timeSlot, activityId) {
            if (itineraryLocked) { showToast("Itinerary Locked", "Unlock your itinerary to add activities.", "warning"); return; }
            placeActivity(activityId, dayNum, timeSlot, null);
        }

        function removeActivityFromSlot(dayNum, timeSlot, activityId = null) {
            if (itineraryLocked) {
                showToast("Itinerary Locked", "Unlock your itinerary to remove activities.", "warning");
                return;
            }
            const key = `day-${dayNum}-${timeSlot}`;
            if (activityId) {
                const val = activeItinerary[key] || '';
                const parts = val.split(';').filter(id => id.trim() !== '' && id !== activityId);
                if (parts.length > 0) {
                    activeItinerary[key] = parts.join(';');
                } else {
                    delete activeItinerary[key];
                }
                const act = activityById(activityId);
                const name = act ? act.name : "activity";
                showToast("Activity Removed", `Removed '${name}' from ${timeSlot} slot on Day ${dayNum}.`, "warning");
            } else {
                delete activeItinerary[key];
                showToast("Slot Cleared", `Cleared all activities in ${timeSlot} slot on Day ${dayNum}.`, "warning");
            }
            saveCurrentItinerary();
            renderPlannerCanvas();
        }

        window.moveActivityInSlot = function(dayNum, timeSlot, activityId, direction) {
            if (itineraryLocked) {
                showToast("Itinerary Locked", "Unlock your itinerary to reorder activities.", "warning");
                return;
            }
            const key = `day-${dayNum}-${timeSlot}`;
            const val = activeItinerary[key] || '';
            const parts = val.split(';').filter(id => id.trim() !== '');
            const idx = parts.indexOf(activityId);
            if (idx === -1) return;
            
            const targetIdx = idx + direction;
            if (targetIdx < 0 || targetIdx >= parts.length) return;
            
            // Swap
            const temp = parts[idx];
            parts[idx] = parts[targetIdx];
            parts[targetIdx] = temp;
            
            activeItinerary[key] = parts.join(';');
            saveCurrentItinerary();
            renderPlannerCanvas();
            showToast("Order Updated", "Activity order updated.", "success");
        };

        // --- Modals Engine ---
        function openDetailsModal(activity) {
            window._detailsActivityId = activity.id;
            // When opened from the slot picker, offer "Add to this slot" right here
            const slotAddBtn = document.getElementById('m-add-to-slot');
            if (slotAddBtn) {
                const sheet = document.getElementById('slotPicker');
                const pickerOpen = sheet && sheet.style.display !== 'none' && typeof _spTargetDay !== 'undefined' && _spTargetDay !== null;
                slotAddBtn.style.display = pickerOpen ? 'inline-flex' : 'none';
                if (pickerOpen) {
                    const tLabel = _spTargetTime.charAt(0).toUpperCase() + _spTargetTime.slice(1);
                    slotAddBtn.innerHTML = `<i class="fa-solid fa-plus"></i> Add to Day ${_spTargetDay} · ${tLabel}`;
                }
            }
            document.getElementById('m-title').textContent = activity.name;
            document.getElementById('m-desc').textContent = activity.desc;
            document.getElementById('m-cost').textContent = activity.cost;
            document.getElementById('m-duration').textContent = activity.duration;
            document.getElementById('m-region').textContent = activity.region;
            document.getElementById('m-type').textContent = activity.isIndoor ? "Indoor (Monsoon Safe)" : "Outdoor (Weather Sensitive)";
            document.getElementById('m-link').href = activity.link;

            const menuBtn = document.getElementById('m-menu-link');
            if (menuBtn) {
                if (activity.menuLink) {
                    menuBtn.href = activity.menuLink;
                    menuBtn.style.display = 'inline-flex';
                } else {
                    menuBtn.style.display = 'none';
                }
            }

            // Load and display graphic image in modal (custom matching or regional defaults)
            let imgName = 'ahyeon_cathedral.png';
            const customImages = {
                'a-hanbok': 'hanbok_palace.png',
                'r-tongin': 'tongin_market_lunch.png',
                'a-secretgarden': 'secret_garden_pond.png',
                'a-kbo': 'kbo_baseball_stadium.png',
                'a-gamcheon': 'gamcheon_village.png',
                'a-nseoultower': 'nseoul_tower.png',
                'a-starfield': 'starfield_library.png',
                'a-diamond': 'diamond_bay_yacht.png',
                'a-hanriver': 'han_river_picnic.png',
                'a-lolpark': 'lol_park.png',
                'a-noraebang': 'noraebang.png',
                'a-skycapsule': 'sky_capsule.png'
            };

            if (customImages[activity.id]) {
                imgName = customImages[activity.id];
            } else if (activity.region === 'Busan') {
                imgName = 'oryukdo_busan.png';
            } else if (activity.region === 'Seoul 1' || activity.region === 'Seoul 3') {
                imgName = 'gyeongbokgung_seoul.png';
            }
            const modalImg = document.getElementById('m-img');
            if (modalImg) {
                modalImg.src = 'images/' + imgName;
                modalImg.alt = activity.name;
                modalImg.style.display = 'block';
            }

            // Load dynamic Traveler Tips / Reddit advice
            const tipsText = activity.tips || "Ask locals or check Naver/Kakao Maps for current opening hours and the best transport route.";
            const tipsEl = document.getElementById('m-tips');
            if (tipsEl) {
                tipsEl.textContent = tipsText;
            }

            // Trigger ZAR dynamic conversion inside modal
            setTimeout(() => {
                const modal = document.getElementById('detailsModal');
                const walker = document.createTreeWalker(modal, NodeFilter.SHOW_TEXT);
                const RATE = 0.0108;
                const fmtR = v => 'R' + Math.round(v).toLocaleString('en-US');
                const numVal = s => parseFloat(s.replace(/[^0-9]/g, ''));
                
                let n;
                while (n = walker.nextNode()) {
                    let val = n.nodeValue;
                    if (val.includes('₩') && !val.includes('≈R')) {
                        let matches = val.match(/₩\s?([\d,]+)(k)?/);
                        if (matches) {
                            let k = matches[2];
                            let amount = numVal(matches[1]);
                            if (k) amount *= 1000;
                            n.nodeValue = val + ` (≈${fmtR(amount * RATE)})`;
                        }
                    }
                }
            }, 50);

            document.getElementById('detailsModal').classList.add('active');
        }

        function showActivityById(activityId) {
            const act = activities.find(a => a.id === activityId);
            if (act) openDetailsModal(act);
        }

        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        // --- Questionnaire / Recommendations ---
        function openQuestionnaire() {
            // Reset active step
            document.querySelectorAll('.quest-step').forEach(step => step.classList.remove('active'));
            document.getElementById('questStep-1').classList.add('active');
            
            // Highlight selector states
            selectQuestUser(currentTrackUser);
            
            // Load saved survey state if any
            const savedSurvey = localStorage.getItem(`itinerary_survey_${questSelectedUser}`);
            if (savedSurvey) {
                const survey = JSON.parse(savedSurvey);
                questSelectedInterests = survey.interests || ['culture'];
                questPriorityInterest = survey.priority || 'culture';
                questSelectedPace = survey.pace || 'relaxed';
                questBudgetThreshold = survey.budget || 12000;
                questFoodExclusions = survey.exclusions || [];
                questFoodRankings = survey.rankings || ['bbq', 'stews', 'street', 'cafes'];
                questLayoutChoice = survey.layout || 'auto';
                questFoodWishlist = survey.wishlist || [];
            } else {
                questSelectedInterests = ['culture'];
                questPriorityInterest = 'culture';
                questSelectedPace = 'relaxed';
                questBudgetThreshold = 12000;
                questFoodExclusions = [];
                questFoodRankings = ['bbq', 'stews', 'street', 'cafes'];
                questLayoutChoice = 'auto';
                questFoodWishlist = [];
            }

            // Sync selections to UI
            const keyMap = {
                'fashion': 'qOpt-fashion',
                'culture': 'qOpt-culture',
                'thrills': 'qOpt-thrills',
                'foodie': 'qOpt-foodie'
            };
            for (let key in keyMap) {
                const opt = document.getElementById(keyMap[key]);
                if (opt) {
                    opt.classList.toggle('selected', questSelectedInterests.includes(key));
                }
            }

            // Sync budget slider
            const slider = document.getElementById('questBudgetSlider');
            if (slider) {
                slider.value = questBudgetThreshold;
                updateSurveyBudgetDisplay(questBudgetThreshold);
            }

            // Sync exclusions
            const exclKeys = ['seafood', 'beef', 'pork', 'vegetarian'];
            exclKeys.forEach(k => {
                const el = document.getElementById(`qExcl-${k}`);
                if (el) el.classList.toggle('selected', questFoodExclusions.includes(k));
            });

            // Sync and sort food ranking elements based on questFoodRankings
            const foodContainer = document.getElementById('foodRankContainer');
            if (foodContainer) {
                questFoodRankings.forEach(k => {
                    const el = document.getElementById(`qFood-${k}`);
                    if (el) {
                        foodContainer.appendChild(el);
                    }
                });
            }
            updateFoodRankingsFromDOM();

            // Sync layout choice
            selectQuestLayout(questLayoutChoice);

            // Sync wishlist checkboxes
            const wishlistItems = ['bbq', 'crab', 'chicken', 'noodles', 'soup', 'kalguksu', 'hotteok', 'bingsu', 'convenience'];
            wishlistItems.forEach(item => {
                const el = document.getElementById(`qWish-${item}`);
                if (el) {
                    el.classList.toggle('selected', questFoodWishlist.includes(item));
                }
            });
            
            document.getElementById('questModal').classList.add('active');
        }

        function nextQuestStep(stepNum) {
            document.querySelectorAll('.quest-step').forEach(step => step.classList.remove('active'));
            document.getElementById(`questStep-${stepNum}`).classList.add('active');
        }

        function toggleFoodWishlist(foodItem) {
            if (questFoodWishlist.includes(foodItem)) {
                questFoodWishlist = questFoodWishlist.filter(item => item !== foodItem);
            } else {
                questFoodWishlist.push(foodItem);
            }
            const el = document.getElementById(`qWish-${foodItem}`);
            if (el) {
                el.classList.toggle('selected', questFoodWishlist.includes(foodItem));
            }
        }

        function selectQuestUser(userName) {
            questSelectedUser = userName;
            document.querySelectorAll('#questStep-1 .quest-opt').forEach(opt => {
                opt.classList.toggle('selected', opt.innerText.trim() === userName);
            });
            // Try loading saved data for this specific user when selected
            const savedSurvey = localStorage.getItem(`itinerary_survey_${userName}`);
            if (savedSurvey) {
                const survey = JSON.parse(savedSurvey);
                questSelectedInterests = survey.interests || ['culture'];
                questPriorityInterest = survey.priority || 'culture';
                questSelectedPace = survey.pace || 'relaxed';
                questBudgetThreshold = survey.budget || 12000;
                questFoodExclusions = survey.exclusions || [];
                questFoodRankings = survey.rankings || ['bbq', 'stews', 'street', 'cafes'];
                questLayoutChoice = survey.layout || 'auto';
                questFoodWishlist = survey.wishlist || [];
            } else {
                questFoodWishlist = [];
            }

            // Sync wishlist checkboxes
            const wishlistItems = ['bbq', 'crab', 'chicken', 'noodles', 'soup', 'kalguksu', 'hotteok', 'bingsu', 'convenience'];
            wishlistItems.forEach(item => {
                const el = document.getElementById(`qWish-${item}`);
                if (el) {
                    el.classList.toggle('selected', questFoodWishlist.includes(item));
                }
            });
        }

        function selectQuestInterest(interestName) {
            if (questSelectedInterests.includes(interestName)) {
                if (questSelectedInterests.length > 1) {
                    questSelectedInterests = questSelectedInterests.filter(i => i !== interestName);
                }
            } else {
                questSelectedInterests.push(interestName);
            }
            
            const keyMap = {
                'fashion': 'qOpt-fashion',
                'culture': 'qOpt-culture',
                'thrills': 'qOpt-thrills',
                'foodie': 'qOpt-foodie'
            };
            for (let key in keyMap) {
                const opt = document.getElementById(keyMap[key]);
                if (opt) {
                    opt.classList.toggle('selected', questSelectedInterests.includes(key));
                }
            }
        }

        function handleInterestNext() {
            if (questSelectedInterests.length === 0) {
                showToast("Selection Required", "Please select at least one interest.", "warning");
                return;
            }

            if (questSelectedInterests.length >= 3) {
                const container = document.getElementById('questPriorityOptions');
                container.innerHTML = '';

                const interestLabels = {
                    'fashion': '<i class="fa-solid fa-shirt"></i> Fashion, Trends & Aesthetics',
                    'culture': '<i class="fa-solid fa-monument"></i> History, Heritage & Palaces',
                    'thrills': '<i class="fa-solid fa-wand-magic-sparkles"></i> Theme Parks, Games & Thrills',
                    'foodie': '<i class="fa-solid fa-utensils"></i> Traditional Markets & Food Hunts'
                };

                if (!questSelectedInterests.includes(questPriorityInterest)) {
                    questPriorityInterest = questSelectedInterests[0];
                }

                questSelectedInterests.forEach(interest => {
                    const opt = document.createElement('div');
                    opt.className = 'quest-opt';
                    if (interest === questPriorityInterest) {
                        opt.classList.add('selected');
                    }
                    opt.innerHTML = interestLabels[interest];
                    opt.onclick = () => selectPriority(interest);
                    container.appendChild(opt);
                });

                nextQuestStep('2b');
            } else {
                questPriorityInterest = questSelectedInterests[0];
                nextQuestStep(3);
            }
        }

        function selectPriority(interest) {
            questPriorityInterest = interest;
            const container = document.getElementById('questPriorityOptions');
            const children = container.children;
            questSelectedInterests.forEach((item, i) => {
                if (children[i]) {
                    children[i].classList.toggle('selected', item === interest);
                }
            });
        }

        function handlePaceBack() {
            if (questSelectedInterests.length >= 3) {
                nextQuestStep('2b');
            } else {
                nextQuestStep(2);
            }
        }

        function selectQuestPace(paceName) {
            questSelectedPace = paceName;
            document.querySelectorAll('#questStep-3 .quest-opt').forEach(opt => {
                opt.classList.toggle('selected', opt.id === `qOpt-${paceName}`);
            });
        }

        function updateSurveyBudgetDisplay(val) {
            questBudgetThreshold = parseInt(val);
            document.getElementById('questBudgetValue').innerText = 'R' + parseInt(val).toLocaleString();
            const usd = Math.round(val / 18.52);
            const krw = Math.round(usd * 1360);
            document.getElementById('questBudgetExchange').innerText = `≈ $${usd.toLocaleString()} USD ≈ ₩${krw.toLocaleString()} KRW`;
        }

        function toggleFoodExclusion(excl) {
            if (questFoodExclusions.includes(excl)) {
                questFoodExclusions = questFoodExclusions.filter(e => e !== excl);
            } else {
                questFoodExclusions.push(excl);
            }
            document.getElementById(`qExcl-${excl}`).classList.toggle('selected', questFoodExclusions.includes(excl));
        }

        function setupFoodDragAndDrop() {
            const container = document.getElementById('foodRankContainer');
            if (!container) return;

            // ── Mouse drag (desktop) ──────────────────────────────────────
            let dragEl = null;

            container.querySelectorAll('.quest-opt').forEach(item => {
                item.setAttribute('draggable', 'true');
            });

            container.addEventListener('dragstart', (e) => {
                const target = e.target.closest('.quest-opt');
                if (target) {
                    dragEl = target;
                    e.dataTransfer.effectAllowed = 'move';
                    setTimeout(() => { target.style.opacity = '0.4'; }, 0);
                }
            });

            container.addEventListener('dragover', (e) => {
                e.preventDefault();
                const target = e.target.closest('.quest-opt');
                if (target && target !== dragEl) {
                    const rect = target.getBoundingClientRect();
                    const next = (e.clientY - rect.top) / (rect.bottom - rect.top) > 0.5;
                    container.insertBefore(dragEl, next ? target.nextSibling : target);
                }
            });

            container.addEventListener('dragend', (e) => {
                const target = e.target.closest('.quest-opt');
                if (target) target.style.opacity = '1';
                updateFoodRankingsFromDOM();
            });

            // ── Touch drag (iOS / Android) ────────────────────────────────
            let touchDragEl = null;
            let touchClone  = null;
            let touchOffX = 0, touchOffY = 0;

            container.addEventListener('touchstart', (e) => {
                const target = e.target.closest('.quest-opt');
                if (!target) return;
                e.preventDefault();
                touchDragEl = target;
                const rect = target.getBoundingClientRect();
                const touch = e.touches[0];
                touchOffX = touch.clientX - rect.left;
                touchOffY = touch.clientY - rect.top;
                touchClone = target.cloneNode(true);
                touchClone.style.cssText = `
                    position:fixed; left:${rect.left}px; top:${rect.top}px;
                    width:${rect.width}px; pointer-events:none;
                    opacity:0.75; z-index:9999;
                    border-radius:10px; box-shadow:0 8px 24px rgba(0,0,0,0.22);
                    transition:none;
                `;
                document.body.appendChild(touchClone);
                target.style.opacity = '0.35';
            }, { passive: false });

            container.addEventListener('touchmove', (e) => {
                if (!touchDragEl || !touchClone) return;
                e.preventDefault();
                const touch = e.touches[0];
                touchClone.style.left = (touch.clientX - touchOffX) + 'px';
                touchClone.style.top  = (touch.clientY - touchOffY) + 'px';
                touchClone.style.display = 'none';
                const elBelow = document.elementFromPoint(touch.clientX, touch.clientY);
                touchClone.style.display = '';
                const over = elBelow ? elBelow.closest('.quest-opt') : null;
                if (over && over !== touchDragEl && container.contains(over)) {
                    const rect = over.getBoundingClientRect();
                    const next = (touch.clientY - rect.top) / (rect.bottom - rect.top) > 0.5;
                    container.insertBefore(touchDragEl, next ? over.nextSibling : over);
                }
            }, { passive: false });

            const endTouch = () => {
                if (!touchDragEl) return;
                touchDragEl.style.opacity = '1';
                if (touchClone) { touchClone.remove(); touchClone = null; }
                touchDragEl = null;
                updateFoodRankingsFromDOM();
            };
            container.addEventListener('touchend', endTouch);
            container.addEventListener('touchcancel', endTouch);
        }

        function updateFoodRankingsFromDOM() {
            const container = document.getElementById('foodRankContainer');
            if (!container) return;
            const children = Array.from(container.children);
            questFoodRankings = children.map(child => child.getAttribute('data-food-type'));
            // Only update rank badge numbers — do NOT force .selected on all items
            children.forEach((child, idx) => {
                const badge = child.querySelector('.rank-badge');
                if (badge) badge.innerText = idx + 1;
            });

        }

        function selectQuestLayout(layout) {
            questLayoutChoice = layout;
            const autoBtn = document.getElementById('qLayout-auto');
            const manualBtn = document.getElementById('qLayout-manual');
            if (autoBtn) autoBtn.classList.toggle('selected', layout === 'auto');
            if (manualBtn) manualBtn.classList.toggle('selected', layout === 'manual');
        }

        function submitQuestionnaire() {
            closeModal('questModal');
            localStorage.setItem('itinerary_survey_completed', 'true');

            // Save survey selections
            const surveyState = {
                interests: questSelectedInterests,
                priority: questPriorityInterest,
                pace: questSelectedPace,
                budget: questBudgetThreshold,
                exclusions: questFoodExclusions,
                rankings: questFoodRankings,
                layout: questLayoutChoice,
                wishlist: questFoodWishlist
            };
            localStorage.setItem(`itinerary_survey_${questSelectedUser}`, JSON.stringify(surveyState));

            // Build recommendation pools straight from the shared menu data,
            // ranked by how well each item matches THIS survey.
            const poolOtherPicks = getOtherMembersPicks();
            const selectedPool = activities
                .filter(a => a.type !== 'food')
                .filter(a => !isOverBudget(a, questBudgetThreshold))
                .map(a => ({ a, s: matchScore(a, surveyState, poolOtherPicks) }))
                .sort((x, y) => y.s - x.s)
                .map(x => x.a.id);
            const foodPool = activities
                .filter(a => a.type === 'food')
                .filter(a => !isDietExcluded(a, questFoodExclusions))
                .filter(a => !isOverBudget(a, questBudgetThreshold))
                .map(a => ({ a, s: matchScore(a, surveyState, poolOtherPicks) }))
                .sort((x, y) => y.s - x.s)
                .map(x => x.a.id);

            // If auto layout choice, populate itinerary automatically
            if (questLayoutChoice === 'auto') {
                if (questSelectedUser === 'Ayden') {
                    activeItinerary = {
                        'day-2-morning': 'r-hanwoo',
                        'day-2-afternoon': 's-hongdaevintage;a-vr',
                        'day-2-evening': 'r-mapo;a-noraebang',
                        'day-3-morning': 'r-onion;a-hanbok',
                        'day-3-afternoon': 'r-tongin;a-insadong',
                        'day-3-evening': 'r-bora;a-nseoultower',
                        'day-4-morning': 'a-secretgarden',
                        'day-4-afternoon': 'r-jaeyondo;s-seongsu;s-anderson-bell',
                        'day-4-evening': 'r-sounds-of-apple;r-neungdong-minari',
                        'day-5-morning': 'a-personalcolor',
                        'day-5-afternoon': 's-oy-myeong;s-myeongdong',
                        'day-5-evening': 'r-kyoja;r-chizn-bingsu',
                        'day-6-morning': 'a-cooking',
                        'day-6-afternoon': 'a-theclimb',
                        'day-6-evening': 'a-hanriver',
                        'day-7-morning': 'r-gejang',
                        'day-7-evening': 'r-bonjeon-gukbap;a-choryang-ibagu-gil;r-taeseongdang',
                        'day-8-morning': 'a-skycapsule;r-ops-bakery',
                        'day-8-afternoon': 'a-gamcheon;a-huinnyeoul',
                        'day-8-evening': 'a-gwangalli-beach;a-drones;a-diamond',
                        'day-9-morning': 'a-haedong-yonggungsa',
                        'day-9-afternoon': 'a-luge;a-spaland-centum',
                        'day-9-evening': 'r-amook;r-jagalchi',
                        'day-10-morning': 'a-oryukdo;a-taejongdae',
                        'day-10-evening': 'r-hanwoo',
                        'day-11-morning': 's-namdaemun',
                        'day-11-afternoon': 'a-lolpark;a-cinema',
                        'day-11-evening': 'a-kbo',
                        'day-12-morning': 'a-natmuseum',
                        'day-12-afternoon': 'a-starfield'
                    };
                } else {
                    activeItinerary = {};

                    // Baseline locks
                    activeItinerary['day-3-morning'] = 'a-hanbok';
                    activeItinerary['day-3-afternoon'] = 'r-tongin';
                    activeItinerary['day-4-evening'] = 'a-nseoultower';
                    activeItinerary['day-8-morning'] = 'a-gamcheon';
                    activeItinerary['day-8-evening'] = 'a-drones';
                    activeItinerary['day-9-afternoon'] = 'a-luge';
                    activeItinerary['day-11-evening'] = 'a-kbo';
                    activeItinerary['day-12-afternoon'] = 'a-starfield';

                    // Fill with recommendations
                    if (questSelectedPace === 'packed') {
                        activeItinerary['day-2-afternoon'] = selectedPool[0] || 'a-noraebang';
                        activeItinerary['day-4-afternoon'] = selectedPool[1] || 'a-cooking';
                        activeItinerary['day-5-morning'] = selectedPool[2] || 's-hongdaevintage';
                        activeItinerary['day-5-afternoon'] = selectedPool[3] || 's-oy-myeong';
                        activeItinerary['day-6-evening'] = 'a-hanriver';
                        activeItinerary['day-8-afternoon'] = selectedPool[4] || 'a-songdo';
                        activeItinerary['day-9-morning'] = 'a-uncemetery';
                        activeItinerary['day-11-afternoon'] = 'a-lolpark';

                        // Insert foods
                        activeItinerary['day-2-evening'] = foodPool[0] || 'r-mapo';
                        activeItinerary['day-3-evening'] = foodPool[1] || 'r-gwangjang';
                        activeItinerary['day-5-evening'] = foodPool[2] || 'r-onion';
                        activeItinerary['day-9-evening'] = foodPool[3] || 'r-gukbap';
                    } else {
                        activeItinerary['day-5-afternoon'] = selectedPool[0] || 's-oy-myeong';
                        activeItinerary['day-6-evening'] = 'a-hanriver';
                        activeItinerary['day-8-afternoon'] = selectedPool[1] || 'a-songdo';

                        // Insert foods
                        activeItinerary['day-2-evening'] = foodPool[0] || 'r-mapo';
                        activeItinerary['day-9-evening'] = foodPool[1] || 'r-gukbap';
                    }
                }
            } else {
                activeItinerary = {};
            }

            // Save & switch profile track
            currentTrackUser = questSelectedUser;
            saveCurrentItinerary();
            loadUserTrack(questSelectedUser);
            renderPlannerCanvas();

            showToast("Itinerary Generated", `Recommendations loaded successfully for ${questSelectedUser}!`, "success");
        }

        // --- Toast Engine ---
        function showToast(title, message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast-msg ${type}`;

            let icon = 'fa-circle-check';
            if (type === 'error') icon = 'fa-circle-exclamation';
            if (type === 'warning') icon = 'fa-triangle-exclamation';

            toast.innerHTML = `
                <i class="toast-icon fa-solid ${icon}"></i>
                <div class="toast-body">
                    <h5>${title}</h5>
                    <p>${message}</p>
                </div>
            `;

            container.appendChild(toast);

            // Trigger slide out after 4 seconds
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(10px) scale(0.95)';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // Theme management overrides
        if (localStorage.getItem('theme') === 'dark') {
            document.body.classList.add('dark-theme');
            updateThemeButton(true);
        } else {
            updateThemeButton(false);
        }

        function toggleTheme() {
            const isDark = document.body.classList.toggle('dark-theme');
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
            updateThemeButton(isDark);
        }

        function updateThemeButton(isDark) {
            const btn = document.getElementById('themeToggle');
            if (btn) {
                btn.innerHTML = isDark ? '<i class="fa-solid fa-sun"></i> <span>Light Mode</span>' : '<i class="fa-solid fa-moon"></i> <span>Dark Mode</span>';
            }
        }

        function toggleItineraryLock() {
            itineraryLocked = !itineraryLocked;
            const btn = document.getElementById('lockItineraryBtn');
            const aiBtn = document.getElementById('generateAIGuideBtn');
            if (btn) {
                if (itineraryLocked) {
                    btn.innerHTML = '<i class="fa-solid fa-lock"></i> Itinerary Locked';
                    btn.style.backgroundColor = '#d84315';
                    btn.style.color = '#fff';
                    showToast("Itinerary Locked", "Planner edits are locked. AI Travel Guide is now ready to generate!", "success");
                    if (aiBtn) {
                        aiBtn.disabled = false;
                        aiBtn.style.opacity = '1';
                        aiBtn.style.cursor = 'pointer';
                        aiBtn.innerText = 'Generate AI Travel Guide';
                    }
                } else {
                    btn.innerHTML = '<i class="fa-solid fa-lock-open"></i> Lock Itinerary';
                    btn.style.backgroundColor = '';
                    btn.style.color = '';
                    showToast("Itinerary Unlocked", "Planner is editable. Lock your itinerary to generate the AI Travel Guide.", "info");
                    if (aiBtn) {
                        aiBtn.disabled = true;
                        aiBtn.style.opacity = '0.5';
                        aiBtn.style.cursor = 'not-allowed';
                        aiBtn.innerText = 'Lock Itinerary to Generate Guide';
                    }
                    const guideContent = document.getElementById('aiTravelGuideContent');
                    if (guideContent) {
                        guideContent.innerHTML = `<p style="color: var(--text-muted); font-style: italic; text-align: center; padding: 20px 0;"><i class="fa-solid fa-lock" style="font-size: 1.5rem; margin-bottom: 8px; display: block; color: var(--accent);"></i> Please lock your itinerary using the "Lock Itinerary" button at the top to unlock and generate the AI Travel Guide walkthrough.</p>`;
                    }
                }
            }
        }

        function triggerAIGuideGeneration() {
            if (!itineraryLocked) return;
            updateAITravelGuide();
            showToast("Guide Generated", "AI Travel Guide updated based on locked plan.", "success");
        }

        function updateAITravelGuide() {
            const container = document.getElementById('aiTravelGuideContent');
            if (!container) return;

            // Load active user's survey settings
            const savedSurvey = localStorage.getItem(`itinerary_survey_${currentTrackUser}`);
            let userBudget = 5000;
            let interests = [];
            let pace = 'relaxed';
            if (savedSurvey) {
                const survey = JSON.parse(savedSurvey);
                userBudget = survey.budget || 12000;
                interests = survey.interests || [];
                pace = survey.pace || 'relaxed';
            }

            let html = `<p style="margin-top: 0; margin-bottom: 12px; font-weight: 500;">Hello <strong>${currentTrackUser}</strong>! Here is your custom-tailored travel plan guide based on your preferences and active planner canvas:</p>`;
            
            // General budget update
            if (userBudget < 12000) {
                html += `<div style="background: rgba(200, 150, 62, 0.1); border-left: 3px solid var(--accent); padding: 8px 12px; border-radius: var(--radius-sm); margin-bottom: 16px; font-size: 0.8rem; color: var(--accent);">
                    <i class="fa-solid fa-piggy-bank"></i> <strong>Budget Focus:</strong> With a budget threshold of R${userBudget.toLocaleString()}, we have optimized your recommendations to prioritize public parks, historic walking paths, free museums, and local street food. Subway transit is recommended over taxis to save up to ₩30,000 per day.
                </div>`;
            } else {
                html += `<div style="background: rgba(74, 107, 83, 0.1); border-left: 3px solid var(--primary); padding: 8px 12px; border-radius: var(--radius-sm); margin-bottom: 16px; font-size: 0.8rem; color: var(--primary);">
                    <i class="fa-solid fa-gem"></i> <strong>Premium Plan:</strong> With a budget of R${userBudget.toLocaleString()}, you have unlocked premium activities like sunset yacht cruises, color analyses, and top-tier dining. Taxis (especially Kakao T Black) are a viable and comfortable way to navigate Seoul and Busan.
                </div>`;
            }

            let activeDaysCount = 0;
            let dayNarratives = [];

            days.forEach(day => {
                const mornId = activeItinerary[`day-${day.dayNum}-morning`];
                const aftId = activeItinerary[`day-${day.dayNum}-afternoon`];
                const eveId = activeItinerary[`day-${day.dayNum}-evening`];

                if (!mornId && !aftId && !eveId) return;

                activeDaysCount++;
                let dayText = `<div style="margin-bottom: 14px; border-bottom: 1px dashed rgba(255,255,255,0.05); padding-bottom: 12px;">`;
                dayText += `<h4 style="margin: 0 0 6px 0; font-size: 0.9rem; font-weight: 700; color: var(--text-heading);">Day ${day.dayNum} (${day.dateStr}) — ${day.summary}</h4>`;
                
                let activitiesToday = [];
                if (mornId) {
                    const names = mornId.split(';').map(id => {
                        const act = activities.find(a => a.id === id);
                        return act ? `<strong>${act.name}</strong>` : '';
                    }).filter(Boolean);
                    if (names.length > 0) activitiesToday.push(`${names.join(' and ')} in the morning`);
                }
                if (aftId) {
                    const names = aftId.split(';').map(id => {
                        const act = activities.find(a => a.id === id);
                        return act ? `<strong>${act.name}</strong>` : '';
                    }).filter(Boolean);
                    if (names.length > 0) activitiesToday.push(`${names.join(' and ')} in the afternoon`);
                }
                if (eveId) {
                    const names = eveId.split(';').map(id => {
                        const act = activities.find(a => a.id === id);
                        return act ? `<strong>${act.name}</strong>` : '';
                    }).filter(Boolean);
                    if (names.length > 0) activitiesToday.push(`${names.join(' and ')} in the evening`);
                }

                dayText += `<p style="margin: 0 0 6px 0; color: var(--text-main);">Today you have scheduled: ${activitiesToday.join(', ')}.</p>`;

                // Generate tips for today
                let tips = [];

                // Transit advice
                if (day.region === 'Seoul 1') {
                    tips.push(`🚇 <strong>Transit:</strong> Seoul 1 (historic center) is highly walkable, but use the subway (Line 1, 3) to skip heavy central Seoul traffic.`);
                } else if (day.region === 'Seoul 3') {
                    tips.push(`🚇 <strong>Transit:</strong> Gangnam/Jamsil (Seoul 3) is best reached by Subway Line 2 or Line 9 express trains.`);
                } else if (day.region === 'Busan') {
                    tips.push(`🚕 <strong>Transit:</strong> In Busan, coastal spots are far apart. Taking a Kakao T taxi between Haeundae, Gamcheon, and Gwangalli will save you hours compared to city buses.`);
                }

                // Monsoon and Clothing advisory
                let hasOutdoor = false;
                [mornId, aftId, eveId].forEach(id => {
                    if (id) {
                        const act = activities.find(a => a.id === id);
                        if (act && !act.isIndoor) hasOutdoor = true;
                    }
                });
                if (hasOutdoor) {
                    tips.push(`🌧️ <strong>Weather & Gear:</strong> You have outdoor plans today. Late June/July is monsoon season, so pack a compact umbrella, waterproof shoes, and keep a backup indoor activity (like a cozy cafe or museum) ready.`);
                } else {
                    tips.push(`👕 <strong>Clothing:</strong> Cozy indoor settings today. A light jacket is useful as indoor spaces in Korea keep air-conditioning very high in summer.`);
                }

                // Facility Closure check
                [mornId, aftId, eveId].forEach(id => {
                    if (id) {
                        const act = activities.find(a => a.id === id);
                        if (act && act.closedDay !== undefined) {
                            const date = new Date(2026, 5, 26 + day.dayNum);
                            const dayOfWeek = date.getDay();
                            if (dayOfWeek === act.closedDay) {
                                const daysNames = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
                                tips.push(`⚠️ <strong>Closure Alert:</strong> <strong>${act.name}</strong> is scheduled today, but it is typically CLOSED on ${daysNames[act.closedDay]}s. Double-check details!`);
                            }
                        }
                    }
                });

                // Nearby dining recommendations
                let recommendedDining = [];
                activities.forEach(act => {
                    if (act.type === 'food' && act.region === day.region) {
                        recommendedDining.push(act.name);
                    }
                });
                if (recommendedDining.length > 0) {
                    const choices = recommendedDining.slice(0, 2);
                    tips.push(`🍴 <strong>Nearby Food:</strong> While in the ${day.region} region today, check out local spots like <em>${choices.join('</em> or <em>')}</em>.`);
                }

                dayText += `<ul style="margin: 0; padding-left: 18px; font-size: 0.82rem; color: var(--text-muted); list-style-type: none;">`;
                tips.forEach(tip => {
                    dayText += `<li style="margin-bottom: 4px; text-indent: -14px; padding-left: 14px;">${tip}</li>`;
                });
                dayText += `</ul></div>`;

                dayNarratives.push(dayText);
            });

            if (activeDaysCount === 0) {
                html += `<p style="color: var(--text-muted); font-style: italic;">No activities have been placed on the canvas yet. Drag items from the sidebar to compile your conversational day-by-day travel guide narrative!</p>`;
            } else {
                html += dayNarratives.join('');
            }

            container.innerHTML = html;
        }

        window.onbeforeprint = function() {
            const days = document.getElementsByClassName("agenda-day");
            for (let i = 0; i < days.length; i++) {
                days[i].classList.remove("collapsed");
            }
            document.getElementById("printHeading").style.display = "block";
        };

        window.onafterprint = function() {
            document.getElementById("printHeading").style.display = "none";
        };
    </script>
    <script>
        // --- ZAR conversion (South African Rand) ---
        // Rate as of June 2026: 1 KRW = R0.0108  (₩10,000 ≈ R108). Update RATE when rates move.
        (function(){
            const RATE = 0.0108;
            const fmtR = v => 'R' + Math.round(v).toLocaleString('en-US');
            function num(s, k){ let v = parseFloat(s.replace(/,/g,'')); if(k) v *= 1000; return v; }
            function convWon(match, a, ak, b, bk){
                let va = num(a, ak), vb = b ? num(b, bk) : null;
                if (vb !== null && bk && !ak && va < 1000) va *= 1000; // "₩8–25k" → 8k–25k
                if (va < 100) return match; // skip tiny/odd matches
                let out = match + ' (≈' + fmtR(va * RATE);
                if (vb !== null) out += '–' + fmtR(vb * RATE);
                return out + ')';
            }
            function convKRW(match, a, b){
                let va = num(a,false), vb = b ? num(b,false) : null;
                if (va < 100) return match;
                let out = match + ' (≈' + fmtR(va * RATE);
                if (vb !== null) out += '–' + fmtR(vb * RATE);
                return out + ')';
            }
            const reWon = /₩\s?([\d][\d,\.]*)(k)?(?:\s?[–—-]\s?₩?\s?([\d][\d,\.]*)(k)?)?/g;
            const reKRW = /([\d][\d,]{2,})(?:\s?[–—-]\s?([\d][\d,]{2,}))?\s?KRW/g;
            const walker = document.createTreeWalker(document.body, NodeFilter.SHOW_TEXT, {
                acceptNode: n => (n.parentNode && /^(SCRIPT|STYLE)$/.test(n.parentNode.nodeName)) ? NodeFilter.FILTER_REJECT : NodeFilter.FILTER_ACCEPT
            });
            const nodes = [];
            while (walker.nextNode()) nodes.push(walker.currentNode);
            nodes.forEach(n => {
                const t = n.nodeValue;
                if (!t || t.indexOf('≈R') !== -1) return;
                if (t.indexOf('₩') === -1 && t.indexOf('KRW') === -1) return;
                let nt = t.replace(reWon, convWon);
                nt = nt.replace(reKRW, convKRW);
                if (nt !== t) n.nodeValue = nt;
            });
        })();
    </script>

    <!-- ── Food Wishlist Tooltip DOM + Logic ──────────────────────── -->
    <div id="foodTooltip" role="tooltip" aria-live="polite">
        <button class="food-sheet-close" onclick="hideFoodTip(); document.getElementById('foodTooltip').classList.remove('visible');" style="position:absolute; top:10px; right:10px; z-index:2;"><i class="fa-solid fa-xmark"></i></button>
        <div class="ft-hero" id="ftHero"></div>
        <div class="ft-body">
            <div class="ft-name" id="ftName"></div>
            <div class="ft-desc" id="ftDesc"></div>
            <div class="ft-tags" id="ftTags"></div>
            <div class="ft-ingredients" id="ftIngredients"></div>
        </div>
    </div>

    <script>
    (function() {
        const FOOD_DATA = {
            bbq: {
                name: 'K-BBQ / Samgyeopsal',
                emoji: '🥩',
                bg: 'linear-gradient(135deg, #c0392b 0%, #e67e22 100%)',
                description: 'Thick pork belly grilled tableside until golden & crispy — wrap it in lettuce with fermented paste and garlic. The ultimate Korean social dining ritual.',
                tags: ['Smoky', 'Rich', 'Communal', 'Must-Try'],
                ingredients: ['Pork belly', 'Lettuce wraps', 'Ssamjang', 'Garlic', 'Kimchi']
            },
            crab: {
                name: 'Raw Marinated Crab',
                emoji: '🦀',
                bg: 'linear-gradient(135deg, #1a3a4a 0%, #2980b9 100%)',
                description: 'Called the "rice thief" — raw crab cured in soy sauce until silky. The roe is intensely umami-rich and almost buttery. Eat with warm rice.',
                tags: ['Umami', 'Salty', 'Sweet', 'Bold'],
                ingredients: ['Raw crab', 'Soy sauce', 'Garlic', 'Ginger', 'Red chili', 'Sesame']
            },
            chicken: {
                name: 'Fried Chicken (Chimaek)',
                emoji: '🍗',
                bg: 'linear-gradient(135deg, #f39c12 0%, #e74c3c 100%)',
                description: 'Double-fried for an impossibly thin, shatteringly crisp shell. Glazed in sweet-spicy gochujang or soy-garlic sauce. Always paired with cold beer — hence "Chimaek" (chicken + maekju).',
                tags: ['Crispy', 'Spicy', 'Sweet-Savory', 'Addictive'],
                ingredients: ['Chicken', 'Gochujang glaze', 'Soy-garlic sauce', 'Pickled radish', 'Beer']
            },
            noodles: {
                name: 'Buckwheat Noodles',
                emoji: '🍜',
                bg: 'linear-gradient(135deg, #27ae60 0%, #2ecc71 100%)',
                description: 'Chewy, earthy noodles served ice-cold in a tangy broth (Mul Naengmyeon) or tossed in perilla oil (Deulkkae Guksu). Refreshing and deeply satisfying — especially in summer.',
                tags: ['Earthy', 'Tangy', 'Refreshing', 'Light'],
                ingredients: ['Buckwheat noodles', 'Cold broth / perilla oil', 'Cucumber', 'Boiled egg', 'Asian pear']
            },
            soup: {
                name: 'Pork Soup / Gukbap',
                emoji: '🍲',
                bg: 'linear-gradient(135deg, #7f8c8d 0%, #bdc3c7 100%)',
                description: 'A Busan soul-food staple — milky pork bone broth ladled over rice with tender meat and chive kimchi. Hearty, warming and incredibly affordable at any pojangmacha.',
                tags: ['Hearty', 'Warming', 'Milky', 'Savory'],
                ingredients: ['Pork bones', 'Rice', 'Chive kimchi', 'Doenjang paste', 'Green onion']
            },
            kalguksu: {
                name: 'Mandu & Kalguksu',
                emoji: '🥟',
                bg: 'linear-gradient(135deg, #8e44ad 0%, #d35400 100%)',
                description: 'Hand-cut wheat noodles simmered in anchovy or chicken broth, often served with plump fried or steamed dumplings. Tongin Market in Seoul is the spiritual home of this dish.',
                tags: ['Comforting', 'Silky', 'Mild', 'Filling'],
                ingredients: ['Hand-cut noodles', 'Dumplings', 'Anchovy broth', 'Zucchini', 'Clams']
            },
            hotteok: {
                name: 'Hotteok Sweet Pancakes',
                emoji: '🥞',
                bg: 'linear-gradient(135deg, #c0392b 0%, #f39c12 100%)',
                description: 'Chewy dough filled with brown sugar, cinnamon and crushed nuts — pressed flat on a hot griddle until caramelised. A Busan street-food classic, best eaten piping hot in winter.',
                tags: ['Sweet', 'Caramelized', 'Chewy', 'Street Food'],
                ingredients: ['Wheat dough', 'Brown sugar', 'Cinnamon', 'Peanuts/seeds', 'Honey']
            },
            bingsu: {
                name: 'Bingsu Shaved Ice',
                emoji: '🍧',
                bg: 'linear-gradient(135deg, #2980b9 0%, #6dd5fa 100%)',
                description: 'Ultra-fine shaved milk ice topped with sweet red bean, condensed milk, fruit or matcha. Far lighter and fluffier than a snow-cone — it melts on your tongue. Perfect for Korean summer heat.',
                tags: ['Cool', 'Sweet', 'Light', 'Photogenic'],
                ingredients: ['Milk ice', 'Red bean (patbingsu)', 'Condensed milk', 'Mochi', 'Fresh fruit']
            },
            convenience: {
                name: 'Korean Convenience Store Hacks',
                emoji: '🏪',
                bg: 'linear-gradient(135deg, #16213e 0%, #0f3460 100%)',
                description: 'GS25 & CU stores are a foodie destination! Try triangle gimbap, spicy rice cakes, instant ramen (with FREE hot water), banana milk, honey butter chips, and corn dogs. Crazy affordable, open 24/7.',
                tags: ['Budget-Friendly', 'Quick', 'Unique', '24/7'],
                ingredients: ['Triangle gimbap', 'Tteokbokki', 'Banana milk', 'Honey butter chips', 'Ramyeon']
            }
        };

        // Detect mobile / touch
        const isTouchDevice = () => window.matchMedia('(max-width: 899px)').matches;

        let _tipTimeout = null;

        // Populate food detail into either bottom-sheet (mobile) or floating tooltip (desktop)
        window.showFoodTipByKey = function(key) {
            const d = FOOD_DATA[key];
            if (!d) return;

            if (isTouchDevice()) {
                // Mobile: slide up bottom-sheet
                const sheet = document.getElementById('foodSheet');
                document.getElementById('fsHero').style.background = d.bg;
                document.getElementById('fsHero').textContent = d.emoji;
                document.getElementById('fsName').textContent = d.name;
                document.getElementById('fsDesc').textContent = d.description;
                document.getElementById('fsTags').innerHTML = d.tags.map(t => `<span class="ft-tag">${t}</span>`).join('');
                document.getElementById('fsIngredients').innerHTML = `<strong>Key Flavours:</strong> ${d.ingredients.join(' · ')}`;
                sheet.style.display = 'block';
                requestAnimationFrame(() => sheet.classList.add('open'));
            } else {
                // Desktop: show centred floating tooltip on click
                const tip = document.getElementById('foodTooltip');
                document.getElementById('ftHero').style.background = d.bg;
                document.getElementById('ftHero').textContent = d.emoji;
                document.getElementById('ftName').textContent = d.name;
                document.getElementById('ftDesc').textContent = d.description;
                document.getElementById('ftTags').innerHTML = d.tags.map(t => `<span class="ft-tag">${t}</span>`).join('');
                document.getElementById('ftIngredients').innerHTML = `<strong>Key Flavours:</strong> ${d.ingredients.join(' · ')}`;
                const rect = tip.getBoundingClientRect();
                tip.style.position = 'fixed';
                tip.style.left = '50%';
                tip.style.top = '50%';
                tip.style.transform = 'translate(-50%, -50%) scale(1)';
                tip.style.pointerEvents = 'auto';
                tip.classList.add('visible');
                clearTimeout(_tipTimeout);
            }
        };

        // Legacy hover trigger (desktop only — no-op on mobile)
        window.showFoodTip = function(e, key) {
            if (isTouchDevice()) return;
            showFoodTipByKey(key);
        };

        window.hideFoodTip = function() {
            _tipTimeout = setTimeout(() => {
                const tip = document.getElementById('foodTooltip');
                tip.classList.remove('visible');
                tip.style.pointerEvents = 'none';
            }, 120);
        };

        window.closeFoodSheet = function() {
            const sheet = document.getElementById('foodSheet');
            sheet.classList.remove('open');
            setTimeout(() => { sheet.style.display = 'none'; }, 360);
        };

        // Mobile sidebar tab helpers
        window.openSidebarMobile = function() {
            const sidebar = document.getElementById('plannerSidebar');
            const backdrop = document.getElementById('sidebarBackdrop');
            sidebar.classList.remove('collapsed');
            sidebarCollapsed = false;
            backdrop.classList.add('visible');
            document.getElementById('mobileTabDiscover').classList.add('active');
            document.getElementById('mobileTabItinerary').classList.remove('active');
        };

        window.closeSidebarMobile = function() {
            const sidebar = document.getElementById('plannerSidebar');
            const backdrop = document.getElementById('sidebarBackdrop');
            sidebar.classList.add('collapsed');
            sidebarCollapsed = true;
            backdrop.classList.remove('visible');
            document.getElementById('mobileTabDiscover').classList.remove('active');
            document.getElementById('mobileTabItinerary').classList.add('active');
            const canvas = document.querySelector('.planner-canvas');
            if (canvas) canvas.scrollIntoView({ behavior: 'smooth', block: 'start' });
        };

        function positionTip(e, tip) {
            const TW = 268, TH = 260;
            const vw = window.innerWidth, vh = window.innerHeight;
            let x = e.clientX + 16;
            let y = e.clientY - 60;
            if (x + TW > vw - 10) x = e.clientX - TW - 16;
            if (y + TH > vh - 10) y = vh - TH - 10;
            if (y < 10) y = 10;
            tip.style.left = x + 'px';
            tip.style.top  = y + 'px';
        }
    })();

    // ── Slot Picker ──────────────────────────────────────────────────────
    let _spTargetDay = null, _spTargetTime = null, _spCatFilter = 'all';

    document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape') return;
        const dm = document.getElementById('detailsModal');
        if (dm && dm.classList.contains('active')) { closeModal('detailsModal'); return; }
        if (document.getElementById('slotPicker').style.display !== 'none') closeSlotPicker();
    });

    window.openSlotPicker = function(dayNum, time, label) {
        _spTargetDay = dayNum;
        _spTargetTime = time;
        _spCatFilter = 'all';

        // Set header label
        document.getElementById('spSlotLabel').textContent = label;
        document.getElementById('spSearch').value = '';

        // Reset filter chips
        document.querySelectorAll('.sp-filter').forEach(b => b.classList.toggle('active', b.dataset.cat === 'all'));

        // Render list
        renderSlotPicker();

        // Show overlay + sheet
        const overlay = document.getElementById('slotPickerOverlay');
        const sheet   = document.getElementById('slotPicker');
        overlay.style.display = 'block';
        sheet.style.display   = 'flex';
        requestAnimationFrame(() => sheet.style.transform = 'translateY(0)');
    };

    window.closeSlotPicker = function() {
        _spTargetDay = null;
        _spTargetTime = null;
        const sheet   = document.getElementById('slotPicker');
        const overlay = document.getElementById('slotPickerOverlay');
        sheet.style.transform = 'translateY(110%)';
        setTimeout(() => {
            sheet.style.display   = 'none';
            overlay.style.display = 'none';
        }, 360);
    };

    window.setSpFilter = function(cat) {
        _spCatFilter = cat;
        document.querySelectorAll('.sp-filter').forEach(b => b.classList.toggle('active', b.dataset.cat === cat));
        renderSlotPicker();
    };

    window.renderSlotPicker = function() {
        const list   = document.getElementById('spList');
        const query  = (document.getElementById('spSearch').value || '').toLowerCase();
        const survey = getSurveyFor(currentTrackUser);
        const otherPicks = getOtherMembersPicks();

        // Determine day region so we can filter region-compatible items
        const day = days.find(d => d.dayNum === _spTargetDay);
        const dayRegion = day ? day.region : 'Any';

        // Score + filter (applies the user's survey: diet, budget, region)
        const spExclusions = survey ? (survey.exclusions || []) : [];
        const spBudget = survey ? (survey.budget || 12000) : 12000;
        let spHiddenDiet = 0, spHiddenBudget = 0;
        let items = activities
            .filter(a => {
                // Skip already placed in this exact slot
                if (activeItinerary[`day-${_spTargetDay}-${_spTargetTime}`] === a.id) return false;
                // Region check
                if (!regionOk(a.region, dayRegion)) return false;
                // Survey: dietary exclusions + budget threshold
                if (isDietExcluded(a, spExclusions)) { spHiddenDiet++; return false; }
                if (isOverBudget(a, spBudget)) { spHiddenBudget++; return false; }
                // Category filter
                if (_spCatFilter === 'top') {
                    const s = matchScore(a, survey, otherPicks);
                    if (s < 30) return false;
                } else if (_spCatFilter === 'favorites') {
                    const favs = getFavoritesFor(currentTrackUser);
                    if (!favs.includes(a.id)) return false;
                } else if (_spCatFilter !== 'all' && !categoryMatches(a, _spCatFilter)) {
                    return false;
                }
                // Search
                if (query && !(a.name + ' ' + (a.teaser || '') + ' ' + (a.desc || '')).toLowerCase().includes(query)) return false;
                return true;
            })
            .map(a => ({ ...a, _score: matchScore(a, survey, otherPicks) }))
            .sort((a, b) => b._score - a._score || a.name.localeCompare(b.name));

        const spNoteParts = [];
        if (spHiddenDiet) spNoteParts.push(`${spHiddenDiet} hidden by dietary preferences`);
        if (spHiddenBudget) spNoteParts.push(`${spHiddenBudget} hidden by budget`);
        const spNote = spNoteParts.length ? `<p style="text-align:center; color:var(--text-muted); padding:12px 0 4px; font-size:0.7rem; font-style:italic;"><i class="fa-solid fa-filter"></i> ${spNoteParts.join(' · ')}</p>` : '';

        if (!items.length) {
            list.innerHTML = `<p style="text-align:center; color:var(--text-muted); padding:30px 0; font-size:0.85rem;">No activities found matching your filters.</p>` + spNote;
            return;
        }

        list.innerHTML = items.map(a => {
            const alreadyScheduled = Object.values(activeItinerary).includes(a.id);
            const matchBadge = a._score >= 30 ? `<span class="sp-card-match">★ ${a._score}% match</span>` : '';
            const scheduledNote = alreadyScheduled ? `<span style="color:var(--accent); font-size:0.62rem;">Already in your plan</span>` : '';
            
            const favs = getFavoritesFor(currentTrackUser);
            const isFav = favs.includes(a.id);
            const favBtn = `
                <button class="sp-fav-btn ${isFav ? 'active' : ''}" onclick="event.stopPropagation(); toggleFavorite('${a.id}')" title="Toggle Favorite">
                    <i class="${isFav ? 'fa-solid' : 'fa-regular'} fa-star"></i>
                </button>
            `;

            return `
                <div class="sp-card" onclick="showActivityById('${a.id}')">
                    <div class="sp-card-left">
                        <div class="sp-card-emoji">${a.emoji || '📌'}</div>
                        <div class="sp-card-info">
                            <div class="sp-card-name">${a.name}</div>
                            <div class="sp-card-meta">
                                <span>${a.region}</span>
                                ${a.cost ? `<span>${a.cost}</span>` : ''}
                                ${a.duration ? `<span>${a.duration}</span>` : ''}
                                ${matchBadge}
                                ${scheduledNote}
                            </div>
                        </div>
                    </div>
                    <div class="sp-card-btns">
                        ${favBtn}
                        <button class="sp-info-btn" onclick="event.stopPropagation(); showActivityById('${a.id}')" title="View details, tips & website first">
                            <i class="fa-solid fa-circle-info"></i>
                        </button>
                        <button class="sp-add-btn" onclick="event.stopPropagation(); addFromSlotPicker('${a.id}')" title="Add to slot">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                </div>
            `;
        }).join('') + spNote;
    };

    window.addFromSlotPicker = function(actId) {
        if (_spTargetDay === null || !_spTargetTime) return;
        if (itineraryLocked) { showToast("Itinerary Locked", "Unlock your itinerary to add activities.", "warning"); return; }
        placeActivity(actId, _spTargetDay, _spTargetTime, null);
        closeSlotPicker();
    };



    // ── Swipe gesture: left = close sidebar (go to Itinerary), right = open sidebar (go to Discover)
    (function() {
        let swipeStartX = 0, swipeStartY = 0;
        const THRESHOLD = 60, MAX_VERT = 80;

        document.addEventListener('touchstart', (e) => {
            swipeStartX = e.touches[0].clientX;
            swipeStartY = e.touches[0].clientY;
        }, { passive: true });

        document.addEventListener('touchend', (e) => {
            if (!window.matchMedia('(max-width: 899px)').matches) return;
            const dx = e.changedTouches[0].clientX - swipeStartX;
            const dy = Math.abs(e.changedTouches[0].clientY - swipeStartY);
            if (dy > MAX_VERT) return; // ignore vertical scrolls
            if (dx < -THRESHOLD && !sidebarCollapsed) {
                // Swipe left → go to My Itinerary
                closeSidebarMobile();
            } else if (dx > THRESHOLD && sidebarCollapsed) {
                // Swipe right → go to Discover
                openSidebarMobile();
            }
        }, { passive: true });
    })();
    </script>


</body>
</html>
