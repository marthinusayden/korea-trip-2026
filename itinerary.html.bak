            },
            'Brudene': {
                'day-3-morning': 'a-hanbok',
                'day-3-afternoon': 'r-tongin',
                'day-4-evening': 'a-nseoultower',
                'day-5-morning': 'a-vr',
                'day-5-afternoon': 'a-lolpark',
                'day-6-evening': 'a-hanriver',
                'day-8-morning': 'a-gamcheon',
                'day-8-evening': 'a-drones',
                'day-9-afternoon': 'a-luge',
                'day-11-evening': 'a-kbo',
                'day-12-afternoon': 'a-leeum;a-starfield'
            },
            'Odile': {
                'day-3-morning': 'a-hanbok',
                'day-4-evening': 'a-nseoultower',
                'day-5-morning': 'a-photobooth',
                'day-5-afternoon': 's-oy-myeong',
                'day-6-evening': 'a-hanriver',
                'day-8-morning': 'a-gamcheon',
                'day-8-evening': 'a-drones',
                'day-9-afternoon': 'a-luge',
                'day-11-evening': 'a-kbo',
                'day-12-afternoon': 'a-leeum;a-starfield'
            }
        };

        // Current Placed Itinerary state loaded from LocalStorage or Default
        let activeItinerary = {};

        // --- Drag & Drop Context ---
        let draggedActivityId = null;
        let draggedSourceSlot = null;

        function getFavoritesFor(user) {
            try { return JSON.parse(localStorage.getItem(`itinerary_favorites_${user}`)) || []; }
            catch (e) { return []; }
        }
        function saveFavoritesFor(user, favs) {
            localStorage.setItem(`itinerary_favorites_${user}`, JSON.stringify(favs));
        }
        function toggleFavorite(id) {
            let favs = getFavoritesFor(currentTrackUser);
            const idx = favs.indexOf(id);
            if (idx > -1) {
                favs.splice(idx, 1);
                showToast("Removed from Favorites", "Activity removed from your favorites list.", "info");
            } else {
                favs.push(id);
                showToast("Added to Favorites", "Activity added to your favorites list.", "success");
            }
            saveFavoritesFor(currentTrackUser, favs);
            renderActivityMenu();
            renderPlannerCanvas();
            if (window.renderSlotPicker && document.getElementById('slotPicker') && document.getElementById('slotPicker').style.display !== 'none') {
                window.renderSlotPicker();
            }
        }


        function confirmReplace(oldName, newName, onConfirm) {
            document.getElementById('confirmReplaceText').textContent = `Are you sure you want to replace '${oldName}' with '${newName}'? This slot already has an activity scheduled.`;
            const yesBtn = document.getElementById('confirmReplaceYesBtn');
            const newYesBtn = yesBtn.cloneNode(true);
            yesBtn.parentNode.replaceChild(newYesBtn, yesBtn);
            newYesBtn.addEventListener('click', () => {
                closeModal('confirmReplaceModal');
                onConfirm();
            });
            document.getElementById('confirmReplaceModal').classList.add('active');
        }

        function placeActivity(actId, targetDayNum, targetTimeSlot, sourceSlot = null, targetCardId = null) {
            const act = activityById(actId);
            const day = days.find(d => d.dayNum === targetDayNum);
            if (!act || !day) return;

            // Region check
            const isValidRegion = regionOk(act.region, day.region);
            if (!isValidRegion) {
                showToast("Invalid Region", `Cannot place '${act.name}' on Day ${targetDayNum}. It is in ${act.region}, but we are in ${day.region}.`, "error");
                const slotEl = document.getElementById(`slot-${targetDayNum}-${targetTimeSlot}`);
                if (slotEl) {
                    slotEl.classList.add('drag-over');
                    slotEl.classList.add('drag-invalid');
                    setTimeout(() => slotEl.classList.remove('drag-over', 'drag-invalid'), 400);
                }
                return;
            }

            // Closed day warning
            if (act.closedDay !== undefined) {
                const date = new Date(2026, 5, 26 + targetDayNum); // Friday June 26 = Day 0
                const dayOfWeek = date.getDay();
                if (dayOfWeek === act.closedDay) {
                    const daysNames = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
                    showToast("Warning: Facility Closed", `Note: '${act.name}' is usually closed on ${daysNames[act.closedDay]}s!`, "warning");
                }
            }

            const targetSlotKey = `day-${targetDayNum}-${targetTimeSlot}`;
            const existingActId = activeItinerary[targetSlotKey] || '';
            let targetParts = existingActId.split(';').filter(id => id.trim() !== '');

            const isSameSlot = sourceSlot && sourceSlot.dayNum === targetDayNum && sourceSlot.timeSlot === targetTimeSlot;

            if (isSameSlot) {
                // Reordering within the same slot
                if (!targetCardId || targetCardId === actId) return;
                
                // Remove the dragged activity from its current index
                targetParts = targetParts.filter(id => id !== actId);
                
                // Find target index
                const targetIdx = targetParts.indexOf(targetCardId);
                if (targetIdx > -1) {
                    targetParts.splice(targetIdx, 0, actId); // Insert before targetCardId
                } else {
                    targetParts.push(actId);
                }
                
                activeItinerary[targetSlotKey] = targetParts.join(';');
                saveCurrentItinerary();
                renderPlannerCanvas();
                showToast("Reordered", `Reordered activities in this slot.`, "success");
                return;
            }

            // Dragged from another slot or sidebar
            if (targetParts.includes(act.id)) {
                showToast("Already Scheduled", `'${act.name}' is already in this slot.`, "warning");
                return;
            }

            if (sourceSlot) {
                const sourceSlotKey = `day-${sourceSlot.dayNum}-${sourceSlot.timeSlot}`;
                const sourceVal = activeItinerary[sourceSlotKey] || '';
                const sourceParts = sourceVal.split(';').filter(id => id.trim() !== '' && id !== act.id);
                if (sourceParts.length > 0) {
                    activeItinerary[sourceSlotKey] = sourceParts.join(';');
                } else {
                    delete activeItinerary[sourceSlotKey];
                }
            }

            if (targetCardId) {
                const targetIdx = targetParts.indexOf(targetCardId);
                if (targetIdx > -1) {
                    targetParts.splice(targetIdx, 0, act.id);
                } else {
                    targetParts.push(act.id);
                }
            } else {
                targetParts.push(act.id);
            }
            
            activeItinerary[targetSlotKey] = targetParts.join(';');
            saveCurrentItinerary();
            renderPlannerCanvas();
            showToast("Activity Placed", `Added '${act.name}' to Day ${targetDayNum} ${targetTimeSlot}.`, "success");
        }

        // --- Core Functions ---
        
        window.addEventListener('DOMContentLoaded', () => {
            loadUserTrack(currentTrackUser);
            renderActivityMenu();
            renderPlannerCanvas();
            setupFoodDragAndDrop();
            
            // Default to My Itinerary section instead of Discover on mobile devices on load
            if (window.matchMedia('(max-width: 899px)').matches) {
                const sidebar = document.getElementById('plannerSidebar');
                if (sidebar) sidebar.classList.add('collapsed');
                sidebarCollapsed = true;
                const btnDiscover = document.getElementById('mobileTabDiscover');
                const btnItinerary = document.getElementById('mobileTabItinerary');
                if (btnDiscover) btnDiscover.classList.remove('active');
                if (btnItinerary) btnItinerary.classList.add('active');
            }

            // Check if questionnaire has ever been filled
            if (!localStorage.getItem('itinerary_survey_completed')) {
                setTimeout(openQuestionnaire, 1000);
            }

        });

        // Toggle Sidebar visibility
        function toggleSidebar() {
            const sidebar = document.getElementById('plannerSidebar');
            sidebarCollapsed = !sidebarCollapsed;
            sidebar.classList.toggle('collapsed', sidebarCollapsed);
        }

        // Toggle Day accordion visibility
        function toggleDay(header) {
            const dayCard = header.closest('.agenda-day');
            if (dayCard) {
                dayCard.classList.toggle('collapsed');
            }
        }

        // Switch navigation tabs
        function switchTab(event, tabId) {
            // Hide all tab contents
            document.querySelectorAll('.tab-content').forEach(el => el.classList.remove('active'));
            // Deactivate all tab buttons
            document.querySelectorAll('.tab-btn').forEach(el => el.classList.remove('active'));
            
            // Show active tab content
            const targetContent = document.getElementById(tabId);
            if (targetContent) {
                targetContent.classList.add('active');
            }
            // Activate current tab button
            if (event && event.currentTarget) {
                event.currentTarget.classList.add('active');
            }
        }

        // --- Data Loading and Tracks ---
        function loadUserTrack(userName) {
            currentTrackUser = userName;
            localStorage.setItem('currentTrackUser', userName);
            
            // Highlight active button
            familyMembers.forEach(member => {
                const btn = document.getElementById(`userBtn-${member}`);
                if (btn) btn.classList.toggle('active', member === userName);
            });

            // Read from LocalStorage or Load default
            const savedData = localStorage.getItem(`itinerary_track_${userName}`);
            if (savedData) {
                activeItinerary = normalizeItinerary(JSON.parse(savedData));
                
                // Smart Migration for Ayden's locked Day 2 and Day 3 choices
                if (userName === 'Ayden') {
                    let migrated = false;
                    if (activeItinerary['day-2-morning'] === 'r-hanwoo') {
                        activeItinerary['day-2-morning'] = 'r-layered';
                        migrated = true;
                    }
                    if (activeItinerary['day-2-evening'] === 'r-mapo;a-hongdaebusking;a-noraebang') {
                        activeItinerary['day-2-evening'] = 'r-mapo;a-hongdaebusking;a-photobooth;r-sulbing';
                        migrated = true;
                    }
                    if (activeItinerary['day-3-afternoon'] === 'r-tongin;a-insadong') {
                        activeItinerary['day-3-afternoon'] = 'r-tosokchon;a-insadong;r-bora';
                        migrated = true;
                    }
                    if (activeItinerary['day-3-evening'] === 'r-bora;a-mountaingym;a-nseoultower') {
                        activeItinerary['day-3-evening'] = 'a-mountaingym;a-nseoultower';
                        migrated = true;
                    }
                    if (activeItinerary['day-4-morning'] === 'a-secretgarden') {
                        activeItinerary['day-4-morning'] = 'r-camel-coffee;a-secretgarden';
                        migrated = true;
                    }
                    if (activeItinerary['day-4-afternoon'] === 'r-jaeyondo;s-seongsu;s-anderson-bell') {
                        activeItinerary['day-4-afternoon'] = 'r-neungdong-minari;s-seongsu;s-anderson-bell;r-jaeyondo';
                        migrated = true;
                    }
                    if (activeItinerary['day-4-evening'] === 'r-sounds-of-apple;r-neungdong-minari') {
                        activeItinerary['day-4-evening'] = 'r-sounds-of-apple;r-yukjeon';
                        migrated = true;
                    }
                    if (activeItinerary['day-5-morning'] === 'a-personalcolor') {
                        activeItinerary['day-5-morning'] = 'a-yeonnam';
                        migrated = true;
                    }
                    if (activeItinerary['day-5-morning'] === 'a-yeonnam') {
                        activeItinerary['day-5-morning'] = 'r-reindeer;a-yeonnam';
                        migrated = true;
                    }
                    if (activeItinerary['day-6-morning'] === 'a-cooking') {
                        activeItinerary['day-6-morning'] = 'a-ikseon';
                        migrated = true;
                    }
                    if (activeItinerary['day-6-afternoon'] === 'a-theclimb') {
                        activeItinerary['day-6-afternoon'] = 'a-cinema';
                        migrated = true;
                    }
                    if (activeItinerary['day-8-afternoon'] === 'a-gamcheon;a-huinnyeoul') {
                        activeItinerary['day-8-afternoon'] = 'r-haeundae-market;a-xthesky';
                        migrated = true;
                    }
                    if (activeItinerary['day-8-afternoon'] === 'r-haeundae-market;a-xthesky') {
                        activeItinerary['day-8-afternoon'] = 'r-haeundae-market;a-xthesky;a-oryukdo';
                        migrated = true;
                    }
                    if (activeItinerary['day-8-evening'] === 'a-gwangalli-beach;a-drones;a-diamond') {
                        activeItinerary['day-8-evening'] = 'r-handasot;a-drones';
                        migrated = true;
                    }
                    if (activeItinerary['day-9-morning'] === 'a-haedong-yonggungsa') {
                        activeItinerary['day-9-morning'] = 'a-gamcheon';
                        migrated = true;
                    }
                    if (activeItinerary['day-9-afternoon'] === 'a-luge;a-spaland-centum') {
                        activeItinerary['day-9-afternoon'] = 'a-huinnyeoul;r-momos';
                        migrated = true;
                    }
                    if (activeItinerary['day-9-evening'] === 'r-amook;r-jagalchi' || activeItinerary['day-9-evening'] === 'r-jagalchi;r-amook') {
                        activeItinerary['day-9-evening'] = 'r-halmae-gaya-milmyeon;r-biff-square-street;r-sulbing';
                        migrated = true;
                    }
                    if (activeItinerary['day-10-morning'] === 'a-oryukdo;a-uncemetery') {
                        activeItinerary['day-10-morning'] = 'a-uncemetery';
                        migrated = true;
                    }
                    if (activeItinerary['day-11-morning'] === 's-namdaemun') {
                        activeItinerary['day-11-morning'] = 'r-milestone;s-namdaemun';
                        migrated = true;
                    }
                    if (activeItinerary['day-12-afternoon'] === 'a-starfield') {
                        activeItinerary['day-12-afternoon'] = 'a-leeum;a-starfield';
                        migrated = true;
                    }
                    if (migrated) {
                        saveCurrentItinerary();
                    }
                }
            } else {
                activeItinerary = normalizeItinerary({ ...defaultItineraries[userName] });
                saveCurrentItinerary();
            }

            renderActivityMenu();   // match scores are per-user
            renderPlannerCanvas();
            showToast("Itinerary Loaded", `Switched to ${userName}'s custom track.`, "success");
