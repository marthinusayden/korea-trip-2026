// ════════════════════════════════════════════════════════════════════════
//  KOREA 2026 — SHARED TRIP DATA (single source of truth)
//  Used by menu.html (browse) and itinerary.html (planner sidebar).
//
//  Planner metadata per item:
//    plannable  false → browse-only (food-guide knowledge cards)
//    interest   ['fashion'|'culture'|'thrills'|'foodie'] survey interest tags
//    diet       contains: 'pork' | 'beef' | 'seafood' | 'spicy'
//    vegOk      vegetarian-friendly option exists
//    wish       survey food-wishlist key (bbq, crab, chicken, noodles,
//               soup, kalguksu, hotteok, bingsu, convenience)
//    foodCat    survey ranking bucket: bbq | stews | street | cafes
//    indoor     monsoon-safe flag · needsBooking · closedDay (0=Sun…6=Sat)
//    expensive  hidden when budget < R12,000
//    region     seoul1 (Jun 27–Jul 3) · busan (Jul 3–6) · seoul2 (Jul 6–9) · any
// ════════════════════════════════════════════════════════════════════════

const TD_FOOD_GUIDE = [
  {"id":"fg-samgyeopsal","cat":"must-try","name":"Samgyeopsal (삼겹살)","emoji":"🥩","gradient":"linear-gradient(135deg,#c0392b,#e67e22)","region":"any","cost":"₩15,000–25,000 pp","costZAR":"≈ R160–270","duration":"1.5–2 hrs","teaser":"Thick pork belly grilled at your table — the iconic Korean BBQ experience.","desc":"The definitive Korean dining ritual. Thick slices of pork belly (samgyeopsal) or marinated pork ribs (galbi) are grilled on a built-in tabletop grill. You wrap the meat in perilla or lettuce leaves, add a smear of ssamjang paste, sliced garlic, and kimchi. The social energy is half the meal.","highlights":["Pork belly (삼겹살)","Marinated short rib (갈비)","Ssamjang dipping paste","Garlic — grill it!","Kimchi pancake to finish"],"tips":"Order the first round of pork belly for the grill's seasoning, then switch to galbi for sweetness. Press the buzzer (or call \"저기요!\") to get service. Banchan side dishes are free and infinitely refillable — don't be shy to ask.","hours":"Most BBQ spots: 11:30am – midnight","address":"Everywhere in Korea — Mapo-gu has some of the best","mapLink":"https://naver.me/FfMW1xK2","link":"https://www.instagram.com/explore/tags/samgyeopsal/","plannable":false},

  {"id":"fg-gejang","cat":"must-try","name":"Ganjang Gejang (간장게장)","emoji":"🦀","gradient":"linear-gradient(135deg,#1a3a4a,#2980b9)","region":"any","cost":"₩14,000–31,000","costZAR":"≈ R150–335","duration":"45 min","teaser":"Raw crab cured in soy — so rich and umami-packed Koreans call it \"the rice thief.\"","desc":"Fresh raw crab marinated for days in a savory soy sauce brine until silky and intensely flavoured. The roe turns almost buttery. You scoop the orange-gold innards directly over hot rice — it's so addictive that Koreans literally call it \"bap-doduk\" (rice thief). There is also a spicy version, yangnyeom gejang.","highlights":["Medium stone crab (돌게) — ₩14k","Premium flower crab (꽃게) — ₩31k","Soy brined (ganjang) — milder","Spicy marinated (yangnyeom) — bolder","Eat with hot steamed rice"],"tips":"The Ahyeon-dong Ganjang Gejang restaurant near your accommodation in Ahyeon is world-famous and very foreigner-friendly — staff will show you how to eat it. Avoid pulling legs off; spoon the roe out instead.","hours":"Typically 11am – 9pm (closed Sundays in some spots)","address":"Ahyeon-dong, Mapo-gu (near accommodation)","mapLink":"https://map.naver.com/v5/search/%EC%95%84%ED%98%84%EB%8F%99%20%EA%B0%84%EC%9E%A5%EA%B2%8C%EC%9E%A5","link":"https://www.instagram.com/ah_gejang/","plannable":false},

  {"id":"fg-chimaek","cat":"must-try","name":"Chimaek — Fried Chicken + Beer (치맥)","emoji":"🍗","gradient":"linear-gradient(135deg,#f39c12,#e74c3c)","region":"any","cost":"₩18,000–28,000 for a whole chicken","costZAR":"≈ R195–300","duration":"1.5 hrs","teaser":"Double-fried chicken + cold beer. An entire culture unto itself.","desc":"Korean fried chicken (KFC — the original) is double-fried so the outer crust is impossibly thin and shatteringly crispy. Available in soy-garlic glaze or spicy gochujang. Paired with a cold draft beer (maekju) — a combo so beloved it became \"Chimaek\" (치킨+맥주). Many places deliver directly to Han River parks.","highlights":["Half chicken: soy-garlic + spicy mixed","Pickled radish cubes — mandatory side","Yangnyeom (spicy glaze)","Crispy original (후라이드)","Beer: Cass, Terra, Hite — all ~₩4k/can"],"tips":"Order delivery to Yeouido Hangang Park using Baemin/Coupang apps for the full experience. Most shops are open till 2–3am. BBQ Chicken, Kyochon, BHC, and Mom's Touch are the top chains.","hours":"Most open 2pm – 2am","address":"Everywhere — Hongdae and Mapo especially","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/치맥/","plannable":false},

  {"id":"fg-tteokbokki","cat":"must-try","name":"Tteokbokki (떡볶이)","emoji":"🌶️","gradient":"linear-gradient(135deg,#e74c3c,#c0392b)","region":"any","cost":"₩3,000–8,000","costZAR":"≈ R32–86","duration":"10 min","teaser":"Chewy rice cakes in fiery, sweet-savory gochujang sauce — the defining Korean street food.","desc":"Cylindrical rice cakes (tteok) simmered in a bubbling sauce of gochujang, fish stock, and sugar. Spicy, sticky, and addictive. Usually served with fish cake (eomuk) skewers on the side. Modern versions include rose tteokbokki (creamy, less spicy) and gukmul (soupy broth style). Available at every pojangmacha tent and street stall.","highlights":["Classic gochujang (매운)","Rose tteokbokki (크리미) — milder","Gukmul style (brothy)","Add fried dumplings on top","Fish cake skewers alongside"],"tips":"Tongin Market does an oil-fried version (gireum tteokbokki) unique to that market — pan-fried in oil instead of broth, much less spicy. A must-try on your Day 1 market visit.","hours":"Street stalls: typically noon – 10pm","address":"Tongin Market, Myeongdong, Hongdae, Busan Nampo-dong","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/떡볶이/","plannable":false},

  {"id":"fg-hotteok","cat":"must-try","name":"Hotteok (호떡)","emoji":"🫓","gradient":"linear-gradient(135deg,#d35400,#f39c12)","region":"any","cost":"₩1,000–2,000","costZAR":"≈ R10–22","duration":"5 min","teaser":"Chewy street pancakes filled with brown sugar and cinnamon — caramelised on a griddle.","desc":"A ball of yeast dough stuffed with brown sugar, cinnamon, and crushed peanuts or sesame seeds, then pressed flat onto a hot griddle until the outside is burnished and crispy while the inside melts into a gooey caramel. Best eaten piping hot right from the stall. A winter street food classic, but sold year-round in Busan especially.","highlights":["Sweet (달콤) — classic sugar-cinnamon","씨앗호떡 — seeds hotteok (Busan iconic!)","Cheese hotteok — modern twist","Green onion (부추) — savoury version"],"tips":"Ssiat hotteok (씨앗호떡) in Busan's BIFF Square / Nampo-dong is the most famous version — filled with pumpkin seeds and sunflower seeds. The queue tells you which stall is best. Bring napkins — the sugar syrup leaks everywhere.","hours":"Street stalls 10am – 8pm","address":"BIFF Square / Nampo-dong, Busan; Insadong, Seoul","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/씨앗호떡/","plannable":false},

  {"id":"fg-bingsu","cat":"must-try","name":"Bingsu (빙수)","emoji":"🍧","gradient":"linear-gradient(135deg,#2980b9,#6dd5fa)","region":"any","cost":"₩8,000–18,000","costZAR":"≈ R86–195","duration":"20 min","teaser":"Ultra-fine shaved milk ice that melts on your tongue — Korea's summer obsession.","desc":"Far lighter than a snow-cone, bingsu is made from frozen blocks of sweetened milk that's shaved into feather-light ribbons. Topped with red bean paste (patbingsu), condensed milk, fresh fruit, or matcha. The texture dissolves instantly on the tongue — it's unlike anything from back home. Perfect for the July heat.","highlights":["Patbingsu (팥빙수) — red bean classic","Mango bingsu (망고)","Strawberry (딸기)","Matcha bingsu (말차)","Injeolmi (인절미) — rice cake + bean powder"],"tips":"Sulbing (설빙) is the reliable national chain. For premium bingsu, Cafe Bora in Insadong (right near Gyeongbokgung) and Cafe de Paris in Myeongdong have photogenic, elaborate versions. Order one large to share — portions are generous.","hours":"Summer hours: 11am – 10pm","address":"Sulbing chains everywhere; Cafe Bora, Insadong","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/빙수/","plannable":false},

  {"id":"fg-naengmyeon","cat":"must-try","name":"Naengmyeon / Milmyeon (냉면/밀면)","emoji":"🍜","gradient":"linear-gradient(135deg,#27ae60,#1abc9c)","region":"any","cost":"₩8,000–12,000","costZAR":"≈ R86–130","duration":"20 min","teaser":"Ice-cold noodles served in chilled broth or spicy paste — the perfect summer dish.","desc":"Chewy buckwheat or wheat noodles served either in an icy beef broth (mul naengmyeon — tangy, lightly sour) or tossed in a spicy-sweet gochujang sauce (bibim naengmyeon). Milmyeon is the Busan variation made with wheat noodles in icy herbal broth. Daeyeon Milmyeon near your Busan hotel is one of the best.","highlights":["Mul (물) — iced broth, tangy","Bibim (비빔) — spicy-sweet sauce","Milmyeon (밀면) — Busan style, wheat noodle","Cut the noodles with scissors before eating","Add vinegar and mustard on the side to taste"],"tips":"Ask for scissors (가위) to cut the long noodles — Koreans always do this. The broth in mul naengmyeon is meant to be drunk at the end. Pair with wang-mandu (steamed dumplings) at Daeyeon Milmyeon in Busan.","hours":"Typically 10:30am – 8:30pm","address":"Daeyeon Milmyeon, Nam-gu, Busan (near hotel)","mapLink":"https://naver.me/FGo4MvF1","link":"https://naver.me/FGo4MvF1","plannable":false},

  {"id":"fg-samgyetang","cat":"must-try","name":"Samgyetang (삼계탕)","emoji":"🍲","gradient":"linear-gradient(135deg,#7f8c8d,#bdc3c7)","region":"seoul1","cost":"₩17,000–22,000","costZAR":"≈ R185–240","duration":"45 min","teaser":"A whole young chicken stuffed with rice and ginseng, slow-braised in broth — deeply nourishing.","desc":"A whole small chicken (poussins) is stuffed with glutinous rice, garlic, jujube dates, and Korean ginseng root, then braised for hours in a milky, restorative broth. It's eaten in summer on the hottest days as \"fight heat with heat.\" Tosokchon Samgyetang near Gyeongbokgung serves it in a traditional hanok building — one of the most acclaimed spots.","highlights":["Whole chicken per person (a meal in itself)","Ginseng root — earthy and slightly bitter","Glutinous rice stuffing","Jujube dates inside","Dip chicken in salt + pepper"],"tips":"Tosokchon near Gyeongbokgung Palace is the most famous — expect queues. Arrive before 11:30am or after 2pm. The broth is incredibly mild and clean — season it yourself with salt at the table.","hours":"Tosokchon: 10am – 9pm daily","address":"Tosokchon, Cheongun-dong, Jongno-gu, Seoul","mapLink":"http://www.tosokchon.com/main.php","link":"http://www.tosokchon.com/main.php","plannable":false},

  {"id":"fg-gimbap","cat":"convenience","name":"Triangle Gimbap (삼각김밥)","emoji":"🍙","gradient":"linear-gradient(135deg,#2c3e50,#4a6b53)","region":"any","cost":"₩1,200–1,800","costZAR":"≈ R13–20","duration":"2 min","teaser":"Korea's convenience store staple — triangular rice balls with surprise fillings, wrapped in seaweed.","desc":"Triangular packages of seasoned rice packed with fillings like tuna mayo, kimchi, bulgogi, spam, or shrimp. Available in every GS25, CU, 7-Eleven, and Emart24 at all hours. Satisfying, fresh, and absurdly cheap. The plastic wrapper unfolds in three steps to keep the seaweed crispy — there's a technique. Ask a local to show you.","highlights":["Tuna mayo (참치마요) — #1 bestseller","Kimchi tuna","Spam + egg","Buldak (spicy chicken)","Corn mayo"],"tips":"Eat immediately after purchase — the seaweed softens within 20 minutes. Pair with banana milk (바나나우유) for the full Korean convenience store breakfast. GS25 and CU are generally fresher and more varied than 7-Eleven.","hours":"Open 24/7","address":"GS25 and CU — on every block in Seoul and Busan","mapLink":"","link":"","plannable":false},

  {"id":"fg-ramyeon","cat":"convenience","name":"Convenience Store Ramen (라면)","emoji":"🍜","gradient":"linear-gradient(135deg,#8e44ad,#e74c3c)","region":"any","cost":"₩1,500–2,500","costZAR":"≈ R16–27","duration":"5 min","teaser":"Cook instant ramen in a styrofoam cup at the store's FREE hot water station — a Korean institution.","desc":"Korean convenience stores have a free hot water machine and microwave for customers to use. Buy any ramyeon (Shin Ramyun, Buldak fire noodles, Carbo Buldak, etc), cook it in-store at the eating counter, and sit with free broth at 2am. A legendary budget meal. Buldak Carbonara (pink packet) is the most internationally popular right now.","highlights":["Shin Ramyun (신라면) — classic spicy","Buldak Carbonara (불닭카보나라) — creamy & spicy","Samyang original (삼양라면)","Add egg from the fridge section (₩1k)","Upgrade: add a rice ball on the side"],"tips":"The eating counters near windows are a vibe — watching Seoul at 1am with cup noodles is a whole experience. CU tends to have the widest ramyeon selection. You can microwave many of the premium cup ramyeon varieties too.","hours":"24/7","address":"Any GS25 / CU / 7-Eleven","mapLink":"","link":"https://www.instagram.com/explore/tags/편의점라면/","plannable":false},

  {"id":"fg-bananamilk","cat":"convenience","name":"Banana Milk (바나나우유)","emoji":"🍌","gradient":"linear-gradient(135deg,#f1c40f,#e67e22)","region":"any","cost":"₩1,300–1,800","costZAR":"≈ R14–20","duration":"instant","teaser":"The iconic barrel-shaped bottle of sweet banana-flavoured milk — a Korean pop culture legend.","desc":"Binggrae Banana Flavoured Milk is the most recognizable drink in Korea, sold since 1974 in its distinctive barrel-shaped bottle. Sweetened and gently banana-flavoured — not artificial, more like banana candy. There's also Strawberry (딸기우유) and Melon. A cold one from the fridge is essential at least once.","highlights":["Original Banana (바나나)","Strawberry (딸기)","Melon (메론)","Binggrae brand — the OG","Drink straight from the bottle only"],"tips":"Buy it cold from the fridge section. The newer \"Banaholic\" version has a more intense flavour. The bottle is iconic enough that Binggrae sells it as merchandise — there's a whole Binggrae character universe on Instagram.","hours":"24/7","address":"Any convenience store","mapLink":"","link":"https://www.instagram.com/binggrae_official/","plannable":false},

  {"id":"fg-honeybutter","cat":"convenience","name":"Honey Butter Chips (허니버터칩)","emoji":"🍟","gradient":"linear-gradient(135deg,#f9ca24,#f0932b)","region":"any","cost":"₩1,500–2,000","costZAR":"≈ R16–22","duration":"instant","teaser":"The snack that caused a nationwide shortage — sweet, salty, buttery potato crisps.","desc":"Haitai Honey Butter Chips launched in 2014 and sold out across the country within weeks, spawning queues and black-market reselling. Sweet, buttery, salty, and weirdly addictive. Now widely available again. Also try: Honey Butter Almonds, Honey Butter Squid, and the Haepyo brand alternatives.","highlights":["Honey Butter Chips (허니버터칩)","Honey Butter Almonds","Homerun Ball (홈런볼) — puffed corn snack","Choco Pie (초코파이)","Pepero stick cookies"],"tips":"The snack aisle in any Korean convenience store is worth 10 minutes of browsing — there's constant product innovation. Grab a couple of things you've never seen before as a rule.","hours":"24/7","address":"Any convenience store","mapLink":"","link":"","plannable":false},

  {"id":"fg-corndog","cat":"convenience","name":"Korean Corn Dog (핫도그)","emoji":"🌭","gradient":"linear-gradient(135deg,#e67e22,#d35400)","region":"any","cost":"₩2,500–5,000","costZAR":"≈ R27–54","duration":"5 min","teaser":"The stretchy-cheese Korean corn dog — a street food that breaks the internet regularly.","desc":"Not like a Western corn dog. Korean hot dogs (hotdog) are dipped in a thick batter, covered in panko breadcrumbs or rice flour, and deep-fried until ultra-crispy. The filling is beef sausage + mozzarella — you pull it apart and the cheese stretches dramatically. Some versions are half-potato, half-corndog. Top with sugar, ketchup, or mustard.","highlights":["Classic sausage + cheese","Half-half (반반) — half potato, half batter","Squid ink batter version (검정)","Sugar coating on top","Myungrang hot dog chain — the most famous"],"tips":"Myungrang Hotdog (명랑핫도그) has the best QC consistency — look for the yellow signboard. Korea Hotdog chains (코리아 핫도그) are also good. Available in Hongdae, Myeongdong, and near any major station.","hours":"Street stalls 11am – 10pm","address":"Hongdae, Myeongdong, Busan Nampo-dong","mapLink":"","link":"https://www.instagram.com/explore/tags/핫도그/","plannable":false},

  {"id":"fg-buldak","cat":"convenience","name":"Buldak Noodles (불닭볶음면)","emoji":"🔥","gradient":"linear-gradient(135deg,#c0392b,#922b21)","region":"any","cost":"₩1,800–3,000","costZAR":"≈ R19–32","duration":"5 min","teaser":"The nuclear-spice noodles that went globally viral — a Korean rite of passage.","desc":"Samyang Foods Buldak (\"fire chicken\") noodles are among the spiciest commercially available instant noodles globally. The original is a true chilli-oil sauce mixed into thick noodles. More manageable variants: Carbonara (creamy, sweet), Cheese, Jjajang. The challenge is eating original Buldak without any additions. Available everywhere.","highlights":["Original (2x Spicy) — 8706 Scoville","Carbonara (pink) — most beginner-friendly","Cheese (yellow packet)","Corn (sweet, very mild)","Jjajang (black bean)"],"tips":"Buy the Carbonara packet — it's creamy, tangy, and genuinely delicious rather than just painful. If you eat the original, have banana milk on standby. Available in every convenience store and supermarket.","hours":"24/7","address":"Any convenience store","mapLink":"","link":"https://www.instagram.com/explore/tags/불닭볶음면/","plannable":false},

  {"id":"fg-notipping","cat":"etiquette","name":"The No-Tipping Rule","emoji":"💳","gradient":"linear-gradient(135deg,#2c3e50,#34495e)","region":"any","cost":"Saves you awkwardness","costZAR":"","duration":"","teaser":"Tipping is genuinely not practiced in South Korea — don't do it.","desc":"In Korea, tipping is not part of the culture and can cause confusion or be interpreted as rude or pitying. Service charges are built into menu prices. At restaurants, sit-down or street food, just pay the bill and leave. This applies to taxis, hair salons, and delivery drivers too. The service is usually excellent without it.","highlights":["No tip at restaurants","No tip in taxis","No tip at hair salons / spas","No tip for hotel staff","Just say \"감사합니다\" — that's enough"],"tips":"The only exception: at some high-end international hotel restaurants catering to foreign tourists, a 10% service charge may already be printed on your bill. In that case it's included and no additional tip is needed.","hours":"","address":"","mapLink":"","link":"","plannable":false},

  {"id":"fg-banchan","cat":"etiquette","name":"Banchan Culture (반찬)","emoji":"🥢","gradient":"linear-gradient(135deg,#27ae60,#2ecc71)","region":"any","cost":"Free — always","costZAR":"","duration":"","teaser":"The free side dishes that arrive with every Korean meal are infinitely refillable — ask for more.","desc":"Every Korean restaurant meal comes with 3–8 small dishes of side dishes called banchan: kimchi, seasoned spinach, pickled radish, bean sprouts, fishcake, etc. These are completely free and you can request refills as many times as you like by calling the server. They are shared by the whole table, not individual portions.","highlights":["Kimchi (김치) — the essential fermented cabbage","Kongnamul (콩나물) — seasoned bean sprouts","Japchae (잡채) — glass noodles","Gamja jorim (감자조림) — braised potatoes","Say \"리필 해주세요\" (ri-pil hae-joo-se-yo) for refills"],"tips":"Don't serve banchan directly onto your individual rice bowl — eat from the shared dishes. Spoon rice into your mouth rather than picking up the rice bowl (only soup bowls are lifted). Chopsticks do not go into rice bowls upright — this is a funeral ritual.","hours":"","address":"","mapLink":"","link":"","plannable":false},

  {"id":"fg-buzzer","cat":"etiquette","name":"Table Buzzer & Ordering","emoji":"🔔","gradient":"linear-gradient(135deg,#8e44ad,#6c3483)","region":"any","cost":"","costZAR":"","duration":"","teaser":"Press the table button or call \"저기요!\" — Korean restaurants don't come to check on you.","desc":"Korean restaurants operate on a call-when-needed model. Servers won't hover or check in — when you need anything, press the electronic buzzer on the table (most places have them) or call out \"저기요!\" (jeo-gi-yo — \"excuse me!\"). This applies to ordering, asking for refills, requesting the bill, or adding items. Don't wait to be attended to.","highlights":["Press table buzzer (호출 버튼)","Call \"저기요!\" to summon staff","Order everything at once when possible","Bill: say \"계산이요\" (gye-san-i-yo)","Many places have tablet ordering now"],"tips":"At busy pojangmacha (street food tents) and BBQ places, service is fast-paced — have your order ready when you call. Menus often have pictures; pointing is completely acceptable. Papago app camera mode is excellent for translating menus in real time.","hours":"","address":"","mapLink":"","link":"","plannable":false},

  {"id":"fg-drinking","cat":"etiquette","name":"Korean Drinking Etiquette","emoji":"🍶","gradient":"linear-gradient(135deg,#16213e,#0f3460)","region":"any","cost":"","costZAR":"","duration":"","teaser":"Never pour your own drink — pour for others and let them pour for you.","desc":"Korean drinking culture centers on communal respect. You always pour for others at the table, not for yourself. When someone offers to pour for you, hold your glass with both hands or with one hand supporting the other. Don't start drinking before the eldest person takes a sip. Turn away from elders when taking a drink as a sign of respect. Soju is the national spirit; it's mixed with beer in a \"somaek\" (soju + maekju).","highlights":["Hold your glass with both hands when being poured for","Pour for others before yourself","Oldest person drinks first","Turn away from elders when drinking","Somaek (소맥) = soju bomb in beer"],"tips":"Soju (~₩5,000–6,000/bottle) is the world's best-selling spirit for a reason — clean and smooth at 16–25% ABV. \"Cheer\" is \"건배!\" (geon-bae) — say it and clink glasses. The custom of not letting glasses go empty is the main thing to remember.","hours":"","address":"","mapLink":"","link":"https://www.instagram.com/explore/tags/소맥/","plannable":false},

  {"id":"fg-dosirak","cat":"convenience","name":"Convenience Store Dosirak (도시락)","emoji":"🍱","gradient":"linear-gradient(135deg,#1e8449,#82e0aa)","region":"any","cost":"₩4,000–6,500","costZAR":"≈ R43–70","duration":"10 min","teaser":"Full lunchbox meals — rice, meat, banchan — for the price of a coffee, microwaved in-store.","desc":"Korean convenience store dosirak are proper meals: compartmented boxes of rice, a main (bulgogi, pork cutlet, spicy chicken), and 3–5 side dishes, refreshed daily. Microwave them at the in-store counter. A legitimate budget dinner that locals eat constantly — especially on travel days.","highlights":["Bulgogi dosirak — safe bet","Pork cutlet (donkatsu) boxes","Spam + egg classics","Microwave at the counter — free","New lineups every season"],"tips":"The dosirak shelf is restocked in the morning and around 5pm — peak freshness. Pair with instant miso/seaweed soup from the shelf (just add the hot water that's already free).","hours":"24/7","address":"Any GS25 / CU / 7-Eleven / Emart24","plannable":false,"mapLink":"","link":""},

  {"id":"fg-icecream","cat":"convenience","name":"The Ice Cream Chest (아이스크림)","emoji":"🍦","gradient":"linear-gradient(135deg,#117a65,#a3e4d7)","region":"any","cost":"₩1,000–3,000","costZAR":"≈ R11–32","duration":"instant","teaser":"Melona, Samanco fish waffles, and Jaws bars — the legendary ₩1,000 freezer chest.","desc":"Every convenience store has a chest freezer of iconic Korean ice creams: Melona (melon cream bars), Samanco (fish-shaped waffle filled with ice cream and red bean), Jaws Bar (shark-shaped shaved-ice), Bibibig, and Screw Bar. In July heat, this chest is your best friend — most cost about ₩1,000–1,500.","highlights":["Melona (메로나) — melon cream icon","Samanco (붕어싸만코) — waffle fish","Jaws Bar (죠스바) — shark ice pop","Screw Bar (스크류바)","Power Cap squeeze tubes"],"tips":"Supermarkets and \"ice cream discount stores\" sell the same bars at 50% off if you pass one. Melona + banana milk is an elite combination, no further questions.","hours":"24/7","address":"Any convenience store","plannable":false,"mapLink":"","link":""}
];

const TD_RESTAURANTS = [
  {"id":"r-gejang","neighbourhood":"ahyeon","cat":"seoul","name":"Ahyeon-dong Ganjang Gejang (아현동 간장게장)","emoji":"🦀","gradient":"linear-gradient(135deg,#1a3a4a,#2980b9)","region":"seoul1","cost":"₩14,000–31,000","costZAR":"≈ R150–335","duration":"1 hr","teaser":"A world-famous soy crab restaurant 5 minutes walk from your Ahyeon accommodation.","desc":"One of Seoul's most acclaimed ganjang gejang (soy-marinated raw crab) spots, tucked into a quiet Ahyeon alleyway. The crab arrives cut and ready to eat, overflowing with intensely flavoured orange roe. Staff are experienced with foreign guests and will guide you through the meal. Set meals are excellent value.","highlights":["Medium stone crab set (돌게) — ₩14k","Large flower crab (꽃게) — ₩31k","Rice — mandatory partner","Warm broth on the side","Spicy version (양념게장) available"],"tips":"Come for lunch (opens at 11am). Arrive early — it fills up. This is literally 5 minutes from your Ahyeon accommodation on foot. Card payment accepted.","hours":"11am – 9pm (closed Sundays)","address":"Ahyeon-dong, Mapo-gu, Seoul","mapLink":"https://map.naver.com/v5/search/%EC%95%84%ED%98%84%EB%8F%99%20%EA%B0%84%EC%9E%A5%EA%B2%8C%EC%9E%A5","link":"https://www.instagram.com/ah_gejang/","interest":["foodie"],"diet":["seafood"],"vegOk":false,"wish":"crab","indoor":true,"closedDay":0},

  {"id":"r-mapo","neighbourhood":"mapo","cat":"seoul","name":"Mapo 최대포 — Legendary Pork Galbi","emoji":"🔥","gradient":"linear-gradient(135deg,#922b21,#e67e22)","region":"seoul1","cost":"₩18,000–22,000 /portion","costZAR":"≈ R195–240","duration":"1.5 hrs","teaser":"Decades-old Mapo BBQ legend — marinated pork ribs over charcoal near Gongdeok station.","desc":"Mapo Jeongpo Galbi (최대포) has been serving marinated pork galbi (ribs) in the Gongdeok area for decades. Spacious, extremely family-friendly, open daily 11am–11pm. The signature marinated ribs (양념갈비) are sweet and smoky. The salt-grilled version (소금구이) follows. Finish with pig skin (껍데기) — chewy and unique.","highlights":["Marinated pork ribs (양념갈비) — 200g ₩18k","Salt-grilled pork (소금구이)","Galmaegisal (skirt steak cut)","Pig skin (껍데기) — order last","Doenjang jjigae to finish"],"tips":"One stop from Ahyeon on the subway, or a short walk. Card payment accepted. Order the marinated ribs first while the grill heats up, then salt-grilled for contrast. Staff bring the scissors and flip for you.","hours":"11am – 11pm daily","address":"Gongdeok-dong, Mapo-gu, Seoul","mapLink":"https://naver.me/FfMW1xK2","link":"https://naver.me/FfMW1xK2","interest":["foodie"],"diet":["pork"],"vegOk":false,"wish":"bbq","foodCat":"bbq","indoor":true},

  {"id": "r-kyoja", "neighbourhood": "myeongdong", "cat": "seoul", "name": "Myeongdong Kyoja (명동교자)", "emoji": "🥟", "gradient": "linear-gradient(135deg,#27ae60,#1abc9c)", "region": "seoul1", "cost": "₩10,000–11,000", "costZAR": "≈ R108–120", "duration": "45 min", "teaser": "Michelin Bib Gourmand kalguksu (hand-cut noodles) and mandu — one of Seoul's best values.", "desc": "A Myeongdong institution since 1966, awarded Michelin Bib Gourmand (outstanding value) for years running. The menu is famously short: two or three dishes only. The kalguksu (garlic-heavy chicken noodle soup) is silky and warming; the mandu (pork dumplings) are plump and juicy. Noodle and rice refills are free with a main order.", "highlights": ["Kalguksu (칼국수) — hand-cut noodle soup ₩10k", "Mandu (만두) — steamed pork dumplings ₩10k", "Bibim guksu (비빔국수) — spicy cold noodles", "Rice and noodle refills are free", "Kimchi is exceptional here"], "tips": "Awarded Michelin Bib Gourmand for years. Silky chicken kalguksu noodle soup and garlic-heavy pork dumplings. Noodle and rice refills are free. Arrive by 11:30am.", "hours": "10:30am – 9:30pm (closed Sundays)", "address": "Myeongdong 2-ga, Jung-gu, Seoul", "mapLink": "http://www.mdkj.co.kr", "link": "http://www.mdkj.co.kr", "interest": ["foodie"], "diet": ["pork"], "vegOk": false, "wish": "kalguksu", "foodCat": "stews", "indoor": true, "closedDay": 0, "logo": "https://upload.wikimedia.org/wikipedia/commons/4/44/Michelin_Guide_logo.svg", "menuLink": "http://www.mdkj.co.kr/en/menu/menu_01.php"},

  {"id": "r-tosokchon", "neighbourhood": "insadong", "cat": "seoul", "name": "Tosokchon Samgyetang (토속촌)", "emoji": "🍲", "gradient": "linear-gradient(135deg,#7f8c8d,#95a5a6)", "region": "seoul1", "cost": "₩17,000–19,000", "costZAR": "≈ R185–205", "duration": "1 hr", "teaser": "Ginseng chicken soup served inside a 100-year-old traditional hanok — iconic wellness meal.", "desc": "Tosokchon is widely regarded as the best samgyetang (ginseng chicken soup) in Seoul. A whole small chicken is stuffed with glutinous rice, garlic, and ginseng, then braised for hours in a pure, milky broth. The restaurant is a rambling traditional hanok complex near Gyeongbokgung. The restorative broth is one of those \"this tastes like health\" moments.", "highlights": ["Samgyetang — whole chicken ₩17k", "Black chicken version (오골계삼계탕) — richer, ₩22k", "Ginseng liquor shot (인삼주) — included", "Glutinous rice stuffing", "Season the broth yourself with salt + pepper at the table"], "tips": "Arrive before 11:30am or after 2pm to avoid the biggest queues. The restaurant is enormous but still fills up. Walk 10 minutes from Gyeongbokgung. Pair with a day at the palace — eat lunch here then explore.", "hours": "10am – 9pm daily", "address": "Cheongun-dong, Jongno-gu (near Gyeongbokgung Palace)", "mapLink": "http://www.tosokchon.com/main.php", "link": "http://www.tosokchon.com/main.php", "interest": ["foodie", "culture"], "diet": [], "vegOk": false, "wish": "soup", "foodCat": "stews", "indoor": true, "logo": "https://logo.clearbit.com/tosokchon.com"},

  {"id":"r-tongin","neighbourhood":"insadong","cat":"seoul","name":"Tongin Market 통인시장 — Brass-Coin Lunch","emoji":"🪙","gradient":"linear-gradient(135deg,#c8963e,#d35400)","region":"seoul1","cost":"₩5,000 coin set","costZAR":"≈ R54","duration":"1 hr","teaser":"Buy brass coins and trade them with market stalls to build your own lunchbox — a unique Seoul experience.","desc":"Tongin Market (built 1941) runs a unique \"yeopjeon\" (brass coin) lunch system: pay ₩5,000 at the office and receive old-style brass coins to trade with any stall in the market for small portions of food. Build your own dosirak (lunchbox) from 30+ vendors. The gireum tteokbokki (oil-fried rice cakes, not broth) is unique to Tongin.","highlights":["Brass coins from the Market Office — ₩5k set","Gireum tteokbokki (기름떡볶이) — oil-fried, must-try","Japchae (glass noodles)","Jeon (savory pancakes)","Mandu (dumplings)"],"tips":"Go Monday–Saturday around noon. The coin office is at the entrance on the left. Tell vendors how many coins you're spending; portions are tiny by design. Bring an appetite and try at least 10 different stalls. 5-minute walk from Gyeongbokgung subway exit.","hours":"Mon–Sat 11am – 2pm (coin lunch)","address":"Jahamun-ro, Jongno-gu, Seoul (near Gyeongbokgung)","mapLink":"https://english.visitkorea.or.kr/svc/contents/contentsView.do?vcontsId=79811","link":"https://english.visitkorea.or.kr/svc/contents/contentsView.do?vcontsId=79811","interest":["foodie","culture"],"diet":[],"vegOk":true,"wish":"hotteok","foodCat":"street","indoor":true,"onItinerary":true},

  {"id":"r-mangwon","cat":"seoul","name":"Mangwon Market (망원시장)","emoji":"🛒","gradient":"linear-gradient(135deg,#4a6b53,#70937a)","region":"seoul1","cost":"₩2,000–10,000 per item","costZAR":"≈ R22–108","duration":"1–2 hrs","teaser":"The authentic local market alternative to tourist-saturated Gwangjang — genuine food, real prices.","desc":"Mangwon Market in Mapo-gu is where locals actually shop. It's lively, affordable, and free from the tourist premium and pushy vendors found in Gwangjang or Namdaemun. Great street food options: bindaetteok pancakes, ddeokbokki, fish cake skewers, homemade banchan. Walk along the Gyeongui Line Forest Park after.","highlights":["Bindaetteok (빈대떡) — mung bean pancake","Tteokbokki from local stalls","Freshly made rice cakes (떡)","Banchan (side dish) vendors","Jeon (savory pancakes) of all types"],"tips":"Open daily but best on weekend mornings when the most vendors are out. Combine with a walk along the Gyeongui Line Forest Park (연남동) which runs nearby — a beautiful urban greenway.","hours":"Daily 9am – 8pm (some stalls close earlier)","address":"Mangwon-dong, Mapo-gu (5 min from Mapo station)","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/망원시장/","interest":["foodie","culture"],"diet":[],"vegOk":true,"foodCat":"street","indoor":true},

  {"id":"r-noryangjin","cat":"seoul","name":"Noryangjin Fish Market (노량진 수산시장)","emoji":"🐟","gradient":"linear-gradient(135deg,#1a3a5a,#2471a3)","region":"seoul1","cost":"Buy + cook fee ~₩10k","costZAR":"≈ R108","duration":"2 hrs","teaser":"Buy live seafood at wholesale prices and take it upstairs to a restaurant that cooks it for you on the spot.","desc":"Noryangjin is Seoul's main wholesale fish market, open around the clock. You walk through the enormous floor of tanks and stalls, choose live seafood — octopus, abalone, crab, clams, lobster — negotiate a price, then take it to any of the upstairs restaurants who will prepare it for a small \"cooking fee\" (~₩5,000–10,000). A wild, memorable experience.","highlights":["Live octopus (산낙지) — sliced alive, still moving","Raw fish platter (회)","King crab (킹크랩)","Abalone (전복)","Cooking fee: grilled, steamed, or fried upstairs"],"tips":"Go with an adventurous mindset — vendors will call for you and negotiate is expected. The upstairs restaurants are all legitimate; compare cooking fees. Best visited late evening or very early morning when it's most atmospheric. Take subway to Noryangjin station.","hours":"24/7 (busiest midnight – 5am and 8–11am)","address":"Noryangjin-dong, Dongjak-gu, Seoul","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/노량진수산시장/","interest":["foodie","thrills"],"diet":["seafood"],"vegOk":false,"wish":"crab","foodCat":"street","indoor":true},

  {"id":"r-gwangjang","neighbourhood":"insadong","cat":"seoul","name":"Gwangjang Market (광장시장) ⚠️","emoji":"⚠️","gradient":"linear-gradient(135deg,#922b21,#c0392b)","region":"seoul1","cost":"₩5,000–15,000","costZAR":"≈ R54–162","duration":"1 hr","teaser":"Korea's oldest market — famous food, but flagged by Reddit for tourist pricing and pushy vendors.","desc":"Established in 1905, Gwangjang is famous for bindaetteok (mung bean pancakes) and mayak gimbap (mini seaweed rice rolls). It appears in many travel guides. However, Reddit's r/koreatravel community consistently warns of price gouging, pushy vendors, and portions given unrequested then charged. Visit with caution and Mangwon Market awareness.","highlights":["Bindaetteok (빈대떡) — if you go, get this","Mayak Gimbap (마약김밥) — tiny, addictive rolls","Raw beef tartare (육회) — very fresh here","Silkworm larvae (번데기) — for the adventurous"],"tips":"⚠️ TOURIST WARNING: Calculate your bill before eating. Pay per item, not \"however much the vendor decides.\" Vendors in central aisles often give extra portions then demand more money. The side alleys (not the main photogenic area) have more honest vendors. Mangwon Market is a better all-around experience.","hours":"10am – 10pm (food stalls from midday)","address":"Jongno 4-ga, Jongno-gu, Seoul","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/광장시장/","interest":["foodie","culture"],"diet":[],"vegOk":true,"wish":"hotteok","foodCat":"street","indoor":true},

  {"id":"r-gukbap","neighbourhood":"busan-nampo","cat":"busan","name":"Ssangdoongi Dwaeji Gukbap (쌍둥이 돼지국밥)","emoji":"🍲","gradient":"linear-gradient(135deg,#6c3483,#8e44ad)","region":"busan","cost":"₩9,000–12,000","costZAR":"≈ R97–130","duration":"30 min","teaser":"Rich pork bone broth over rice — the definitive Busan soul food, open daily near your hotel.","desc":"Busan is the spiritual home of dwaeji gukbap (pork bone soup), and Ssangdoongi is consistently rated among the very best. Milky, warming pork bone broth is ladled over rice with tender boiled pork slices. Open daily from 9am to 11pm, located in Daeyeon-dong just minutes from the Bonathree Hotel.","highlights":["Dwaeji Gukbap (돼지국밥) — ₩9k","Baekban set — soup + suyuk pork + rice","Suyuk (수육) — separate plate of boiled pork","Fresh shrimp paste to add to taste","Chive kimchi (부추김치) — free side"],"tips":"Stir the pot vigorously before eating to mix the rice. Season with salt, fermented shrimp paste (새우젓), and chive kimchi to your taste. The baekban set (₩12k) is best value — you get the full experience. No reservations.","hours":"9am – 11pm daily","address":"Daeyeon-dong, Nam-gu, Busan (near Bonathree Hotel)","mapLink":"https://naver.me/GDcM07a3","link":"https://naver.me/GDcM07a3","interest":["foodie"],"diet":["pork"],"vegOk":false,"wish":"soup","foodCat":"stews","indoor":true},

  {"id": "r-amook", "neighbourhood": "busan-nampo", "cat": "busan", "name": "Samjin Amook (삼진어묵) — Fish Cake Bakery", "emoji": "🐠", "gradient": "linear-gradient(135deg,#3a6b8a,#2980b9)", "region": "busan", "cost": "₩2,000–5,000 per piece", "costZAR": "≈ R22–54", "duration": "30 min", "teaser": "Busan's famous fish cake \"bakery\" — freshly fried amook stuffed with cheese, shrimp, and peppers.", "desc": "Fish cake (eomuk/amook) is one of Busan's most beloved foods, and Samjin Amook has been making them since 1953. Take a tray and tongs and select from an enormous display of freshly fried cakes: stuffed with mozzarella, shrimp, green pepper, udon noodles, or sweet potato. Interactive, fresh, and great for kids.", "highlights": ["Cheese amook — mozzarella stuffed", "Shrimp amook", "Spicy pepper amook", "Udon stuffed", "Try the amook donuts (어묵도넛)"], "tips": "Go to the flagship Gukje Market branch in Nampo-dong (original location since 1953) or the Haeundae branch. Eat warm — they're best fresh off the fryer. The small museum at the flagship shows the history.", "hours": "9am – 9pm daily", "address": "Gukje Market (Nampo-dong) and Haeundae branch", "mapLink": "https://www.samjinfood.com", "link": "https://www.samjinfood.com", "interest": ["foodie"], "diet": ["seafood"], "vegOk": false, "foodCat": "street", "indoor": true, "logo": "https://logo.clearbit.com/samjinfood.com"},

  {"id":"r-milmyeon","neighbourhood":"busan-seomyeon","cat":"busan","name":"Daeyeon Milmyeon (대연밀면)","emoji":"🍜","gradient":"linear-gradient(135deg,#27ae60,#229954)","region":"busan","cost":"₩8,000–9,000","costZAR":"≈ R86–97","duration":"30 min","teaser":"Refreshing Busan cold wheat noodles with giant steamed dumplings — near the hotel.","desc":"Milmyeon (밀면) is Busan's answer to naengmyeon — chilled wheat noodles in an icy herbal beef broth (mul-milmyeon) or spicy sauce (bibim-milmyeon). Daeyeon Milmyeon in Nam-gu is close to the Bonathree Hotel and consistently excellent. Pair with wang-mandu (giant steamed dumplings) for a full lunch.","highlights":["Mul milmyeon (물밀면) — icy broth","Bibim milmyeon (비빔밀면) — spicy sauce","Wang mandu (왕만두) — giant steamed dumplings","Add vinegar + mustard to taste","Ask for scissors to cut noodles"],"tips":"Open 10:30am – 8:30pm. The restaurant fills up at lunch — arrive just before noon. Milmyeon is uniquely Busan; you can't get this in Seoul. The broth is lighter and less sour than Seoul-style naengmyeon.","hours":"10:30am – 8:30pm daily","address":"Daeyeon-dong, Nam-gu, Busan","mapLink":"https://naver.me/FGo4MvF1","link":"https://naver.me/FGo4MvF1","interest":["foodie"],"diet":["beef"],"vegOk":false,"wish":"noodles","indoor":true},

  {"id":"r-jagalchi","cat":"busan","name":"Jagalchi Fish Market (자갈치시장)","emoji":"🦑","gradient":"linear-gradient(135deg,#1a3a5a,#1f618d)","region":"busan","cost":"Varies — avg ₩20–50k per table","costZAR":"≈ R215–540","duration":"2 hrs","teaser":"Korea's largest fish market — buy fresh from tanks on the ground floor, eat on the 2nd floor.","desc":"The iconic 자갈치 market in Jung-gu (Nampo-dong area) is a Busan landmark. The ground floor is wall-to-wall live seafood vendors. Choose your crab, flatfish, shellfish, or sea cucumber; they clean and prepare it; you take it to any of the 2nd floor restaurants who serve it with rice and banchan. Loud, lively, extremely fresh.","highlights":["Live flatfish (광어회) — sliced raw","Whelk (소라) — chewy shellfish","Sea squirt (멍게) — intense umami","King crab — seasonal","2F restaurant \"processing fee\" ₩5k per kg"],"tips":"Haggle gently — vendors expect it. Early morning (before 10am) has the freshest stock. The 2F restaurants all charge a similar processing fee. Combine with a walk to nearby BIFF Square and Nampo-dong Hotteok Alley.","hours":"Ground floor: 5am – 10pm. 2F restaurants: 8am – 9pm","address":"Nampo-dong, Jung-gu, Busan","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/자갈치시장/","interest":["foodie","thrills"],"diet":["seafood"],"vegOk":false,"foodCat":"street","indoor":true},

  {"id":"r-bora","cat":"cafe","name":"Café Bora (카페 보라)","emoji":"💜","gradient":"linear-gradient(135deg,#6c3483,#8e44ad)","region":"seoul1","cost":"₩6,000–9,000","costZAR":"≈ R65–97","duration":"45 min","teaser":"The most Instagrammable café in Seoul — purple matcha soft-serve and traditional honeycomb waffles.","desc":"Cafe Bora is famous for its signature charcoal honeycomb waffles (호떡와플), lavender-purple matcha soft-serve, and Bora Latte (perilla leaf + cream). Located steps from Gyeongbokgung Palace in Insadong's Ssamziegil courtyard. The purple palette against the traditional hanok background is impossibly photogenic. Usually queues of 20–30 minutes.","highlights":["Charcoal waffle (숯불호떡와플) — ₩5k","Bora soft-serve (보라소프트아이스크림) — purple swirl","Bora Latte — perilla leaf, not coffee","Traditional sikhye drink","Ssamziegil courtyard setting"],"tips":"Come right when they open (10am) or after 3pm for shorter queues. The waffle sells out on weekends by 2pm. Order at the window, wait for name to be called. The Ssamziegil courtyard outside is also lovely to browse — crafts, indie brands, galleries.","hours":"10am – 8pm daily (may close Mon)","address":"Insadong-gil, Insadong, Jongno-gu (in Ssamziegil)","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/카페보라/","interest":["foodie","fashion"],"diet":[],"vegOk":true,"wish":"bingsu","foodCat":"cafes","indoor":true},

  {"id": "r-terarosa", "neighbourhood": "gangnam", "cat": "cafe", "name": "Terarosa at F1963 (Busan)", "emoji": "☕", "gradient": "linear-gradient(135deg,#3e2723,#6d4c41)", "region": "busan", "cost": "₩6,000–9,000", "costZAR": "≈ R65–97", "duration": "1 hr", "teaser": "South Korea's most lauded specialty coffee roaster, inside a spectacular converted wire factory.", "desc": "Terarosa is Korea's highest-regarded specialty coffee brand — single-origin beans, precise pour-overs, and impeccable espresso. The F1963 branch in Suyeong-gu, Busan, occupies a vast industrial space inside a converted wire factory complex. Beautiful exposed brick, lush greenhouse elements, and a Yes24 secondhand bookshop next door.", "highlights": ["Single-origin pour-over (핸드드립)", "Espresso tonic", "Cold brew", "Signature cakes — honey roll, tarts", "Browse the Yes24 bookshop next door"], "tips": "F1963 is a half-day destination — coffee + browse the bookshop + explore the cultural complex. Also has a Terarosa in Seosomun, Seoul if you don't make it to Busan. The Busan branch is architecturally special.", "hours": "9am – 8pm daily", "address": "F1963 Cultural Complex, Suyeong-gu, Busan", "mapLink": "http://www.f1963.org", "link": "http://www.f1963.org", "interest": ["foodie", "fashion"], "diet": [], "vegOk": true, "foodCat": "cafes", "indoor": true, "logo": "https://logo.clearbit.com/terarosa.com"},

  {"id":"r-sulbing","neighbourhood":"myeongdong","cat":"cafe","name":"Sulbing (설빙) — Bingsu Chain","emoji":"🍧","gradient":"linear-gradient(135deg,#2980b9,#85c1e9)","region":"any","cost":"₩8,000–14,000","costZAR":"≈ R86–150","duration":"30 min","teaser":"Korea's national bingsu (shaved ice) chain — reliable, generous, and in every major area.","desc":"Sulbing (설빙) is the go-to chain for patbingsu (red bean shaved ice), mango bingsu, and injeolmi bingsu (rice cake + bean powder). Shaved milk ice is incredibly light — it dissolves immediately on the tongue rather than crunching like ice. Portions are enormous and perfectly shareable. Open in summer from 10am; usually still available at the Hongdae and Myeongdong branches year-round.","highlights":["Patbingsu (팥빙수) — classic red bean","Mango bingsu","Injeolmi bingsu (인절미) — rice cake + bean powder","Strawberry (딸기)","Cheesecake bingsu (seasonal)"],"tips":"One large bingsu is enough for two people. Eat quickly in summer — the ice melts faster than you expect in Korean July heat. The Myeongdong branch usually has English menus.","hours":"10am – 10pm (seasonal variance)","address":"Multiple — Myeongdong, Hongdae, Insadong, Haeundae","mapLink":"","link":"https://www.instagram.com/sulbing_official/","interest":["foodie"],"diet":[],"vegOk":true,"wish":"bingsu","foodCat":"cafes","indoor":true},

  {"id": "r-parisbaguette", "cat": "bakery", "name": "Paris Baguette / Tous Les Jours", "emoji": "🥐", "gradient": "linear-gradient(135deg,#c8963e,#a04000)", "region": "any", "cost": "₩2,000–6,000", "costZAR": "≈ R22–65", "duration": "15 min", "teaser": "Korea's ubiquitous bakery chains — great breakfast pastries, cakes, and filled breads on every block.", "desc": "Paris Baguette and Tous Les Jours (both Korean) are the cornerstone of Korean bakery culture. Available literally everywhere. Good for: croissants, soft cream-filled bread, garlic bread, cakes, egg tarts, and hot beverages. Not artisanal — but consistent, affordable, and a genuine cultural fixture. Excellent grab-and-go breakfast.", "highlights": ["Garlic cream bread (마늘빵) — a signature item", "Soft cream-filled rolls", "Red bean bun (팥빵)", "Egg tart", "Croissants — surprisingly good"], "tips": "Korea's ubiquitous bakery chain. Great for grab-and-go sweet garlic cream bread, croissants, egg tarts, and soft pastries.", "hours": "7am – 10pm (most locations)", "address": "On almost every block in Seoul and Busan", "mapLink": "", "link": "", "interest": ["foodie"], "diet": [], "vegOk": true, "foodCat": "cafes", "indoor": true, "logo": "https://upload.wikimedia.org/wikipedia/commons/b/b7/Paris_Baguette_logo.svg", "menuLink": "http://www.paris.co.kr/"},

  {"id": "r-onion", "neighbourhood": "seongsu", "cat": "bakery", "name": "Cafe Onion Anguk (어니언 안국)", "emoji": "🥐", "gradient": "linear-gradient(135deg,#6e4a2f,#c8963e)", "region": "seoul1", "cost": "₩5,000–12,000", "costZAR": "≈ R54–130", "duration": "1 hr", "teaser": "Seoul's most famous hanok bakery-café — pandoro mountains of sugar inside a traditional courtyard house.", "desc": "Onion's Anguk branch occupies a beautifully restored hanok where you sit on heated wooden floors around a courtyard. The signature pandoro — a butter brioche buried under a mountain of powdered sugar — is the most photographed pastry in Seoul. Strong specialty coffee, too.", "highlights": ["Pandoro — the signature", "Hanok courtyard seating", "Specialty espresso bar", "Steps from Anguk station + palaces", "Branches in Seongsu & Gwangjang too"], "tips": "Come on a weekday before 11am or expect a queue. Pairs perfectly with a Gyeongbokgung / Bukchon morning — it's right by Anguk station. Order at the counter, find floor seating.", "hours": "7am – 10pm (from 9am weekends)", "address": "Gyedong-gil, Anguk, Jongno-gu, Seoul", "interest": ["foodie", "fashion"], "diet": [], "vegOk": true, "foodCat": "cafes", "indoor": true, "mapLink": "https://naver.me/", "link": "https://www.instagram.com/cafe.onion/", "logo": "https://logo.clearbit.com/onionkr.com"},

  {"id": "r-kyochon", "neighbourhood": "hongdae", "cat": "chain", "name": "Kyochon Chicken — Chimaek Night", "emoji": "🍗", "gradient": "linear-gradient(135deg,#7d6608,#f4d03f)", "region": "any", "cost": "₩20,000–28,000", "costZAR": "≈ R215–300", "duration": "1.5 hrs", "teaser": "Korea's benchmark fried chicken chain — honey-soy wings + cold beer is the national pastime.", "desc": "Kyochon is the chain that defined modern Korean fried chicken: double-fried, brushed (never drowned) in garlic-soy or honey glaze, impossibly crisp. Order a \"half-half\" with a cold draft beer for the classic chimaek experience, in-store or delivered to a Han River park.", "highlights": ["Honey Original — the bestseller", "Garlic-soy (Kyochon Original)", "Red pepper series for heat seekers", "Half-half combos", "Delivers to Han River picnic zones"], "tips": "Benchmark Korean fried chicken. Double-fried for maximum crunch and brushed with garlic-soy or honey glaze. Try chimaek delivery to Han River park.", "hours": "Most branches 12pm – 12am", "address": "Branches everywhere in Seoul & Busan", "interest": ["foodie"], "diet": [], "vegOk": false, "wish": "chicken", "indoor": true, "mapLink": "https://naver.me/", "link": "http://www.kyochon.com/", "logo": "https://www.kyochon.com/images/common/logo.png", "menuLink": "http://www.kyochon.com/menu/"},

  {"id": "r-isaac", "neighbourhood": "hongdae", "cat": "chain", "name": "Isaac Toast (이삭토스트)", "emoji": "🥪", "gradient": "linear-gradient(135deg,#9c640c,#f5b041)", "region": "any", "cost": "₩3,500–5,500", "costZAR": "≈ R38–60", "duration": "15 min", "teaser": "The cult grab-and-go breakfast: buttered griddle toast, egg, ham, and that famous sweet sauce.", "desc": "Isaac Toast is Korea's breakfast institution — sandwiches of thick toast grilled in butter, layered with a seasoned egg omelette, ham or bulgogi, cheese, cabbage slaw, and the signature sweet-savoury sauce. Under ₩6,000 and on practically every block.", "highlights": ["Ham Special — the classic order", "Bulgogi MVP", "Bacon Best", "Double egg + cheese add-ons", "Pairs with banana milk, obviously"], "tips": "Korea's ultimate breakfast griddle sandwiches with ham, cabbage slaw, egg, and their famous sweet kiwi sauce. Very fast commuter service.", "hours": "Most branches 7am – 7pm", "address": "Everywhere — multiple branches per district", "interest": ["foodie"], "diet": ["pork"], "vegOk": false, "wish": "convenience", "indoor": true, "mapLink": "https://naver.me/", "link": "https://www.isaac-toast.co.kr/", "logo": "https://www.isaac-toast.co.kr/img/logo.svg", "menuLink": "https://www.isaac-toast.co.kr/menu/menu.php"},

  {"id": "r-randys", "neighbourhood": "hongdae", "cat": "bakery", "name": "Randy's Donuts (랜디스도넛)", "emoji": "🍩", "gradient": "linear-gradient(135deg,#b03a2e,#f1948a)", "region": "any", "cost": "₩3,000–5,500", "costZAR": "≈ R32–60", "duration": "30 min", "teaser": "The giant LA donut sign lands in Korea — fluffy rings with Korea-only glazes.", "desc": "The iconic Los Angeles donut shop has become a phenomenon in Korea, with locations marked by the giant orange donut. Korean-exclusive flavours (injeolmi, black sesame, seasonal fruit glazes) sit beside the classic glazed ring. Great photo-op, better snack.", "highlights": ["Classic glazed — benchmark", "Injeolmi (roasted soybean) — Korea only", "Seasonal fruit glazes", "Giant donut sign photo-op", "Good iced coffee"], "tips": "LA-born giant donut sign shop. Fluffy rings with exclusive Korean flavors like injeolmi, black sesame, and sweet potato. Long lines on weekends.", "hours": "Most branches 10am – 9pm", "address": "Yeonnam-dong & Gangnam, Seoul (check Naver for nearest)", "interest": ["foodie", "fashion"], "diet": [], "vegOk": true, "foodCat": "cafes", "indoor": true, "mapLink": "https://naver.me/", "link": "https://www.instagram.com/randysdonuts_kr/", "logo": "https://logo.clearbit.com/randysdonuts.com", "menuLink": "https://randysdonuts.com/menu/"},

  {"id": "r-sinjeon", "neighbourhood": "hongdae", "cat": "chain", "name": "Sinjeon Tteokbokki (신전떡볶이)", "emoji": "🌶️", "gradient": "linear-gradient(135deg,#922b21,#e74c3c)", "region": "any", "cost": "₩4,000–10,000", "costZAR": "≈ R43–108", "duration": "45 min", "teaser": "The fast-casual tteokbokki chain Koreans actually eat — peppery sauce, cheese rice cakes, fried sides.", "desc": "Sinjeon is the country's biggest tteokbokki franchise for a reason: a distinctively peppery (not just sweet) gochujang sauce, optional cheese-stuffed rice cakes, and a menu of fried sides and cheap gimbap to dunk. A reliable, cheap, very Korean lunch anywhere in the country.", "highlights": ["Original tteokbokki — peppery & hot", "Cheese tteokbokki — milder", "Fried mandu + fish cake sides", "Cheap gimbap rolls", "Rose (cream) sauce option"], "tips": "Fast-casual tteokbokki chain with distinctively peppery, spicy gochujang sauce and cheese-stuffed rice cakes. Dip the fried fish cakes in the sauce!", "hours": "Most branches 11am – 10pm", "address": "Branches everywhere in Seoul & Busan", "interest": ["foodie"], "diet": ["spicy"], "vegOk": false, "foodCat": "street", "indoor": true, "mapLink": "https://naver.me/", "link": "https://sinjeon.co.kr/", "logo": "https://logo.clearbit.com/sinjeon.co.kr", "menuLink": "https://sinjeon.co.kr/menu/"},

  {"id":"r-hanwoo","neighbourhood":"seongsu","cat":"seoul","name":"Hanwoo Somori Gukbap (한우 소머리국밥)","emoji":"🐂","gradient":"linear-gradient(135deg,#5d4037,#a1887f)","region":"seoul1","cost":"₩12,000–18,000","costZAR":"≈ R130–195","duration":"1 hr","teaser":"Premium Hanwoo beef-head soup simmered for hours — the deep-cut local bowl.","desc":"Somori gukbap is a hearty broth made by simmering premium Hanwoo beef for hours until the stock turns rich and the meat collapses. Served bubbling with rice, fresh kimchi, and salted shrimp to season. A locals' staple around Mapo — warming, restorative, zero tourist markup.","highlights":["Hanwoo (Korean native beef) stock","Tender beef-head meat slices","Season with salt + saeujeot shrimp paste","Free kimchi & banchan","Open early — great first-day breakfast"],"tips":"Stir the bowl well and season gradually. Most gukbap houses open before 8am — it's the classic jet-lag breakfast. Look for busy local spots around Gongdeok/Ahyeon on Naver Maps.","hours":"Typically 7am – 9pm","address":"Mapo-gu, Seoul (several around Gongdeok)","interest":["foodie"],"diet":["beef"],"vegOk":false,"wish":"soup","foodCat":"stews","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/somorigukbap/"},

  {"id":"r-perilla","neighbourhood":"seongsu","cat":"seoul","name":"Perilla Oil Buckwheat Noodles (들기름막국수)","emoji":"🍝","gradient":"linear-gradient(135deg,#4a6b53,#a9dfbf)","region":"seoul1","cost":"₩10,000–14,000","costZAR":"≈ R108–150","duration":"1 hr","teaser":"Cold buckwheat noodles in nutty cold-pressed perilla oil and roasted seaweed — clean and addictive.","desc":"Deulgireum makguksu — chewy buckwheat noodles tossed in fragrant cold-pressed perilla oil, soy, and a snowfall of roasted seaweed — has become one of Seoul's most loved \"clean\" dishes. Nutty, savoury, and light, it's the perfect antidote to a week of BBQ and fried chicken.","highlights":["Cold-pressed perilla oil","Buckwheat (memil) noodles","Roasted seaweed + sesame topping","Often served with bone broth on the side","Vegetarian-friendly"],"tips":"Mix thoroughly before eating — the oil should coat every strand. Famous makguksu specialists have queues at lunch; go before noon or mid-afternoon.","hours":"Typically 11am – 9pm","address":"Specialists in Mapo & Yeonnam — check Naver Maps","interest":["foodie"],"diet":[],"vegOk":true,"wish":"noodles","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/들기름막국수/"},

  {"id":"r-michelin-crab","neighbourhood":"gangnam","cat":"seoul","name":"Michelin Ganjang Gejang Set","emoji":"🦀","gradient":"linear-gradient(135deg,#0e6251,#45b39d)","region":"seoul1","cost":"₩30,000–45,000","costZAR":"≈ R325–485","duration":"1.5 hrs","teaser":"The splurge version: Michelin-listed soy-marinated raw crab with roe-and-rice in the shell.","desc":"Seoul's Michelin-recognised gejang specialists (Keunkiwajip near the palaces, Pro Ganjang Gejang in Sinsa) serve flower crab cured to silk in aged soy brine. The ritual finale: hot rice and sesame oil mixed directly inside the roe-lined shell. Expensive, unforgettable.","highlights":["Flower crab in aged soy brine","Roe + rice mixed in the shell","Full set with grilled fish + banchan","Michelin-listed spots: Keunkiwajip, Pro","Lunch sets are cheaper than dinner"],"tips":"Go at lunch for set-menu pricing. Book ahead on Catch Table or arrive at opening. This is the \"rice thief\" experience worth budgeting for once.","hours":"Typically 11:30am – 9:30pm","address":"Keunkiwajip (Jongno) / Pro (Sinsa), Seoul","interest":["foodie"],"diet":["seafood"],"vegOk":false,"wish":"crab","indoor":true,"expensive":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/ganjanggejang/"},

  {"id": "r-samwon", "neighbourhood": "apgujeong", "cat": "seoul", "name": "Samwon Garden — Premium Galbi", "emoji": "🥩", "gradient": "linear-gradient(135deg,#641e16,#cb4335)", "region": "seoul2", "cost": "₩45,000–70,000 pp", "costZAR": "≈ R485–755", "duration": "1.5 hrs", "teaser": "Seoul's legendary garden BBQ house — 40+ years of melt-apart marinated Hanwoo short rib.", "desc": "Operating since 1976 in Apgujeong, Samwon Garden is the grande dame of premium Korean BBQ: marinated Hanwoo galbi grilled tableside in a sprawling complex of gardens and waterfalls. This is the celebratory, dress-slightly-nicer version of K-BBQ — and the galbi is genuinely exceptional.", "highlights": ["Marinated Hanwoo galbi", "Garden + waterfall setting", "Naengmyeon to finish — tradition", "Galbi-jjim (braised ribs) also famous", "Valet + English menus available"], "tips": "Legendary premium Hanwoo BBQ house operating since 1976. Sprawling garden complex with waterfalls. Order cold naengmyeon after your grilled galbi.", "hours": "11:30am – 10pm daily", "address": "Apgujeong, Gangnam-gu, Seoul", "interest": ["foodie"], "diet": ["beef"], "vegOk": false, "wish": "bbq", "foodCat": "bbq", "indoor": true, "expensive": true, "mapLink": "https://naver.me/", "link": "https://www.samwongarden.com/", "logo": "https://logo.clearbit.com/samwongarden.com", "menuLink": "https://www.samwongarden.com/menu"},

  {"id":"r-noah","neighbourhood":"seongsu","cat":"cafe","name":"Noah Cityhouse Café & Gallery","emoji":"🎨","gradient":"linear-gradient(135deg,#2c3e50,#aab7b8)","region":"seoul1","cost":"₩6,000–12,000","costZAR":"≈ R65–130","duration":"1 hr","teaser":"A minimalist multi-storey café-showroom in Seongsu — artisan coffee in a design-magazine interior.","desc":"Part café, part gallery, part design showroom in Seongsu — Seoul's \"Brooklyn.\" Concrete, steel, and warm wood frame artisan coffee and sculptural desserts. Come for the interiors, stay to people-watch Seoul's best-dressed neighbourhood.","highlights":["Design-forward multi-floor space","Artisan espresso + pour-over","Sculptural seasonal desserts","Seongsu gallery-hopping nearby","Quiet on weekday mornings"],"tips":"Seongsu cafés peak 1–5pm on weekends — go weekday morning for the space to yourself. Combine with the salt-bread bakeries and silver shops on the same streets.","hours":"Typically 10am – 9pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion","foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/seongsucafe/"},

  {"id":"r-buckwheat-chicken","neighbourhood":"hongdae","cat":"seoul","name":"Buckwheat-Crust Fried Chicken","emoji":"🍗","gradient":"linear-gradient(135deg,#784212,#e59866)","region":"seoul1","cost":"₩20,000–24,000","costZAR":"≈ R215–260","duration":"1.5 hrs","teaser":"Korea's craft-chicken trend: buckwheat-flour batter fried to an impossibly airy crunch.","desc":"The artisan answer to the big chains: chicken coated in buckwheat flour and fried so the crust shatters like tempura, served with house-made garlic-soy and sweet-spicy sauces. Seoul's craft chicken houses (many around Mapo and Yeonnam) pair these with small-brewery beer.","highlights":["Buckwheat batter — extra crunch","House garlic-soy glaze","Craft beer pairings","Smaller portions than chains — order sides","Trendy Yeonnam/Mapo locations"],"tips":"These spots are dinner-only crowd magnets — arrive before 6:30pm or be ready to waitlist on Catch Table. The plain (huraideu) version shows off the crust best.","hours":"Typically 5pm – 11pm","address":"Yeonnam & Mapo, Seoul — check Naver Maps","interest":["foodie"],"diet":[],"vegOk":false,"wish":"chicken","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/koreanfriedchicken/"},

  {"id":"r-londonbagel","cat":"bakery","name":"London Bagel Museum (런던베이글뮤지엄)","emoji":"🥯","gradient":"linear-gradient(135deg,#6e4a2f,#d5a86b)","region":"seoul1","cost":"₩4,000–9,000","costZAR":"≈ R43–97","duration":"1 hr","teaser":"The most hyped bakery in Korea — pretzel bagels and spring-onion cream cheese worth the queue.","desc":"London Bagel Museum sparked Korea's bagel obsession: a London-corner-shop interior, trays of pretzel bagels, and tubs of whipped cream cheese (spring onion, yuzu, garlic). The Anguk branch near the palaces is the original. Queues are real but the line moves; everything freezes well for snacks later.","highlights":["Pretzel salt bagel — the signature","Spring onion cream cheese","Potato cheese bagel (hot)","London-corner-shop interiors","Anguk original + Dosan branch"],"tips":"Use the Catch Table app to join the waitlist remotely, or go on a weekday right at opening (8am). Take a box to go and eat in Bukchon if the wait for seats is long.","hours":"8am – 6pm (sells out earlier some days)","address":"Anguk, Jongno-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/london.bagel.museum/"},

  {"id":"r-layered","cat":"bakery","name":"Cafe Layered Yeonnam (카페 레이어드)","emoji":"🧁","gradient":"linear-gradient(135deg,#884ea0,#d7bde2)","region":"seoul1","cost":"₩4,500–9,000","costZAR":"≈ R49–97","duration":"1 hr","teaser":"British-style scone heaven in a red-brick Yeonnam house — towering cream-topped bakes.","desc":"Cafe Layered turned the humble scone into a Seoul phenomenon: dozens of varieties from Earl Grey to injeolmi, piled with clotted cream, in a cottage-core red-brick house in Yeonnam-dong — a 15-minute walk from Hongdae. The Anguk branch is equally pretty.","highlights":["Signature scones (10+ flavours)","Clotted cream + house jams","Victoria sponge + carrot cake","Cottage-style interiors","Yeonnam-dong café-street location"],"tips":"Scones sell out by late afternoon — mid-morning is ideal. Combine with a stroll along the Gyeongui Line Forest Park, which runs right through Yeonnam.","hours":"10am – 9pm daily","address":"Yeonnam-dong, Mapo-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/cafe_layered/"},

  {"id":"r-knotted","cat":"bakery","name":"Cafe Knotted (노티드) — Cream Donuts","emoji":"🍩","gradient":"linear-gradient(135deg,#c2185b,#f8bbd0)","region":"any","cost":"₩3,500–5,000","costZAR":"≈ R38–54","duration":"30 min","teaser":"Korea's cult cream-filled donuts — pillowy rings, pastel boxes, and the smiley bear.","desc":"Knotted's milk-cream donuts — impossibly light brioche rings filled with vanilla cream — became a national craze and never left. Pastel shops, character merch, and flavours like Injeolmi and Mugwort beside classic Milk Cream. Branches across Seoul and in Busan.","highlights":["Classic Milk Cream — start here","Injeolmi + seasonal Korean flavours","Smiley bear merch","Branches in most major districts","Boxes travel well for hotel snacks"],"tips":"The cream is rich — one each is plenty. Big branches (Gangnam, Jamsil, Lotte World Mall) rarely queue like the original did. Good gift boxes for the flight home.","hours":"Most branches 10am – 9pm","address":"Branches across Seoul & Busan","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/cafeknotted/"},

  {"id": "r-eggdrop", "cat": "chain", "name": "Egg Drop (에그드랍)", "emoji": "🍳", "gradient": "linear-gradient(135deg,#b9770e,#f7dc6f)", "region": "any", "cost": "₩4,500–6,500", "costZAR": "≈ R49–70", "duration": "15 min", "teaser": "Soft scrambled-egg sandwiches on buttery brioche — Isaac Toast's trendier rival.", "desc": "Egg Drop stacks impossibly soft scrambled eggs on toasted brioche with toppings like bacon, avocado, or bulgogi, finished with signature sauces. The yellow-boxed sandwiches are an Instagram fixture and a perfect fast breakfast before a palace morning.", "highlights": ["Bacon Double Cheese — bestseller", "Avocado Holic", "Bulgogi option", "Sweet \"Garlic Bomb\" sauce", "Coffee set deals"], "tips": "Thick, buttery brioche griddled toast stuffed with fluffy scrambled eggs, bacon, and sweet garlic-bomb sauce. Perfect Instagrammable morning fuel.", "hours": "Most branches 8am – 9pm", "address": "Branches everywhere in Seoul & Busan", "interest": ["foodie"], "diet": ["pork"], "vegOk": false, "wish": "convenience", "indoor": true, "mapLink": "https://naver.me/", "link": "https://www.instagram.com/eggdrop_official/", "logo": "https://logo.clearbit.com/eggdrop.co.kr", "menuLink": "https://eggdrop.co.kr/menu/"},

  {"id":"r-gongdeok-jokbal","cat":"seoul","name":"Gongdeok Jokbal & Jeon Alley","emoji":"🐷","gradient":"linear-gradient(135deg,#6e2c00,#dc7633)","region":"seoul1","cost":"₩15,000–35,000","costZAR":"≈ R160–380","duration":"1.5 hrs","teaser":"A covered market alley of glistening soy-braised pork trotters and fried-to-order jeon pancakes.","desc":"One subway stop from Ahyeon, Gongdeok Market hides a famous alley of jokbal (soy-braised pork trotters, sliced and wrapped in lettuce) and stalls piling mixed jeon (savoury pancakes) sold by the plateful. Loud, local, cheap, and best with a bottle of makgeolli.","highlights":["Jokbal — collagen-rich braised pork","Mixed jeon plate — pick from 20+ types","Makgeolli (rice wine) pairing","Covered alley — rain-proof","Walking distance from Ahyeon base"],"tips":"Point at what you want — vendors plate a mixed selection by price (₩10k feeds two as a snack). Evening is the atmosphere peak. Cash helps at the jeon stalls.","hours":"Stalls ~11am – 10pm","address":"Gongdeok Market, Mapo-gu, Seoul","interest":["foodie","culture"],"diet":["pork"],"vegOk":false,"foodCat":"street","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/공덕시장/"},

  {"id":"r-cvs","cat":"chain","name":"GS25 / CU Convenience Store Run","emoji":"🏪","gradient":"linear-gradient(135deg,#1b4f72,#5dade2)","region":"any","cost":"₩1,000–8,000","costZAR":"≈ R11–86","duration":"30 min","teaser":"The full K-convenience ritual: triangle gimbap, cook-it-yourself ramyeon, banana milk, snack haul.","desc":"A planned stop, not an errand: Korean convenience stores are a food destination. Grab triangle gimbap and a fresh dosirak, cook ramyeon at the free hot-water counter, raid the snack aisle for honey-butter everything, and finish with banana milk at the window seats. Open 24/7, every block.","highlights":["Triangle gimbap + dosirak lunchboxes","Hot-water ramyeon counter","Banana milk & snack aisle","1+1 / 2+1 promo deals","Perfect cheap dinner on travel days"],"tips":"Look for \"1+1\" and \"2+1\" tags — automatic freebies at the till. GS25 and CU have the best fresh food; Emart24 is calmer for late-night sit-downs. T-money cards work as payment.","hours":"24/7","address":"Every block, everywhere","interest":["foodie"],"diet":[],"vegOk":true,"wish":"convenience","indoor":true,"mapLink":"","link":"https://www.instagram.com/explore/tags/편의점/"},

  {"id":"r-ops","cat":"bakery","name":"OPS Bakery (옵스) — Haeundae","emoji":"🥖","gradient":"linear-gradient(135deg,#7e5109,#f5cba7)","region":"busan","cost":"₩2,500–7,000","costZAR":"≈ R27–76","duration":"30 min","teaser":"Busan's beloved heritage bakery since 1989 — famous for its \"Schweine-chen\" cream buns.","desc":"OPS is Busan's home-grown bakery institution, beloved for decades. The signature \"Schweinchen\" (a soft bun with sweet cream) and the red-bean breads have cult status, and everything is baked on-site daily. The Haeundae branch makes an easy stop before the beach or Sky Capsule.","highlights":["Schweinchen cream bun — the icon","Red bean bread (단팥빵)","Seasonal fruit cakes","Baked on-site daily","Multiple Busan branches incl. Haeundae"],"tips":"Take a tray and tongs, self-serve style. Mornings have the fullest shelves. A box of buns is perfect fuel for the Blueline Sky Capsule queue.","hours":"Typically 8am – 10pm","address":"Haeundae, Busan (multiple branches)","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/옵스베이커리/"},

  {"id":"r-momos","cat":"cafe","name":"Momos Coffee Roastery (모모스커피)","emoji":"☕","gradient":"linear-gradient(135deg,#4d3319,#b9770e)","region":"busan","cost":"₩5,500–10,000","costZAR":"≈ R60–108","duration":"1 hr","teaser":"Home of a World Barista Champion — Busan's pilgrimage-worthy roastery on Yeongdo.","desc":"Momos Coffee put Busan on the global coffee map when Jooyeon Jeon won the 2019 World Barista Championship. The Yeongdo roastery is a destination: a huge harbourside space with a tasting bar, single-origin pour-overs, and house-baked goods. Pairs perfectly with Huinnyeoul Village nearby.","highlights":["World Barista Champion pedigree","Single-origin pour-over bar","Harbourside roastery space","House bakery","Combine with Huinnyeoul Village"],"tips":"Order a pour-over flight if available, and buy beans as gifts — the packaging is beautiful. The original Oncheonjang branch is closer to central Busan if Yeongdo doesn't fit your day.","hours":"9am – 6pm (roastery; check Naver)","address":"Yeongdo-gu, Busan","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/momos_coffee/"},

  {"id":"r-haeundae-market","cat":"busan","name":"Haeundae Traditional Market","emoji":"🍜","gradient":"linear-gradient(135deg,#0e6655,#73c6b6)","region":"busan","cost":"₩3,000–12,000","costZAR":"≈ R32–130","duration":"1 hr","teaser":"A covered market street one block from the beach — famous kalguksu stalls, hotteok, and grilled eel.","desc":"One block behind Haeundae Beach, this compact covered market is the antidote to beachfront restaurant prices: steaming hand-cut kalguksu noodle stalls (the market's claim to fame), ssiat hotteok, gimbap ladies, fried chicken, and grilled eel. Cheap, fast, and full of character.","highlights":["Kalguksu noodle stalls — market icons","Ssiat hotteok (seed pancakes)","Grilled eel restaurants","Fresh gimbap to take to the beach","Covered — works in the rain"],"tips":"Sit at whichever kalguksu stall has locals slurping — they're all good, ~₩6–8k a bowl. Take gimbap and hotteok to the beach for sunset. Card accepted at most stalls now.","hours":"Stalls ~9am – 9pm","address":"Haeundae-ro 620beon-gil, Haeundae, Busan","interest":["foodie","culture"],"diet":[],"vegOk":true,"wish":"kalguksu","foodCat":"street","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/해운대시장/"},

  {"id":"r-yeongcheon","cat":"seoul","name":"Yeongcheon Market (영천시장) — Kkwabaegi Alley","emoji":"🥨","gradient":"linear-gradient(135deg,#935116,#f0b27a)","region":"seoul2","cost":"₩1,000–8,000","costZAR":"≈ R11–86","duration":"1 hr","teaser":"The local market 10 minutes from your Seodaemun apartment — legendary twisted sugar doughnuts.","desc":"Yeongcheon Market sits right between your Bugahyeon-ro apartment and the old city — a genuinely local covered market famous for kkwabaegi (twisted doughnuts rolled in sugar, fried fresh all day) and old-school tteokbokki counters. Zero tourists, real Seoul.","highlights":["Kkwabaegi twisted doughnuts — ₩1k each","Old-school tteokbokki counters","Fresh tofu & banchan vendors","Mandu steamers","10 min walk from the leg-3 apartment"],"tips":"Buy kkwabaegi by the bagful from whichever stall is frying right then. Go late afternoon when everything's fresh for the dinner rush. Cash is easiest here.","hours":"Stalls ~8am – 8pm","address":"Tongil-ro, Seodaemun-gu, Seoul (near Dongnimmun station)","interest":["foodie","culture"],"diet":[],"vegOk":true,"wish":"hotteok","foodCat":"street","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/영천시장/"},

  {"id":"r-imun","cat":"seoul","name":"Imun Seolnongtang (이문설농탕) — Since 1904","emoji":"🥣","gradient":"linear-gradient(135deg,#717d7e,#d5dbdb)","region":"seoul2","cost":"₩13,000–16,000","costZAR":"≈ R140–175","duration":"45 min","teaser":"Seoul's oldest restaurant — milky ox-bone soup served the same way for 120 years.","desc":"Registered as Seoul's first licensed restaurant, Imun Seolnongtang has ladled seolleongtang (milky ox-bone soup with brisket and rice) since 1904. You season it yourself with salt, pepper, and spring onion at the table. Eating here is tasting living Seoul history.","highlights":["Seolleongtang — 120-year recipe","Season at the table: salt + scallions","Suyuk (boiled brisket plate) to share","Kkakdugi radish kimchi — famous here","Seoul's oldest restaurant"],"tips":"It's near Jongno 3-ga / Insadong — easy after palaces. The broth arrives unseasoned by design; salt it gradually. Add rice into the bowl if it isn't already in.","hours":"8am – 9pm (check holidays)","address":"Ujeongguk-ro, Jongno-gu, Seoul","interest":["foodie","culture"],"diet":["beef"],"vegOk":false,"wish":"soup","foodCat":"stews","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/이문설농탕/"},

  {"id":"r-mijin","neighbourhood":"gwanghwamun","cat":"seoul","name":"Gwanghwamun Mijin (광화문 미진) — Since 1954","emoji":"🍱","gradient":"linear-gradient(135deg,#1e8449,#a9dfbf)","region":"seoul2","cost":"₩10,000–15,000","costZAR":"≈ R108–160","duration":"45 min","teaser":"70 years of cold buckwheat noodles dipped in chilled broth — the office workers' lunch legend.","desc":"Mijin has served memil guksu (buckwheat noodles with a chilled soy-based dipping broth, Korean-style) near Gwanghwamun since 1954. At lunch, the queue of office workers says everything. Clean, nutty, refreshing — ideal in July heat and an easy walk from Gyeongbokgung or Seodaemun.","highlights":["Memil guksu — dip-style buckwheat noodles","Refill broth kettles on the table","Buckwheat jeon (pancake) side","70-year institution","Fast-moving lunch queue"],"tips":"Go before 11:45am or after 1:15pm to dodge the office rush. Order the buckwheat pancake to share. The broth is for dipping, not drinking straight — though everyone does at the end.","hours":"11am – 9pm (break time mid-afternoon)","address":"Jong-ro, Gwanghwamun, Seoul","interest":["foodie","culture"],"diet":[],"vegOk":false,"wish":"noodles","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/광화문미진/"},

  {"id": "r-bills-gangnam", "neighbourhood": "gangnam", "cat": "cafe", "name": "Bills Gangnam", "emoji": "🍳", "gradient": "linear-gradient(135deg,#e8c97a,#c47a2e)", "region": "seoul2", "cost": "₩20,000–45,000", "costZAR": "≈ R215–485", "duration": "1 hr", "teaser": "The legendary Sydney all-day breakfast institution — ricotta hotcakes and shakshouka in Gangnam.", "desc": "The Australian brunch empire famous for the \"world's best breakfast\" has a Seoul outpost in Gangnam. Bills does ricotta hotcakes with honeycomb butter, shakshouka, and its legendary scrambled eggs on brioche. The Gangnam branch draws a mix of wealthy locals and travellers in the mood for a special-occasion breakfast. Not cheap — but occasionally worth the splurge.", "highlights": ["Ricotta hotcakes + honeycomb butter — the signature", "Shakshouka with house-baked bread", "Scrambled eggs on brioche", "Granola with seasonal fruit", "Wagyu steak burger at lunch"], "tips": "Sydney-style all-day brunch. Legendary ricotta hotcakes with honeycomb butter, silky scrambled eggs, and shakshouka. Great upscale Gangnam splurge.", "hours": "8am – 10pm daily", "address": "Sinsa-dong, Gangnam-gu, Seoul", "interest": ["foodie", "fashion"], "diet": [], "vegOk": true, "foodCat": "cafes", "indoor": true, "needsBooking": true, "mapLink": "https://naver.me/", "link": "https://www.instagram.com/billsrestaurant/", "logo": "https://logo.clearbit.com/billskorea.com", "menuLink": "https://www.billsrestaurant.com/menu"},

  {"id": "r-nudake", "neighbourhood": "apgujeong", "cat": "cafe", "name": "Nudake — Haus Dosan", "emoji": "🎂", "gradient": "linear-gradient(135deg,#1c1c1c,#7d6608)", "region": "seoul2", "cost": "₩12,000–28,000", "costZAR": "≈ R130–300", "duration": "1 hr", "teaser": "Gentle Monster's dramatic dessert lab — architectural cakes and sculptural pastries inside an art installation.", "desc": "Nudake is the dessert café arm of the Gentle Monster universe, housed inside the Haus Dosan complex in Apgujeong. The space doubles as a gallery with constantly rotating art installations. The cakes and pastries are built to the same visual drama as the eyewear — expect geometric mousse domes, terracotta cream tarts, and flavours that shift seasonally.", "highlights": ["Seasonal geometric mousse cakes", "Terracotta cream tart", "Black sesame choux", "Matcha latte + iced lattes", "Inside the Haus Dosan art installation"], "tips": "Gentle Monster's dramatic dessert lab inside Haus Dosan. Famous for its structural 'Peak' matcha croissant cake and geometric pastries.", "hours": "11am – 9pm daily", "address": "Haus Dosan, Apgujeong, Gangnam-gu, Seoul", "interest": ["fashion", "foodie"], "diet": [], "vegOk": true, "foodCat": "cafes", "indoor": true, "mapLink": "https://naver.me/", "link": "https://www.instagram.com/nudake_official/", "logo": "https://logo.clearbit.com/nudake.com", "menuLink": "https://nudake.com/"},

  {"id":"r-yukjeon","neighbourhood":"seongsu","cat":"seoul","name":"Yukjeon Sikdang (육전식당)","emoji":"🥩","gradient":"linear-gradient(135deg,#5d4037,#bc8a5f)","region":"seoul2","cost":"₩15,000–30,000","costZAR":"≈ R162–325","duration":"1 hr","teaser":"A Seongsu favourite — pan-fried sliced beef (yukjeon) served on sizzling cast iron in a stripped-back dining room.","desc":"Yukjeon sikdang specialises in yukjeon — thin slices of marinated beef coated in egg and pan-fried, served with banchan and hot rice. The Seongsu branch draws a fashion-forward crowd and has a minimal, warm interior. Casual but excellent, and very reasonable for the quality.","highlights":["Yukjeon (육전) — egg-battered pan-fried beef","Doenjang jjigae to accompany","Fresh banchan spreads","Warm timber dining room","Popular with the Seongsu creative crowd"],"tips":"Arrives quickly — great for a fast lunch before gallery-hopping in Seongsu. Arrive at opening for first service or be prepared to wait. No reservations taken.","hours":"11:30am – 9pm (break ~3–5pm)","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie"],"diet":["beef"],"vegOk":false,"foodCat":"bbq","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/육전식당/"},

  {"id":"r-neungdong-minari","neighbourhood":"seongsu","cat":"seoul","name":"Neungdong Minari (능동미나리 성수점)","emoji":"🌿","gradient":"linear-gradient(135deg,#2e7d32,#a5d6a7)","region":"seoul1","cost":"₩14,000–65,000","costZAR":"≈ R150–700","duration":"1.5 hrs","teaser":"A Seongsu cult restaurant built around minari (Korean water parsley) — rare beef-and-herb combos you won't find anywhere else.","desc":"Neungdong Minari centres every dish around minari (미나리 — Korean water parsley), a green herb with a clean, slightly celery-like flavour. The menu includes minari gomtang (bone broth with parsley), yukhoe bibimbap with raw beef, and a stunning minari suok jeonjol — a hot pot of beef brisket and blanched minari. A unique Seoul experience beloved by locals and food writers.","highlights":["Minari Gomtang (미나리곰탕) — bone broth + herb ₩15k","Yukhoe Bibimbap — raw beef rice bowl ₩15k","Minari Suok Jeongol — herb hot pot ₩48–65k","Minari Yukhoe raw beef salad ₩27k","Minari Gomguk pancake ₩58–86k"],"tips":"The yukhoe (raw beef) dishes are signature — very fresh and handled carefully. The hot pot (suok jeongol) is great value to share. Book through Catch Table for weekends.","hours":"11am – 9pm (break 3–5pm); closed Mondays","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie"],"diet":["beef"],"vegOk":false,"wish":"soup","foodCat":"stews","indoor":true,"closedDay":1,"mapLink":"https://naver.me/","link":"https://www.instagram.com/ndminari/"},

  {"id":"r-waglewagle","neighbourhood":"seongsu","cat":"bakery","name":"Wagle Wagle Bakeshop","emoji":"🥐","gradient":"linear-gradient(135deg,#a04000,#f5cba7)","region":"seoul1","cost":"₩3,500–9,000","costZAR":"≈ R38–97","duration":"30 min","teaser":"A Seongsu neighbourhood bakery producing croissants and stuffed pastries with cult-level queues.","desc":"A small-batch artisan bakery tucked into Seongsu's warehouse district, Wagle Wagle has developed a reputation for exceptionally laminated croissants and creative stuffed pastries. The kind of bakery that sells out by noon on weekends. Simple interior — the focus is entirely on the baking.","highlights":["Plain croissant — benchmark lamination","Almond croissant — generous frangipane","Seasonal stuffed pastries","Made fresh daily — arrive early","Quiet weekday mornings only"],"tips":"Come before 10am on weekdays or expect limited selection. Pairs well with a walk through the Seongsu silver jewellery ateliers and salt bread shops nearby.","hours":"8am – sell-out (usually by noon weekends)","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/waglewagle/"},

  {"id":"r-okseon","neighbourhood":"gangnam","cat":"seoul","name":"Okseon Sikdang (옥전식당) — Yeoksam","emoji":"🍚","gradient":"linear-gradient(135deg,#4a3728,#c8963e)","region":"seoul2","cost":"₩9,000–18,000","costZAR":"≈ R97–195","duration":"45 min","teaser":"A no-frills Korean home-cooking restaurant near Yeoksam station — rice bowls and stews done the old way.","desc":"Okseon Sikdang is a neighbourhood dosirak-style restaurant with the kind of menu you'd find in a Korean grandmother's kitchen — well-seasoned kimchi jjigae, dubu jorim (braised tofu), and doenjang jjigae served in heavy earthenware pots. Extremely local, extremely good value.","highlights":["Kimchi jjigae (pork + kimchi stew)","Doenjang jjigae (fermented soybean stew)","Dubu jorim (spicy braised tofu — veggie-friendly)","Rice + banchan included","Zero tourist markup"],"tips":"Go at lunch when the jjigae is freshest. Cash helps but cards are usually accepted. The braised tofu option makes this one of the few genuinely good vegetarian choices in a standard Korean restaurant.","hours":"11am – 9pm (closed weekends at some branches)","address":"Yeoksam-dong, Gangnam-gu, Seoul","interest":["foodie"],"diet":["pork"],"vegOk":true,"foodCat":"stews","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/옥전식당/"},

  {"id":"r-samjangjip","neighbourhood":"mapo","cat":"seoul","name":"Samjang Jip KBBQ — 24hr (삼장집)","emoji":"🔥","gradient":"linear-gradient(135deg,#922b21,#f39c12)","region":"any","cost":"₩15,000–25,000 pp","costZAR":"≈ R162–270","duration":"1.5 hrs","teaser":"A 24-hour premium pork BBQ specialist — grade-1 Korean pork belly, open through the night.","desc":"Samjang Jip (삼장집) is a 24-hour pork BBQ restaurant specialising in Grade 1 Korean domestic pork belly and shoulder. The sign says \"국내산 1등급 돼지고기 전문점\" — Grade 1 domestic pork specialist — and they mean it. Open around the clock, making it perfect for a late-night post-noraebang BBQ session.","highlights":["Grade 1 domestic pork belly (삼겹살)","Pork shoulder (목살)","Ssamjang with lettuce and garlic","Open 24 hours — great for midnight BBQ","Price-per-portion very competitive for quality"],"tips":"The 24-hour factor is the edge — go after 10pm when the grill masters are in full flow. Great for a post-noraebang BBQ stretch. Order extra banchan refills freely.","hours":"24 hours","address":"Seoul (multiple locations — check Naver Maps)","interest":["foodie"],"diet":["pork"],"vegOk":false,"wish":"bbq","foodCat":"bbq","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/삼장집/"},

  {"id":"r-jaeyondo","neighbourhood":"seongsu","cat":"cafe","name":"Jaeyondo (자연도 소국밥) — Salt Bread","emoji":"🍞","gradient":"linear-gradient(135deg,#a0522d,#f4d03f)","region":"seoul1","cost":"₩2,500–5,000","costZAR":"≈ R27–54","duration":"20 min","teaser":"Seongsu's most celebrated salt bread bakery — the buttery, flaky sogeum-ppang you came to Korea for.","desc":"Jaeyondo is the Seongsu salt bread specialist that sparked Seoul's obsession with sogeum-ppang (소금빵): a buttery croissant-adjacent roll with a flaky, shatteringly crisp exterior, salt-crystal crust, and a pillowy interior. Made in small batches, and worth timing your visit around the fresh batches.","highlights":["Sogeum-ppang (소금빵) — salted butter roll","Butter cream-filled roll","Red bean sogeum variant","Fresh batches announced on Instagram","Seongsu street eating at its finest"],"tips":"Follow their Instagram (@jaeyondo) for daily bake times. Eat warm — the butter is still liquid inside. Go early or check the bake schedule before making a detour.","hours":"10am – sell-out","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/자연도소금빵/"},

  {"id":"r-sofar","neighbourhood":"seongsu","cat":"cafe","name":"So Far Café (소파)","emoji":"☕","gradient":"linear-gradient(135deg,#3d2b1f,#c8963e)","region":"seoul1","cost":"₩6,000–10,000","costZAR":"≈ R65–108","duration":"1 hr","teaser":"A quiet, design-forward Seongsu specialty café — pour-overs and seasonal lattes in a warm concrete space.","desc":"So Far is a Seongsu specialty café with a calm, minimalist interior — warm concrete walls, beam ceilings, and a serious approach to single-origin coffee. The kind of place you come to read for two hours and refocus. Also does seasonal lattes and simple pastries.","highlights":["Single-origin pour-over","Seasonal specialty lattes","Minimalist concrete interiors","Seongsu creative neighbourhood vibe","Good for a quiet mid-morning reset"],"tips":"Best visited on a weekday morning when it's calm. Pairs well with the Seongsu gallery circuit and Neungdong Minari for lunch afterwards.","hours":"9am – 9pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/소파카페/"},

  {"id":"r-brewing-ceremony","neighbourhood":"seongsu","cat":"cafe","name":"Brewing Ceremony (브루잉 세레모니)","emoji":"☕","gradient":"linear-gradient(135deg,#2c1810,#967259)","region":"seoul1","cost":"₩7,000–12,000","costZAR":"≈ R76–130","duration":"1 hr","teaser":"A serious craft coffee destination with a ritual approach to brewing — one of Seongsu's finest.","desc":"Brewing Ceremony is a specialty coffee bar that treats each cup as a ceremony: manual brew methods, carefully sourced single-origin beans, and precise water temperature protocols. The space is calm and intentional — designed around the act of making and drinking coffee well. No rush energy.","highlights":["Ceremony pour-over (15–20 min brew time)","Aeropress + Chemex brewing options","Seasonal espresso menu","Simple pastry pairings","Unhurried, meditative atmosphere"],"tips":"Not for those who want a quick flat white — each manual brew takes 15+ minutes and that's the point. Go on a slow morning. The staff are knowledgeable and happy to explain the process in basic English.","hours":"10am – 8pm (closed some Mondays)","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/브루잉세레모니/"},

  {"id":"r-tokino","neighbourhood":"seongsu","cat":"cafe","name":"ToKiNo Seongsu (토키노)","emoji":"🍵","gradient":"linear-gradient(135deg,#1c3a2f,#5dade2)","region":"seoul1","cost":"₩7,000–13,000","costZAR":"≈ R76–140","duration":"1 hr","teaser":"A Japanese-style tea and coffee bar in Seongsu — matcha rituals and hojicha lattes in a zen industrial space.","desc":"ToKiNo takes its visual cues from Japanese tea culture: blackened wood, careful lighting, ceramic cups, and a menu built around matcha, hojicha, and ceremonial-grade teas alongside espresso. Located in Seongsu's converted-warehouse belt. A quiet counterpoint to the neighbourhood's louder coffee spots.","highlights":["Matcha latte with ceremonial-grade powder","Hojicha latte (roasted green tea)","Shakerato-style iced matcha","Japanese-influenced interiors","Quiet and unhurried"],"tips":"Go between 10am–noon on weekdays for maximum calm. The iced matcha shakerato is a particular standout in July heat.","hours":"10am – 9pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/토키노/"},

  {"id":"r-jinmi-sikdang","neighbourhood":"seongsu","cat":"seoul","name":"Jinmi Sikdang (진미식당)","emoji":"🍜","gradient":"linear-gradient(135deg,#0e6251,#a9dfbf)","region":"seoul1","cost":"₩8,000–15,000","costZAR":"≈ R86–162","duration":"45 min","teaser":"A beloved neighbourhood Korean diner — jjigae, bibimbap, and homestyle dosirak in a warm, unpretentious space.","desc":"Jinmi Sikdang is the definition of a good neighbourhood restaurant: daily specials, excellently seasoned kimchi jjigae, and rice bowls with proper banchan. Small, family-run, and zero frills. The kind of place a local would take you for a quick working lunch.","highlights":["Kimchi jjigae — often the daily special","Bibimbap with mountain vegetables","Sundubu jjigae (soft tofu stew)","Generous banchan","Reasonable prices, fast service"],"tips":"Order whatever the daily handwritten special is — that's what they've made most of that day. No reservations.","hours":"11am – 8pm (may close for breaks)","address":"Seoul (check Naver Maps for nearest branch)","interest":["foodie"],"diet":["pork","spicy"],"vegOk":true,"foodCat":"stews","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/진미식당/"},

  {"id":"r-cosymosy","neighbourhood":"seongsu","cat":"cafe","name":"Cosy Mosy (코지 모지)","emoji":"🌸","gradient":"linear-gradient(135deg,#f5c6cb,#c39bd3)","region":"seoul1","cost":"₩5,000–10,000","costZAR":"≈ R54–108","duration":"1 hr","teaser":"A light-filled plant-and-art café in Seongsu with homemade drinks and a small gifts section.","desc":"Cosy Mosy is a cheerful, warm neighbourhood café in Seongsu with a plant-filled interior, hand-illustrated cards and stationery for sale, and a menu of house-made lattes and light snacks. The kind of spot you stumble into and end up staying two hours.","highlights":["House specialty lattes","Seasonal fruit drinks","Illustrated art cards + small gifts","Plants everywhere","Quiet neighbourhood energy"],"tips":"Good for a mid-afternoon reset between Seongsu shops. The gift section makes it a convenient last-stop pick for small souvenirs.","hours":"11am – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/cosymosy/"},

  {"id":"r-camel-coffee","neighbourhood":"seochon","cat":"cafe","name":"Camel Coffee (카멜커피) — Dosan & Seochon","emoji":"🐪","gradient":"linear-gradient(135deg,#c8963e,#fff5e1)","region":"any","cost":"₩6,000–10,000","costZAR":"≈ R65–108","duration":"45 min","teaser":"Seoul's beloved specialty coffee chain with a flower blossom signature drink — must-visit in Seochon Village.","desc":"Camel Coffee is one of Seoul's most loved specialty café groups, known for a clean, warm aesthetic and excellent coffee. The Seochon Village branch is particularly beloved — a soft, calming space with natural wood and light, perfect before or after Gyeongbokgung. The \"flower blossom\" latte is their calling card.","highlights":["Flower blossom specialty latte (seasonal)","Single-origin pour-over","Iced cream latte","Warm natural wood interior","Seochon Village neighbourhood walk pairs perfectly"],"tips":"The Seochon branch (near Gyeongbokgung) is the most atmospheric. Combine with a hanbok morning and a walk through the old Seochon alleyways. The Dosan branch in Gangnam is also very good.","hours":"9am – 9pm daily","address":"Seochon Village + Dosan Park, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/camelcoffeekorea/"},

  {"id":"r-gangnam-myeonok","neighbourhood":"apgujeong","cat":"seoul","name":"Gangnam Myeonok (강남면옥)","emoji":"🍜","gradient":"linear-gradient(135deg,#1e3a2f,#58d68d)","region":"seoul2","cost":"₩11,000–16,000","costZAR":"≈ R120–175","duration":"45 min","teaser":"A highly-rated Gangnam naengmyeon specialist — cold buckwheat noodles in pristine iced broth.","desc":"Gangnam Myeonok is a clean, popular naengmyeon restaurant in the Gangnam area, known for a particularly pure and well-balanced mul naengmyeon (iced beef broth + buckwheat noodles). The restaurant has a calm, slightly upscale atmosphere with efficient service. Consistently ranked among Seoul's better cold-noodle destinations.","highlights":["Mul naengmyeon (물냉면) — iced broth, tangy","Bibim naengmyeon (비빔냉면) — spicy sauce","Mandu (steamed dumplings) as a side","Clean, slightly upscale setting","Great after the Samwon Garden area"],"tips":"Naengmyeon is the ideal post-BBQ dish — go here after Samwon Garden or another Apgujeong/Gangnam BBQ for the full experience. Use scissors provided at the table to cut the long noodles.","hours":"11am – 9:30pm (break ~3–5pm)","address":"Gangnam-gu, Seoul (near Apgujeong)","interest":["foodie"],"diet":["beef"],"vegOk":false,"wish":"noodles","foodCat":"stews","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/강남면옥/"},

  {"id":"r-hyodo-chicken","neighbourhood":"gangnam","cat":"seoul","name":"Hyodo Chicken (효도치킨 논현점)","emoji":"🍗","gradient":"linear-gradient(135deg,#2d5a1b,#a9dfbf)","region":"seoul2","cost":"₩21,000–24,000","costZAR":"≈ R227–260","duration":"1.5 hrs","teaser":"Founded by two Michelin-trained chefs — the fried chicken with anchovies and rice-syrup glaze that Reddit says is \"a cut above.\"","desc":"Hyodo Chicken was founded by two chefs with Michelin restaurant backgrounds who wanted to make the best fried chicken in Seoul. The result is a small shop in Nonhyeon with two signature styles: Basak (original crispy, juicy) and Asak (even crispier). The anchovy + rice-syrup glaze version is the standout — a salty-sweet combination that elevates the form. Seoul's Reddit food community consistently recommends it.","highlights":["Basak original (바삭) — crispy & juicy ₩21k","Asak (아삭) — ultra-crispy ₩21k","Anchovy + rice-syrup glaze version","Boneless option ₩24k","Two Michelin-restaurant-trained founders"],"tips":"Don't miss: order the variety with anchovy glaze if it's on the board. Arrives quickly and best eaten immediately — don't wait. The restaurant is small, so expect to wait or take away. Reddit says \"don't miss\" — trust the crowd.","hours":"11:30am – 9pm (closed Sundays)","address":"Nonhyeon-dong, Gangnam-gu, Seoul","interest":["foodie"],"diet":[],"vegOk":false,"wish":"chicken","foodCat":"street","indoor":true,"closedDay":0,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/효도치킨/"},

  {"id":"r-joes-garage","neighbourhood":"seongsu","cat":"cafe","name":"Joe's Garage (조스개러지)","emoji":"🔧","gradient":"linear-gradient(135deg,#3d2b1f,#e67e22)","region":"seoul1","cost":"₩7,000–15,000","costZAR":"≈ R76–162","duration":"1 hr","teaser":"A converted garage in Seongsu turned minimalist café and bookshop — the neighbourhood's coolest corner.","desc":"Joe's Garage occupies a converted mechanic's garage in Seongsu — concrete floors, industrial shelving, and a curated selection of design books alongside single-origin coffee and light food. The vibe is cool, unhurried, and very Seongsu. An excellent stop in the neighbourhood's gallery circuit.","highlights":["Specialty espresso bar","Design and art books to browse","Converted garage industrial aesthetic","Light brunch items","Great mid-afternoon reset point"],"tips":"Fits best as part of a longer Seongsu wander — start at Brewing Ceremony for coffee, lunch at Neungdong Minari, then browse Joe's Garage in the early afternoon.","hours":"10am – 9pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion","foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/조스개러지/"},

  {"id":"r-hangjungsun","neighbourhood":"seongsu","cat":"cafe","name":"Han Jung Sun Seongsu (한정선 성수점)","emoji":"🏺","gradient":"linear-gradient(135deg,#c8963e,#f5f0e8)","region":"seoul1","cost":"₩8,000–18,000","costZAR":"≈ R86–195","duration":"1 hr","teaser":"Traditional Korean medicinal herbal teas served in a beautiful hanok-inspired Seongsu space — with row upon row of white ceramic jars.","desc":"Han Jung Sun is an elegant Korean herbal tea and traditional confectionery brand. The Seongsu branch has a stunning interior of white ceramic jars on wooden shelving — one of the most photographed café interiors in the neighbourhood. The menu centres on traditional herbal teas (yuzu, citron, cinnamon, chrysanthemum), sikhye sweet rice punch, and traditional Korean sweets (hangwa).","highlights":["Citron (유자) and cinnamon (수정과) teas","Sikhye sweet rice punch","Hangwa traditional Korean sweets","Wall of white ceramic jars — iconic interior","Yuzu lemon ade served cold in summer"],"tips":"This is more a beautiful space for tea and photos than a destination coffee stop. Come for the interior and a slow, restorative 45 minutes between Seongsu café-hopping.","hours":"11am – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["culture","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/한정선/"},

  {"id":"r-secondaire","neighbourhood":"seongsu","cat":"bakery","name":"Secondaire (세콩데르)","emoji":"🍞","gradient":"linear-gradient(135deg,#f4a261,#e9c46a)","region":"seoul1","cost":"₩5,000–12,000","costZAR":"≈ R54–130","duration":"45 min","teaser":"A playful Seongsu bakery with colourful toast art and Korea-only cream flavours — Instagram gold.","desc":"Secondaire is a Seongsu concept bakery that turned thick-cut toast into an art form — enormous painted toast sculptures mark the entrance, and inside the menu offers elaborately cream-filled and glazed toast, brioches, and pastries. Colourful, fun, and proudly photogenic.","highlights":["Thick cream-toast (signature item)","Seasonal flavour rotations","Enormous painted toast display installation","Coffee pairings","The entrance toast sculpture alone is worth a photo"],"tips":"Come for the visual experience and a quick snack — one cream toast between two is plenty. The installation at the entrance is great for a photo even if you don't queue inside.","hours":"10am – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/secondaire/"},

  {"id":"r-noirmood","neighbourhood":"apgujeong","cat":"cafe","name":"Noir Mood (nm.) — Dosan","emoji":"🖤","gradient":"linear-gradient(135deg,#1c1c1c,#4a4a4a)","region":"seoul2","cost":"₩8,000–16,000","costZAR":"≈ R86–175","duration":"1 hr","teaser":"\"Inspired by cinema, furniture, and couture\" — a moodboard made physical in Apgujeong.","desc":"Noir Mood is a concept café in Dosan/Apgujeong that bills itself as inspired by cinema, furniture, and couture — and delivers. Dark, editorial interiors, carefully designed menus, and the kind of space that feels curated to the last detail. Open daily 12pm–9pm. For the design-inclined visitor.","highlights":["Dark editorial interior design","Specialty coffee + seasonal drinks","Cinema-inspired menu items","Couture-adjacent atmosphere","Dosan Park shopping circuit location"],"tips":"Worth a dedicated visit if you're doing the Dosan shopping circuit. Very photogenic even with a phone camera. Pair with Nudake and the Haus Dosan visit.","hours":"12pm – 9pm daily","address":"Dosan area, Apgujeong, Gangnam-gu, Seoul","interest":["fashion","foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://en.noirmood.com/?utm_source=ig&utm_medium=social&utm_content=link_in_bio","logo":"images/noirmood_logo.png"},

  {"id":"r-meita-wang","neighbourhood":"seongsu","cat":"bakery","name":"MeiTa Wang Egg Tart (메이타왕 에그타르트) — Sungsu","emoji":"🥚","gradient":"linear-gradient(135deg,#f5c518,#e08a00)","region":"seoul1","cost":"₩3,500–5,500","costZAR":"≈ R38–60","duration":"20 min","teaser":"8 years of perfecting a 120g premium egg tart — the flakiest pastry and vanilla-bean custard in Seongsu.","desc":"MeiTa Wang has spent 8 years developing what they describe as the definitive Korean premium egg tart: 120g of thick, flaky pastry made with top-grade French butter and 100% natural vanilla bean custard from local farms. The result is a richly golden, perfectly set custard tart with a shatteringly crisp base. Best served cold, though warm is equally excellent.","highlights":["120g size — substantial and filling","100% natural vanilla bean custard","French butter puff pastry base","Best cold — request from fridge","Local farm egg sourcing"],"tips":"Available at the Sungsu Store location. Buy two — one warm and one cold from the fridge to compare. The shop recommends cold for maximum custard set, but fresh-baked warm has its own appeal.","hours":"10am – 8pm (sell-out possible)","address":"Seongsu-dong (Sungsu Store), Seongdong-gu, Seoul","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/메이타왕/"},

  {"id":"r-pymt","neighbourhood":"gangnam","cat":"cafe","name":"PYMT Coffee (put your mind to)","emoji":"☕","gradient":"linear-gradient(135deg,#d4c9b0,#7f6e56)","region":"seoul2","cost":"₩5,500–11,000","costZAR":"≈ R60–120","duration":"1 hr","teaser":"A sleek Seoul specialty coffee bar focused on coffee bar, coffee bean education, and retail — one of Gangnam's better independents.","desc":"PYMT (Put Your Mind To) is a specialty coffee bar, coffee bean retail shop, and education space in one. The branding is clean and minimal, the beans are carefully sourced, and the approach is more serious than most of Gangnam's aesthetic-first cafés. A good stop for proper coffee before or after a Dosan or Apgujeong afternoon.","highlights":["Specialty espresso bar","Single-origin bean retail","Coffee education sessions (book ahead)","Clean minimal branding","Gangnam's better independent options"],"tips":"Buy a bag of beans as a gift if you find a roast you like — nice travel souvenir and the packaging is handsome.","hours":"10am – 9pm","address":"Gangnam-gu, Seoul","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://litt.ly/pymtcoffee?utm_source=ig&utm_medium=social&utm_content=link_in_bio","logo":"images/pymt_logo.png"},

  {"id":"r-sunday-burger","neighbourhood":"gangnam","cat":"seoul","name":"Sunday Burger Club","emoji":"🍔","gradient":"linear-gradient(135deg,#b03a2e,#f5b041)","region":"seoul2","cost":"₩13,000–20,000","costZAR":"≈ R140–215","duration":"45 min","teaser":"A popular Seoul smash-burger spot — double-smash patties, American cheese, and crispy edges done right.","desc":"Sunday Burger Club serves old-school smash burgers with double patties pressed hard on a flat-top, American cheese, house pickles, and a soft pillowy bun. No gimmicks. The kind of burger where the grease-soaked bun is part of the experience. A reliable indulgence when you need a Western break.","highlights":["Double smash patty (the move)","American cheese melt","House pickles + house sauce","Crinkle fries on the side","Quick service"],"tips":"Go for the double patty — the single feels incomplete. Best eaten immediately while the edges are still crisp. No need to book; quick turnover.","hours":"11:30am – 9pm","address":"Seoul (check Naver Maps for current location)","interest":["foodie"],"diet":["beef"],"vegOk":false,"indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/sundayburgerclub/","logo":"images/sunday_burger_logo.png"},

  {"id":"r-chizn-bingsu","neighbourhood":"seongsu","cat":"cafe","name":"CHIZN Bingsu Nightcap","emoji":"🍧","gradient":"linear-gradient(135deg,#2c3e7a,#6dd5fa)","region":"any","cost":"₩12,000–18,000","costZAR":"≈ R130–195","duration":"45 min","teaser":"A late-night bingsu bar — shaved ice desserts after midnight in a moody Seongsu or Hongdae setting.","desc":"CHIZN positions itself as a \"nightcap\" bingsu destination — a place for shaved ice and sweet drinks in the late evening when most dessert spots have closed. The menu focuses on elevated bingsu presentations with quality milk ice and seasonal toppings. A lovely way to end a long Seoul night.","highlights":["Late-night bingsu — open past midnight","Seasonal toppings (red bean, mango, injeolmi)","Moody lighting for evening dining","Coffee + dessert combos","A distinct alternative to the noraebang circuit"],"tips":"The late-night angle is the main reason to visit — most bingsu is a daytime affair. Perfect as a final stop after noraebang or dinner. Check Instagram for current hours.","hours":"Evening – late night (check Instagram)","address":"Seongsu / Hongdae, Seoul","interest":["foodie"],"diet":[],"vegOk":true,"wish":"bingsu","foodCat":"cafes","indoor":true,"mapLink":"https://m.place.naver.com/restaurant/2076342937/home?entry=pll&utm_source=ig&utm_medium=social&utm_content=link_in_bio","link":"https://www.instagram.com/explore/tags/chizn/","logo":"images/chizn_logo.png"},

  {"id":"r-milestone","neighbourhood":"seongsu","cat":"cafe","name":"Milestone Coffee","emoji":"☕","gradient":"linear-gradient(135deg,#1c1c2e,#c8963e)","region":"any","cost":"₩6,000–10,000","costZAR":"≈ R65–108","duration":"1 hr","teaser":"A benchmark Seoul specialty café known among baristas — consistently excellent espresso in a quiet space.","desc":"Milestone Coffee is well-regarded in Seoul's specialty coffee community for consistent quality and a serious approach to sourcing and extraction. Low-key interior, knowledgeable staff, and some of the more reliably excellent espresso in the city. A good go-to when you want great coffee without Instagram fuss.","highlights":["Consistently excellent espresso","Single-origin filter options","Knowledgeable staff","Quiet, low-key atmosphere","A barista's recommendation"],"tips":"Just order the espresso or flat white and trust the process. No need to overthink the menu.","hours":"9am – 8pm","address":"Seoul (check current location on Naver)","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/milestonecoffee/"},

  {"id": "r-parc-seoul", "neighbourhood": "gangnam", "cat": "cafe", "name": "Parc Seoul", "emoji": "🌿", "gradient": "linear-gradient(135deg,#2d5016,#85c1e9)", "region": "seoul2", "cost": "₩8,000–18,000", "costZAR": "≈ R86–195", "duration": "1.5 hrs", "teaser": "A light-drenched garden café and brunch spot in Gangnam — all-day menus in a lush botanical setting.", "desc": "Parc Seoul is a garden-themed café and brunch restaurant in the Gangnam area with a greenhouse-like interior full of plants, natural light, and a breezy atmosphere. The all-day menu covers Western-influenced brunch items alongside Korean coffee drinks and light mains. Very popular with the Gangnam brunch crowd.", "highlights": ["All-day brunch menu", "Greenhouse-style plant-filled interiors", "Western + Korean hybrid menu", "Excellent light for photos", "Popular with local creative professionals"], "tips": "Weekday mornings are the move — peaceful and uncrowded. The weekend brunch scene can see long waits. Book on Catch Table for weekends.", "hours": "10am – 9pm daily", "address": "Gangnam-gu, Seoul", "interest": ["foodie", "fashion"], "diet": [], "vegOk": true, "foodCat": "cafes", "indoor": true, "needsBooking": false, "mapLink": "https://naver.me/", "link": "https://www.instagram.com/explore/tags/parcseoul/", "logo": "https://logo.clearbit.com/parcseoul.com"},

  {"id":"r-gml","neighbourhood":"seongsu","cat":"cafe","name":"GML Coffee","emoji":"☕","gradient":"linear-gradient(135deg,#2c1810,#f0e0c8)","region":"seoul1","cost":"₩6,000–9,000","costZAR":"≈ R65–97","duration":"45 min","teaser":"A Seongsu micro-roastery café — small-batch roasting, clean interiors, and coffee taken seriously.","desc":"GML is a small Seongsu micro-roastery operating out of a compact, clean space. The focus is on small-batch roasting and precise brewing — the menu rotates based on what's in season and what's been roasted that week. The kind of café that rewards regulars but welcomes curious first-timers with gentle guidance.","highlights":["Small-batch micro-roastery","Weekly rotating single-origins","Compact and focused menu","Honest, knowledgeable service","Seongsu micro-café culture"],"tips":"Ask what roast they recommend for the week — the staff know the beans well. Great companion to a Seongsu morning before the streets get busy.","hours":"9am – 7pm (check Instagram for days)","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://blog.naver.com/dear_elena/224216295901","logo":"images/gml_logo.png"},

  {"id":"r-sounds-of-apple","neighbourhood":"seongsu","cat":"cafe","name":"Sounds of Apple (사운즈오브애플)","emoji":"🎵","gradient":"linear-gradient(135deg,#1c2833,#58d68d)","region":"any","cost":"₩7,000–13,000","costZAR":"≈ R76–140","duration":"1 hr","teaser":"A vinyl-listening café with high-end audio equipment and a carefully curated record collection in Seongsu.","desc":"Sounds of Apple is a music-first café where the whole point is listening: high-end turntables, amplifiers, and speakers create an audiophile listening environment around specialty coffee. Browse the record collection, request a play, or simply sit and let the sound fill the converted warehouse space. One of the more unique café experiences in Seoul.","highlights":["High-fidelity vinyl listening environment","Curated record collection to browse and request","Specialty coffee + simple drinks","Converted warehouse acoustic space","Unique — nowhere else quite like this in Seoul"],"tips":"Come ready to sit still and listen — this isn't a work-from-laptop spot. If you have a record you love, ask if they'll play it. The system is genuinely exceptional.","hours":"12pm – 9pm (check days open)","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["culture","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://m.place.naver.com/restaurant/1916933731/home","link":"https://www.instagram.com/explore/tags/soundsofapple/","logo":"images/sounds_of_apple_logo.png"},

  {"id":"r-reindeer","neighbourhood":"hongdae","cat":"cafe","name":"Reindeer Café","emoji":"🦌","gradient":"linear-gradient(135deg,#4a2c0a,#e8c97a)","region":"any","cost":"₩7,000–12,000","costZAR":"≈ R76–130","duration":"1 hr","teaser":"A warmly decorated Seongsu or Hongdae café with a distinctive seasonal identity and cosy interiors.","desc":"Reindeer is a warmly styled café known for a distinctive aesthetic and a menu of seasonal specialty drinks. The interiors are warm and inviting — the kind of place that becomes a neighbourhood regular-haunt. Simple menu done well with creative seasonal specials.","highlights":["Seasonal specialty lattes","Warm, inviting interiors","Creative drink specials","Neighbourhood regular energy","Good for a slow afternoon"],"tips":"Check their Instagram for current seasonal menu — the specials are often the best thing they make. Walk-in friendly.","hours":"11am – 9pm","address":"Seongsu / Hongdae area, Seoul","interest":["foodie","fashion"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/reindeer카페/"},

  // ── BUSAN RESTAURANTS (added from YouTube research, June 2026) ──

  {"id":"r-taeseongdang","neighbourhood":"choryang","cat":"busan","name":"Taeseongdang 1950 (태성당)","emoji":"🐦","gradient":"linear-gradient(135deg,#6a1b4d,#c07aa8)","region":"busan","cost":"₩2,000–5,000/item","costZAR":"≈ R22–54/item","duration":"30 min","teaser":"Busan's most legendary bakery since 1950 — pioneer of the pie manju (flaky red bean pastry) eaten by generations.","desc":"태성당 (Taeseongdang, 太星堂) opened in 1950, making it one of Korea's oldest surviving bakeries. The founding signature item — pie manju (파이만주) — is a flaky, multi-layered pastry shell filled with sweet, lightly sweet red bean paste. The bakery claims to be the first in Korea to develop this pastry style, now found nationwide. Also beloved for green onion bread (daepa-ppang), melon bread, cream bread, and salt bread. A must-visit on the way to or from Busan Station.","highlights":["Pie manju — flaky red bean pastry (the OG)","Daepa-ppang — green onion bread","Melon bread + salt bread","Beautiful vintage branding — great photos","Near Busan Station / Choryang Ibagu-gil"],"tips":"The Choryang main branch is a few minutes' walk from Busan Station Exit 1 or Choryang Station Exit 12. There's also a Busan Station branch for convenience. Boxes of pie manju travel well as gifts. Stock can sell out mid-afternoon — go in the morning.","hours":"9am – 9pm (approx; check @taesungdang on Instagram)","address":"3-5 Jungang-daero 296beon-gil, Dong-gu, Busan (near Choryang Station)","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/taesungdang_/"},

  {"id":"r-bonjeon-gukbap","neighbourhood":"choryang","cat":"busan","name":"Bonjeon Dwaeji Gukbap (본전돼지국밥)","emoji":"🍲","gradient":"linear-gradient(135deg,#5d4037,#f5cba7)","region":"busan","cost":"₩9,000–12,000","costZAR":"≈ R97–130","duration":"45 min","teaser":"Classic pork rice soup near Busan Station — the perfect first or last bowl of the trip.","desc":"Dwaeji gukbap (돼지국밥) is Busan's iconic comfort food: a creamy, milky pork bone broth poured over a bowl of rice, loaded with soft braised pork slices and green onion. Bonjeon near Busan Station is one of the most consistently recommended spots by both locals and travellers. Simple, filling, deeply flavoured — best customised with fermented salted shrimp (새우젓), pickled chives (부추무침), and a spoonful of doenjang paste.","highlights":["Milky pork bone broth — 'suyuk-style' clean taste","Customise with shrimp paste + pickled chives at the table","Side of sundae (blood sausage) optional","5 min walk from Busan Station","Open for breakfast — great arrival or departure meal"],"tips":"Order plain gukbap and season yourself at the table — this is how locals do it. A full set with sundae is around ₩15,000. Seats fill quickly at peak times; a short queue is normal. Cheap, fast, and deeply satisfying.","hours":"6am – 9pm (some branches 24hr)","address":"Choryang-dong, Dong-gu, Busan (near Busan Station)","interest":["foodie"],"diet":["pork"],"vegOk":false,"foodCat":"soups","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/돼지국밥/"},

  {"id":"r-halmae-gaya-milmyeon","neighbourhood":"seomyeon","cat":"busan","name":"Halmae Gaya Milmyeon (할매가야밀면)","emoji":"🍜","gradient":"linear-gradient(135deg,#0d3349,#1f618d)","region":"busan","cost":"₩9,000–12,000","costZAR":"≈ R97–130","duration":"45 min","teaser":"The historic home of milmyeon — Busan's signature cold wheat noodles born from Korean War necessity.","desc":"Milmyeon (밀면) is Busan's signature cold noodle dish, created by war refugees who couldn't get buckwheat so used wheat flour instead. The noodles are chewy, served cold in a tangy, savoury beef-bone broth (물밀면) or tossed dry in spicy bibim sauce (비빔밀면). Halmae Gaya is considered the historic institution for this dish — a multi-decade family restaurant in the Seomyeon area. Don't miss the complementary warm beef broth kettle that comes with the table.","highlights":["Mul-milmyeon — cold broth style (the classic)","Bibim-milmyeon — spicy dry toss version","Steamed mandu dumplings on the side","Free warm beef broth kettle on the table","Landmark Busan food institution"],"tips":"If you've had naengmyeon in Seoul, milmyeon is the Busan cousin — chewier noodles, slightly different broth character. The bibim version is significantly spicier. Very reasonable prices for the quality. Queue at lunch — 20–30 min wait is normal.","hours":"11am – 9pm (closed some Mondays)","address":"Seomyeon area, Busanjin-gu, Busan","interest":["foodie"],"diet":[],"vegOk":false,"foodCat":"noodles","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/밀면/"},

  {"id":"r-samjin-eomuk","neighbourhood":"choryang","cat":"busan","name":"Samjin Eomuk (삼진어묵)","emoji":"🐟","gradient":"linear-gradient(135deg,#1a5276,#76d7c4)","region":"busan","cost":"₩1,200–5,500/piece","costZAR":"≈ R13–59/piece","duration":"20 min","teaser":"Korea's oldest fish cake brand (est. 1953) — an upscale bakery of handmade gourmet eomuk to eat and gift.","desc":"삼진어묵 (Samjin Eomuk, est. 1953) started as a simple Busan fish cake stall and is now an institution. The shop looks like a high-end bakery but everything on display is freshly made fish cake: shrimp-filled croquettes, cheese-stuffed rolls, curry-flavoured rounds, plain skewers in hot broth, and premium gift-box sets. Korea's cleanest, most elevated take on a street food staple.","highlights":["Shrimp croquette eomuk — standout item","Cheese-stuffed fish cake rolls","Skewers served in warm anchovy broth","Premium gift boxes — great souvenirs","Flagship near Busan Station"],"tips":"Buy a few individual pieces to eat immediately (keep the broth skewer!) plus a gift box to take home. The Busan Station branch is most convenient. Visit in the morning when items are freshest baked.","hours":"9am – 9pm","address":"Multiple locations; flagship near Yeongdo (Yeongdo-gu); Busan Station branch in Dong-gu","interest":["foodie"],"diet":["seafood"],"vegOk":false,"foodCat":"street","indoor":true,"mapLink":"https://naver.me/","link":"https://samjineomuk.com"},

  {"id":"r-dongnae-pajeon","neighbourhood":"dongnae","cat":"busan","name":"Dongnae Halmae Pajeon (동래할매파전)","emoji":"🥞","gradient":"linear-gradient(135deg,#1e8449,#f9e79f)","region":"busan","cost":"₩28,000–40,000 (per pancake)","costZAR":"≈ R302–432","duration":"1.5 hrs","teaser":"The gold standard for Dongnae-style pajeon — a thick, traditional green onion and seafood pancake served with makgeolli.","desc":"Dongnae-style pajeon (동래파전) is the premium version of the Korean savory pancake: thick, fluffy, packed with spring onion and fresh seafood (oyster, clam, shrimp), and served with a unique vinegar-chili dipping sauce. This family-run institution in the Dongnae area is considered the definitive version in all of Korea. Sit-down dining, order one pancake per 1–2 people, pair with a carafe of makgeolli rice wine.","highlights":["Dongnae-style pajeon — OG version","Fresh seafood filling: oysters, clams, shrimp","Unique vinegar-pepper dipping sauce","Traditional sit-down experience","Best paired with makgeolli rice wine"],"tips":"This is worth the journey to Dongnae-gu — take the subway (Line 1 to Dongnae Station). A pancake serves 1–2 people as a main course; pair with steamed whelk (소라찜). Allow 1.5 hrs. More expensive than street pajeon but incomparably better quality.","hours":"11am – 9pm (closed Mondays)","address":"Dongnae-gu, Busan (near Dongnae Station, Metro Line 1)","interest":["foodie"],"diet":["seafood"],"vegOk":false,"foodCat":"traditional","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/동래파전/"},

  {"id":"r-millak-hoe","neighbourhood":"gwangalli","cat":"busan","name":"Millak Raw Fish Town (민락회타운)","emoji":"🐠","gradient":"linear-gradient(135deg,#1a3a5a,#aed6f1)","region":"busan","cost":"₩25,000–50,000 (fish + table fee)","costZAR":"≈ R270–540","duration":"2 hrs","teaser":"Choose live fish from tank vendors on the 1st floor, then take it upstairs to be sliced fresh as hoe (sashimi) with a view of Gwangalli Beach.","desc":"민락회타운 is a multi-floor complex right next to Gwangalli Beach where the ground floor is lined with tanks of live fish and seafood. Pick your flatfish (광어), sea bream (도미), octopus (문어), or whatever's fresh, pay by weight, and the vendor preps and bags it. Take it to any of the 2nd/3rd floor restaurants who set up the banchan, dipping sauces, and serve it as hoe (회 / Korean-style raw fish). Views of Gwangan Bridge from the restaurant floors.","highlights":["Live flatfish (광어) — #1 choice","Sea bream (도미) and sea bass (농어)","2F restaurants add banchan + maeuntang fish stew","Overlooking Gwangan Bridge","Combine with evening Gwangalli beach walk"],"tips":"Fish prices are per 100g — agree on total before they start cutting. Table service fee of ~₩5,000/person is added at the restaurant. Order a maeuntang (spicy fish stew) from the leftover bones — it's often the best part.","hours":"Ground floor: 10am – 10pm. Restaurants: 11am – 11pm","address":"Gwangan-dong, Suyeong-gu, Busan (next to Gwangalli Beach)","interest":["foodie"],"diet":["seafood"],"vegOk":false,"foodCat":"seafood","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/민락회타운/"},

  {"id":"r-handasot","neighbourhood":"gwangalli","cat":"busan","name":"Handasot (한다솥) — Stone Pot Rice","emoji":"🍚","gradient":"linear-gradient(135deg,#2e4057,#c8963e)","region":"busan","cost":"₩25,000–45,000","costZAR":"≈ R270–486","duration":"1.5 hrs","teaser":"Premium stone pot rice (sotbap) with snow crab, abalone, or short ribs — cooked at 500°C and served with a full spread.","desc":"한다솥 is Busan's most celebrated premium sotbap (솥밥) restaurant — individual portions of high-quality rice cooked in volcanic stone pots at extreme temperatures, then served with your choice of topping: fresh snow crab, live abalone, dry-aged short ribs, or seasonal mushrooms. Each bowl arrives with an array of banchan (side dishes), grilled fish, and a claypot soup. A proper sit-down meal for when you want to eat well.","highlights":["Snow crab sotbap — the signature","Abalone sotbap — luxurious option","Dry-aged short rib version","Full banchan spread + grilled fish","Views from Gwangalli location"],"tips":"Weekend queues can be 1+ hour — use the digital waitlist (Naver Waiting). The Gwangalli branch has the best atmosphere. Budget for a premium meal — this is one of the more expensive Busan restaurants but worth it for a special night.","hours":"11:30am – 3pm, 5pm – 9:30pm","address":"Gwangan-dong, Suyeong-gu, Busan (near Gwangalli Beach)","interest":["foodie"],"diet":["seafood"],"vegOk":false,"foodCat":"traditional","indoor":true,"needsBooking":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/한다솥/"},

  {"id":"r-jayeondo-saltbread","neighbourhood":"haeundae-mipo","cat":"busan","name":"Jayeondo Salt Bread (자연도 소금빵)","emoji":"🥖","gradient":"linear-gradient(135deg,#c8963e,#f9e79f)","region":"busan","cost":"₩12,000 for 4 pieces","costZAR":"≈ R130","duration":"20 min","teaser":"Korea's most viral salt bread — sold in sets of 4, baked in batches, and best eaten immediately warm from the oven.","desc":"자연도 소금빵 is one of Korea's most celebrated salt bread (소금빵) bakeries — the Haeundae/Mipo location is beloved for perfectly crispy, buttery-and-soft rolls with ideal salt balance. Salt bread is everywhere in Korea but Jayeondo's is exceptional: the crunch-to-fluff ratio, the butter layering, the precise salting. Sold in minimum sets of 4 pieces only; no single-item purchases. Batches are baked throughout the day.","highlights":["Crispy outside — buttery, airy inside","Perfect salt balance (not too salty)","Sold in sets of 4 only","Baked in batches — best eaten hot","Mipo location is near Blueline Park"],"tips":"Check the batch schedule at the counter and wait for fresh-from-oven — it transforms the experience. The Mipo/Haeundae branch is close to the Blueline Park start point. Buy a set before boarding the Sky Capsule.","hours":"9am – 8pm (or until sold out)","address":"Mipo, Haeundae-gu, Busan","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/jayeondo_original/"},

  {"id":"r-ops-bakery","neighbourhood":"haeundae","cat":"busan","name":"OPS Bakery (옵스 베이커리)","emoji":"🧁","gradient":"linear-gradient(135deg,#7d6608,#f9e79f)","region":"busan","cost":"₩3,000–8,000/item","costZAR":"≈ R32–86/item","duration":"30 min","teaser":"One of Busan's top 3 bakeries — famous for giant custard cream puffs and the moist castella-style Hagwonjeon cake.","desc":"OPS (옵스) is part of Busan's 'top 3 bakeries' alongside Taeseongdang and Samjin. The Haeundae branch is the most visited. Key items: the oversized Chou Cream (슈크림) custard puff — a big, wobbly puff pastry shell with smooth vanilla custard; and Hagwonjeon (학원전), a soft, moist castella-style loaf that's extremely popular as a gift. European-style pastries with Korean quality sensibilities.","highlights":["Chou Cream — giant custard puff (the icon)","Hagwonjeon castella loaf","Gift box sets for souvenirs","European-style pastry quality","Near Haeundae Beach"],"tips":"Buy individually to taste, then get a gift box of Hagwonjeon for home. The Haeundae location is the most accessible; best combined with a Haeundae Beach morning walk. Popular so arrive early or expect a short wait.","hours":"8am – 9pm","address":"Haeundae-gu, Busan","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"cafes","indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/옵스베이커리/"},

  {"id":"r-biff-square-street","neighbourhood":"nampo","cat":"busan","name":"BIFF Square Street Food (비프광장)","emoji":"🥞","gradient":"linear-gradient(135deg,#b03a2e,#f0b27a)","region":"busan","cost":"₩2,000–5,000/item","costZAR":"≈ R22–54/item","duration":"1 hr","teaser":"Busan's most iconic street food square — home of ssiat hotteok, eomuk broth, and all the classic stall foods.","desc":"BIFF Square (부산국제영화제 광장) is named after the Busan International Film Festival. It's a pedestrianised square in Nampo-dong lined with the handprints of film stars and — more importantly for food lovers — a dense cluster of classic street food stalls. The undisputed star is 씨앗호떡 (ssiat hotteok): a chewy fried pancake filled with a mix of sunflower seeds, pumpkin seeds, peanuts, and brown sugar that caramelises on the griddle. Also find eomuk (fish cakes on skewers in broth), tteokbokki, gimbap, and fried snacks.","highlights":["Ssiat hotteok — Busan's signature street pancake","Eomuk skewers in hot anchovy broth","Adjacent to Jagalchi Fish Market","Film star handprint tiles on the pavement","Connects to Gukje Market and Nampo-dong shopping"],"tips":"Ssiat hotteok is best eaten hot — the seeds and sugar are still slightly crunchy and the centre is warm and chewy. Budget ₩2,000 per piece. The square is very walkable with Jagalchi (5 min) and Gukje Market (3 min) — plan a Nampo-dong afternoon hitting all three.","hours":"10am – 10pm (street stalls)","address":"Nampo-dong, Jung-gu, Busan","interest":["foodie"],"diet":[],"vegOk":true,"foodCat":"street","indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/비프광장/"}
];

const TD_ACTIVITIES = [
  {"id":"a-hanbok","neighbourhood":"insadong","cat":"culture","name":"Hanbok Day at Gyeongbokgung Palace","emoji":"👘","gradient":"linear-gradient(135deg,#8e44ad,#e74c3c)","region":"seoul1","cost":"₩15,000–30,000","costZAR":"≈ R162–324","duration":"3–4 hrs","teaser":"Rent traditional Joseon-era dress, get free palace entry, and watch the Royal Guard Ceremony.","desc":"Rent a hanbok (traditional Korean dress) for 4 hours from shops just outside Gyeongbokgung's main gate. Wearing hanbok gives you free entry to the palace, and hundreds of others will be doing the same — it's a joyful, photogenic experience. The Changing of the Royal Guard ceremony happens at 10:00am and 2:00pm (not Tuesdays) at Gwanghwamun Gate.","highlights":["Hanbok rental: ₩15k (simple) – ₩30k (premium, incl accessories)","Free palace entry in hanbok","Royal Guard Ceremony: 10am & 2pm","Gyeonghoeru pavilion pond — iconic photo spot","National Folk Museum inside — free"],"tips":"Book hanbok rental in advance on weekends (April–October). Arrive by 9:30am to be dressed in time for the 10am ceremony. The palace is closed Tuesdays. Wear comfortable shoes — lots of walking on paving stones.","hours":"Palace open 9am – 6pm (closed Tue). Guard ceremony 10am & 2pm","address":"Gyeongbokgung Palace, Jongno-gu, Seoul","onItinerary":true,"needsBooking":false,"mapLink":"https://royal.khs.go.kr/gbg","link":"https://www.instagram.com/explore/tags/gyeongbokgunghanbok/","interest":["culture","fashion"],"indoor":false,"closedDay":2},

  {"id":"a-secretgarden","neighbourhood":"insadong","cat":"culture","name":"Changdeokgung Secret Garden Tour","emoji":"🌿","gradient":"linear-gradient(135deg,#27ae60,#1abc9c)","region":"seoul1","cost":"₩8,000","costZAR":"≈ R86","duration":"2 hrs","teaser":"The Joseon royal family's private garden — ancient trees, hidden ponds, and wooden pavilions.","desc":"Changdeokgung Palace's \"Huwon\" (Secret Garden) is a 78-acre royal garden concealed behind the palace, only accessible by guided tour. Ancient trees (some 300+ years old), lotus ponds, curved pavilions, and almost complete silence — a world away from the city. English tours are limited and sell out 4–6 days ahead.","highlights":["Juhamnu Pavilion over a lotus pond","300-year-old ancient trees","Ongnyucheon stream & rock carvings","Buyongji pond reflection — iconic","Limited English tours: 10:30am, 2:30pm"],"tips":"English tour slots open 4–6 days ahead and sell out immediately. Set a phone reminder for June 24 to book the June 30 slot (your planned day). Book at the Changdeokgung official booking page or at the gate on the day for Korean tours. Palace is closed Mondays.","hours":"Tours 10:30am & 2:30pm (English, 2hrs). Closed Mon","address":"Changdeokgung Palace, Jongno-gu, Seoul","onItinerary":true,"needsBooking":true,"mapLink":"https://royal.khs.go.kr/cdg","link":"https://royal.khs.go.kr/cdg","interest":["culture"],"indoor":false,"closedDay":1},

  {"id":"a-nseoultower","neighbourhood":"itaewon","cat":"culture","name":"N Seoul Tower + Namsan Cable Car","emoji":"🗼","gradient":"linear-gradient(135deg,#2c3e50,#4a6b53)","region":"seoul1","cost":"Cable ₩15,000 RT + Deck ₩21,000","costZAR":"≈ R162 cable + R227 deck","duration":"2–3 hrs","teaser":"Panoramic sunset views over the entire city from Namsan Mountain — cable car or hike up.","desc":"N Seoul Tower sits on Namsan Mountain at 479m elevation, offering 360° views of Seoul's entire skyline. Ride the cable car up (15 min, stunning views) or hike the trail (45 min, pleasant through forest). The tower observation deck is optional — the plaza and surrounding area are free and have incredible views, plus the famous love-lock fence.","highlights":["Cable car RT: ₩15k (Namsan Cable Car)","Observation deck: ₩21k","Love padlock fence — bring a small lock!","Best at sunset: 6pm in late June","N Grill restaurant at the top (pricey but views)"],"tips":"The cable car queues at weekends can be 45+ minutes. Hike up via the Namsan trail instead — it's beautiful and takes 40 minutes from Myeongdong. The plaza area (free) has just as good views as the inside deck. Go at sunset (around 7:30pm in late June/July).","hours":"Tower: 10am – 11pm. Cable car: 10am – 11pm (last ascent 10:15pm)","address":"Namsan Mountain, Yongsan-gu, Seoul","onItinerary":true,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/nseoultower/","interest":["culture","thrills"],"indoor":false},

  {"id":"a-hanriver","neighbourhood":"mapo","cat":"family-fun","name":"Han River Picnic & Paddleboard (Yeouido)","emoji":"🛶","gradient":"linear-gradient(135deg,#2980b9,#27ae60)","region":"seoul1","cost":"Picnic ₩15k + SUP ₩30k/hr","costZAR":"≈ R162 + R324/hr","duration":"Evening","teaser":"Order fried chicken delivery to the park, rent a paddleboard, and watch the Seoul skyline light up.","desc":"Yeouido Hangang Park is one of Seoul's great outdoor experiences. Rent a picnic mat (₩5k), order fried chicken delivery directly to the park (Baemin app), and watch the sunset over the Han River. Kayak and paddleboard rentals are available at the water sports centre. Evening is magical when the city lights reflect on the water.","highlights":["Picnic mat rental from park kiosk — ₩5k","Fried chicken delivery to the park (Baemin)","SUP/Kayak rental — ₩20-30k/hr","Han River Moonlight Night Market (Fri–Sun evenings)","Yeouido full moon festival (seasonal)"],"tips":"The Baemin (배달의민족) app works at the park — search \"한강 배달\" for Han River delivery options. Chicken and pizza both deliver directly to GPS location. SUP rentals are on the east side of the park. Night is more dramatic than day.","hours":"Park: 24/7. Water sports: 10am – 8pm","address":"Yeouido Hangang Park, Yeongdeungpo-gu","onItinerary":true,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/yeouidohangangpark/","interest":["foodie","thrills"],"indoor":false},

  {"id":"a-noraebang","neighbourhood":"hongdae","cat":"family-fun","name":"Noraebang — Private Karaoke Room","emoji":"🎤","gradient":"linear-gradient(135deg,#e91e63,#8e44ad)","region":"any","cost":"₩20,000–30,000/hr per room","costZAR":"≈ R215–324/hr","duration":"1–2 hrs","teaser":"Rent a private singing room with tambourines, light shows, and a digital scoring system.","desc":"Noraebang (노래방) is private-room karaoke — not the stage-in-front-of-strangers kind. You rent a room for your group (capacity usually 4–15 people) with a massive digital songbook (English songs included), tambourines, maracas, and a mic stand. The room has its own sound system and disco lighting. An absolute must for family evenings.","highlights":["Private rooms for just your group","Huge English song catalogue","Tambourines included — mandatory","Score system with applause at the end","Coin-operated time extensions"],"tips":"TJ Noraebang, Su Noraebang, and Luxury Su are popular chains. Most are open till 5–6am. Add coin-time extensions at the machine in the room (₩1,000 = 10min extra). Order drinks to the room. Song search in Korean or English — just type the artist name.","hours":"Noon – 5am (most locations)","address":"Hongdae, Sinchon, Myeongdong, everywhere","onItinerary":true,"needsBooking":false,"mapLink":"","link":"https://www.instagram.com/explore/tags/노래방/","interest":["thrills"],"indoor":true},

  {"id":"a-hongdaebusking","neighbourhood":"hongdae","cat":"shows","name":"Hongdae Street Busking Walk","emoji":"🎸","gradient":"linear-gradient(135deg,#f39c12,#e74c3c)","region":"seoul1","cost":"Free","costZAR":"Free","duration":"1–2 hrs","teaser":"Seoul's most electric street — live bands, dance battles, and fire performers every evening.","desc":"Hongdae (弘大) is built around Hongik University and has been the creative pulse of Seoul for decades. Every Friday and Saturday evening, the pedestrian streets fill with musicians, idol-style dance groups, magicians, and fire performers. The energy is electric. Combine with food stalls and window-shopping along the alleys.","highlights":["K-pop dance groups performing (Fri–Sat evenings)","Live bands at every corner","Juggling and fire performance artists","Street art installations","Night food markets starting 6pm"],"tips":"The best busking clusters around the Hongik University (홍대입구) subway exit 9 area and toward Sangsu-dong. Come between 7pm–10pm on Friday or Saturday for peak energy. Also great on weekday evenings but less crowded.","hours":"Evening: 6pm – 11pm. Busking peaks Fri–Sat","address":"Hongdae area, Mapo-gu (near Hongik University station)","onItinerary":false,"needsBooking":false,"mapLink":"","link":"https://www.instagram.com/explore/tags/홍대버스킹/","interest":["thrills","fashion"],"indoor":false},

  {"id":"a-trickeye","neighbourhood":"hongdae","cat":"family-fun","name":"Trick Eye Museum (Hongdae)","emoji":"🎭","gradient":"linear-gradient(135deg,#e74c3c,#f39c12)","region":"seoul1","cost":"₩12,000–17,000","costZAR":"≈ R130–184","duration":"1.5 hrs","teaser":"Optical illusion art you can interact with — download their AR app for the full magic.","desc":"An interactive gallery of 3D optical illusion paintings and installations. Standing in the right spot makes it look like you're flying over a city, surfing a wave, or being attacked by a giant monster. The AR app (free download) brings some paintings to life as animations through your phone camera. Big hit with all ages.","highlights":["2D paintings that become 3D in photos","AR app — animations through phone camera","Themed zones: fantasy, underwater, horror","Giant Mona Lisa walk-in installation","Love Museum also in the complex"],"tips":"Come on weekdays for smaller crowds and better photos. The AR app is iOS and Android — download before you arrive. The photo ops are genuinely creative and take about 2 minutes per painting to set up correctly. Combine with dinner in Hongdae.","hours":"10am – 9pm daily","address":"Hongdae, Mapo-gu, Seoul","onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/trickeyemuseum/","interest":["thrills"],"indoor":true},

  {"id":"a-photobooth","neighbourhood":"hongdae","cat":"hands-on","name":"4-Cut Photo Booths (Life4Cut / Photoism)","emoji":"📸","gradient":"linear-gradient(135deg,#e91e63,#f48fb1)","region":"any","cost":"₩4,000–5,000 per strip","costZAR":"≈ R43–54","duration":"15 min","teaser":"Korea's self-serve photo studios — props, custom backgrounds, and iconic 4-panel strips to keep.","desc":"Photo booths (인생네컷 / Life4Cut, Photoism) are self-operated mini studios where you choose a themed background, wear props (crowns, glasses, fan headbands), and snap 4 photos that print out as a strip. Very quick, very cheap, very Korean. You get a physical strip to keep plus a digital download. Found everywhere from convenience store strips to dedicated studios.","highlights":["Life4Cut (인생네컷) — most branches","Photoism — higher quality, more filters","Donggam — outdoor/nature themes","Wear props and choose your own backgrounds","Digital copy + physical strip"],"tips":"Go before or after Noraebang — they're usually on the same block in Hongdae and Myeongdong. Some booths have English interfaces. The print quality has improved dramatically — these are proper keepsake photos. Budget 15 minutes per visit.","hours":"10am – 11pm (most locations)","address":"Hongdae, Myeongdong, Insadong, everywhere","onItinerary":false,"needsBooking":false,"mapLink":"","link":"https://www.instagram.com/explore/tags/인생네컷/","interest":["fashion","thrills"],"indoor":true},

  {"id":"a-jjimjilbang","neighbourhood":"hongdae","cat":"hands-on","name":"Jjimjilbang (찜질방) — Korean Bathhouse","emoji":"🧖","gradient":"linear-gradient(135deg,#6d4c41,#8d6e63)","region":"any","cost":"₩12,000–20,000","costZAR":"≈ R130–216","duration":"2–5 hrs","teaser":"A 24-hour Korean bathhouse and sauna complex — the ultimate recovery day activity.","desc":"Jjimjilbang are Korean public bathhouses and saunas that operate around the clock. The communal sauna rooms are gender-mixed (you wear a provided cotton uniform). The bathing pools (gender-separated) have hot, cold, and herbal baths. Famous extras: the iconic round gejang eggs (cooked by the steam), sikhye sweet rice drink, and sleeping rooms for overnight stays.","highlights":["Multiple heated sauna rooms","Cold plunge + hot spring baths","Gejang eggs cooked in steam rooms (₩1k ea)","Sikhye sweet rice punch (무료 sometimes)","\"Dragon\" and \"ice\" rooms are extremes"],"tips":"Spa Lei in Hongdae, Dragon Hill Spa in Yongsan, and Jimjilbang 24 in Myeongdong are popular tourist-friendly spots with English signage. Bring nothing — towels, uniforms, and basics are provided. Shampoo and soap are usually free.","hours":"24/7 (some close 6–8am for cleaning)","address":"Hongdae (Spa Lei), Yongsan (Dragon Hill Spa)","onItinerary":false,"needsBooking":false,"mapLink":"","link":"https://www.instagram.com/explore/tags/찜질방/","interest":["culture","fashion"],"indoor":true},

  {"id":"a-personalcolor","neighbourhood":"hongdae","cat":"hands-on","name":"Personal Color Analysis Consultation","emoji":"🎨","gradient":"linear-gradient(135deg,#b04a8a,#e74c3c)","region":"any","cost":"₩80,000–150,000","costZAR":"≈ R865–1,622","duration":"90 min","teaser":"Discover your exact color season with a professional Korean stylist — a Seongsu or Hongdae staple.","desc":"Personal color analysis (퍼스널컬러) uses colored fabric drapes under natural light to identify your \"season\" (Spring Warm, Summer Cool, Autumn Warm, Winter Cool) and the palette of colors that makes your skin glow vs. look washed out. Hugely popular in Korean beauty culture. English-language studios in Seongsu-dong and Hongdae.","highlights":["4-season color classification","Draped fabric test under natural light","Makeup color recommendations","Skin undertone analysis (warm/cool/neutral)","Hair color suggestions"],"tips":"Book at least 2 weeks in advance — English-speaking studios fill up fast. \"Hello Mirror\" and \"Color Studio\" in Seongsu-dong have English services. Budget 1.5hrs for the session. Great for shopping guidance the rest of the trip.","hours":"By appointment","address":"Seongsu-dong & Hongdae, Seoul","onItinerary":true,"needsBooking":true,"mapLink":"","link":"https://www.instagram.com/explore/tags/퍼스널컬러/","interest":["fashion"],"indoor":true,"expensive":true},

  {"id":"a-nanta","neighbourhood":"myeongdong","cat":"shows","name":"NANTA (난타) — Kitchen Comedy Show","emoji":"🥁","gradient":"linear-gradient(135deg,#e74c3c,#c0392b)","region":"any","cost":"₩35,000–56,000","costZAR":"≈ R378–605","duration":"100 min","teaser":"A globally acclaimed non-verbal comedy show combining kitchen utensils with Samulnori drumming.","desc":"NANTA has been running in Seoul since 1997 and has been performed in 47 countries. Four chefs prepare a wedding banquet using everything in the kitchen as percussion instruments — knives, chopping boards, pots, water cups. No Korean language needed — it's 100% physical comedy and music. Audience participation sections are riotous.","highlights":["100% non-verbal — no language barrier","Audience participation sections","Traditional Samulnori drumming influences","Insadong and Myeongdong theatre locations","Children 4+ welcome"],"tips":"Book at least 2–3 days in advance on Interpark or directly on nanta.co.kr. The Myeongdong Theatre (right near your Seoul base area) is the most convenient. Front-row seats get audience participation action.","hours":"Various showtimes — check website","address":"Myeongdong Theatre or Insadong Theatre","onItinerary":false,"needsBooking":true,"mapLink":"https://www.nanta.co.kr/en/","link":"https://www.nanta.co.kr/en/","interest":["thrills","culture"],"indoor":true},

  {"id":"a-diamond","neighbourhood":"busan-haeundae","cat":"family-fun","name":"Diamond Bay Sunset Yacht Cruise","emoji":"⛵","gradient":"linear-gradient(135deg,#1a3a5a,#2980b9)","region":"busan","cost":"₩30,000–50,000","costZAR":"≈ R324–540","duration":"1.5 hrs","teaser":"A sunset yacht cruise around Gwangalli Bay with views of the illuminated Gwangan Bridge.","desc":"Diamond Bay operates yacht and cruise boat tours from the marina near your Bonathree Hotel. The signature route is the Gwangalli sunset cruise — depart around 5–6pm and watch the city skyline glow as Gwangan Bridge lights up at dusk. Available in various sizes from private yacht to small group tour vessels.","highlights":["Gwangan Bridge (광안대교) lit up at night","Haeundae Beach coastal views","Oryukdo Islets in the distance","Sunset on the open sea","Private yacht available for small groups"],"tips":"Book 2–3 days ahead once the weather forecast is confirmed (July can have rain and choppy seas). The marina is literally walking distance from the Bonathree Hotel. Sunset times in early July are around 7:30–8pm.","hours":"Tours depart 4pm–8pm","address":"Diamond Bay Marina, Nam-gu, Busan (near hotel)","onItinerary":true,"needsBooking":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/diamondbaybusan/","interest":["thrills"],"indoor":false,"expensive":true},

  {"id":"a-gamcheon","neighbourhood":"busan-gamcheon","cat":"culture","name":"Gamcheon Culture Village (감천문화마을)","emoji":"🎨","gradient":"linear-gradient(135deg,#e74c3c,#f39c12)","region":"busan","cost":"Free (stamp map ₩2k optional)","costZAR":"≈ Free","duration":"2 hrs","teaser":"Busan's \"Machu Picchu\" — a terraced hillside village of pastel houses, murals, and the Little Prince.","desc":"A refugee settlement from the 1950s Korean War, Gamcheon was transformed into a stunning open-air art gallery. Narrow alleyways wind between colourful pastel houses, with murals, sculptures, and art installations at every turn. The Little Prince and the Fox statue is the most famous photo spot. The overview viewpoint reveals the full terraced mosaic of rooftops.","highlights":["Little Prince & Fox statue (main photo spot)","Viewpoint over the full village","Stamp rally map (₩2k at the info centre)","Numerous small café and art shop stops","Goguma (sweet potato) snacks from stalls"],"tips":"Come before 11am or after 3pm to avoid peak tourist heat. The stamp map from the info centre (at the bus stop entrance) guides you to hidden corners. Wear comfortable shoes — the alleys are steep. Take bus 2 from Busan station or Gamcheon Culture Village shuttle.","hours":"Free entry 24/7. Info centre: 9am – 6pm","address":"Gamcheon-dong, Saha-gu, Busan","onItinerary":true,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/gamcheonculturevillage/","interest":["culture","fashion"],"indoor":false},

  {"id":"a-luge","neighbourhood":"busan-songdo","cat":"family-fun","name":"Skyline Luge Busan","emoji":"🛷","gradient":"linear-gradient(135deg,#27ae60,#f39c12)","region":"busan","cost":"₩27,000–34,000 (2–3 rides)","costZAR":"≈ R292–367","duration":"2 hrs","teaser":"Race gravity-powered luge carts down coastal tracks — a world-class thrill beside the sea.","desc":"Skyline Luge Busan has 4 track options of varying intensity. Ride a scenic chairlift up the mountain and then race gravity-powered go-kart style luge carts down winding tracks. The coastal views are spectacular. Located next to Haedong Yonggungsa Temple, making it a natural day-pairing.","highlights":["4 tracks: Forest, Zig Zag, Double Twist, Family","Chairlift ride up with ocean views","2-ride combo: ₩27k / 3-ride: ₩34k","All ages welcome (height restriction: 110cm solo)","Located next to sea temple"],"tips":"Arrive right when they open (9am) or after 3pm — summer peak hours see queues of 30+ minutes at midday. Wear comfortable clothes you're happy getting dusty. Buy tickets on Klook for 10–15% discount. Pair with Haedong Yonggungsa Temple which is a 5-minute drive away.","hours":"9am – 6pm (last ride 5:30pm)","address":"Gijang-gun, Busan (near Haedong Yonggungsa)","onItinerary":true,"needsBooking":false,"mapLink":"https://www.skylineluge.com/en/busan/","link":"https://www.skylineluge.com/en/busan/","interest":["thrills"],"indoor":false,"expensive":true},

  {"id":"a-sealife","cat":"family-fun","name":"SEA LIFE Busan Aquarium","emoji":"🦈","gradient":"linear-gradient(135deg,#1a3a5a,#1abc9c)","region":"busan","cost":"₩27,000–32,000","costZAR":"≈ R292–346","duration":"2–3 hrs","teaser":"Korea's premier aquarium on Haeundae Beach — a 80m underwater glass tunnel and Mermaid Show.","desc":"Located directly on the sands of Haeundae Beach, SEA LIFE Busan houses 40,000+ marine creatures across 14 zones. The 80-metre glass tunnel walkthrough tank is the centrepiece — sharks and rays glide overhead. The Coral Mermaid Show, shark feeding, and penguin feeding are all timed events. One of the best aquariums in Korea.","highlights":["80m underwater glass tunnel","Shark feeding: 12:00 & 16:00","Penguin feeding: 11:40 & 15:30","Coral Mermaid Show","Touch pool zone — sea stars and horseshoe crabs"],"tips":"Book on Klook or Trazy at least a day ahead — 15–30% cheaper than door price (door = ₩32k, Klook = ₩21–27k). Check show times online as they vary by day. Allow 2.5 hours to see everything including shows.","hours":"Weekdays 10am–7pm / Weekends 10am–8pm","address":"Haeundae Beach, Haeundae-gu, Busan","onItinerary":true,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.visitsealife.com/busan/","interest":["thrills"],"indoor":true},

  {"id":"a-skycapsule","cat":"family-fun","name":"Haeundae Sky Capsule (해운대 블루라인파크)","emoji":"🚡","gradient":"linear-gradient(135deg,#2980b9,#6dd5fa)","region":"busan","cost":"₩30,000–35,000 per capsule","costZAR":"≈ R324–378","duration":"2 hrs","teaser":"Private elevated coastal train capsules gliding above the sea cliffs — book 4+ weeks ahead.","desc":"Haeundae Blueline Park operates two experiences: the Sky Capsule (elevated 2-4 person private capsule riding 4m above the old coastal rail track) and the Beach Train (retro train on the same route). The Sky Capsule travels between Mipo and Cheongsapo with jaw-dropping coastal views. Only 48 capsules exist — books out weeks ahead in summer.","highlights":["Sky Capsule: private 2–4 person pod","Cheongsapo Bridge Skywalk (clear glass walkway)","Cheongsa Pocha seafood tent at the end","30-minute coastal journey","Beach Train alternative if Capsule sold out"],"tips":"BOOK IMMEDIATELY — Saturday July 4th capsules sell out 3–4 weeks in advance in summer. Book on the official Blueline Park website (blueline.or.kr). The Beach Train is a good alternative if capsules are full. Eat at Cheongsa Pocha raw seafood stall at the Cheongsapo end.","hours":"9am – 6pm (last boarding varies by season)","address":"Mipo Station → Cheongsapo, Haeundae-gu, Busan","onItinerary":true,"needsBooking":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/해운대블루라인파크/","interest":["thrills","culture"],"indoor":true},

  {"id":"a-drones","neighbourhood":"busan-gwangalli","cat":"shows","name":"Gwangalli Beach Drone Show","emoji":"🎇","gradient":"linear-gradient(135deg,#16213e,#0f3460)","region":"busan","cost":"Free","costZAR":"Free","duration":"30 min","teaser":"Hundreds of synchronized drones display animated light formations over the sea every Saturday night.","desc":"The Gwangalli M Drone Show (광안리 드론쇼) runs every Saturday evening at Gwangalli Beach at 8:00pm and 10:00pm. Hundreds of LED drones form animated displays — Korean cultural symbols, animals, and patterns — over Gwangan Bridge backdrop. It's a genuinely spectacular free show and one of the best things about Saturday in Busan.","highlights":["Two shows: 8:00pm and 10:00pm","Hundreds of synchronized LED drones","Gwangan Bridge as backdrop","Best viewed from beach or any restaurant facing the sea","Free, no booking required"],"tips":"Your Busan stay July 3–6 includes Saturday July 5 — the 10pm show is better (fewer crowds and the bridge lighting is more dramatic). Walk to Gwangalli Beach from your hotel (15–20 min) or take a short taxi. Arrive 30 min early for a good beach spot.","hours":"Saturdays: 8pm and 10pm shows","address":"Gwangalli Beach, Suyeong-gu, Busan","onItinerary":true,"needsBooking":false,"mapLink":"","link":"https://www.instagram.com/explore/tags/광안리드론쇼/","interest":["thrills"],"indoor":false},

  {"id":"a-haedong","cat":"culture","name":"Haedong Yonggungsa Temple (해동용궁사)","emoji":"⛩️","gradient":"linear-gradient(135deg,#1a3a5a,#27ae60)","region":"busan","cost":"Free","costZAR":"Free","duration":"1.5 hrs","teaser":"One of Korea's few Buddhist temples built directly on the rocky sea cliffs — built in 1376.","desc":"Haedong Yonggungsa (Dragon Palace Temple by the Sea) is extraordinarily rare — a Buddhist temple complex built right at the water's edge on dramatic volcanic cliff formations. Founded in 1376, the temple has pagodas and shrines perched above crashing waves. Walking the stone path from the dragon totem poles down to the temple is the experience.","highlights":["Dragon totem poles (용) at the entrance path","Main pagoda above the sea","Seokgamoni Buddha statue on the rocks","Lighthouse view from the cliff path","Wish coin toss into the rocks below"],"tips":"Best visited early morning (before 9am) or late afternoon for better lighting and fewer people. Combine with Skyline Luge which is 10 min by car. Wear non-slip shoes — the rocky path gets wet from sea spray. Weekends at midday are extremely crowded.","hours":"7am – 6pm daily (free entry)","address":"Gijang-gun, Busan (northeast coastal area)","onItinerary":false,"needsBooking":false,"mapLink":"","link":"https://www.instagram.com/explore/tags/해동용궁사/","interest":["culture"],"indoor":false},

  {"id":"a-kbo","neighbourhood":"seongsu","cat":"family-fun","name":"KBO Baseball: Doosan vs SSG @ Jamsil","emoji":"⚾","gradient":"linear-gradient(135deg,#003087,#c8963e)","region":"seoul2","cost":"₩8,000–25,000","costZAR":"≈ R86–270","duration":"3.5 hrs","teaser":"Experience Korean baseball culture — synchronized chants, cheerleaders, and bring-your-own fried chicken.","desc":"KBO (Korean Baseball Organization) games have an electrifying atmosphere unlike any other sport in the world. Each team has its own chant for every player, cheerleaders on dugouts, and the entire crowd sings in perfect synchronization. You can bring in your own food and drink from outside — so grab chicken and beer beforehand. Jamsil Stadium is the cathedral of KBO.","highlights":["Synchronized crowd chants + cheerleaders","Bring your own food & alcohol in (officially)","Doosan Bears (home team) vs SSG Landers","Standing bleacher seats (standing section) ₩8k","Reserved seats from ₩12k"],"tips":"Games are Tuesday Jul 7 at 6:30pm. Tickets on Interpark (인터파크) or at the box office 1.5–2hrs before game (weekday games rarely sell out). Buy fried chicken from the stalls outside before entering. Download the chant sheets for your team from Reddit r/koreabaseball.","hours":"Tues Jul 7, 6:30pm (backup: Wed Jul 8)","address":"Jamsil Baseball Stadium, Songpa-gu, Seoul","onItinerary":true,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://mykbostats.com/schedule/week_of/2026-07-07","interest":["thrills"],"indoor":false},

  {"id":"a-lolpark","neighbourhood":"songpa","cat":"family-fun","name":"LOL Park Esports Arena & PC Bang","emoji":"🎮","gradient":"linear-gradient(135deg,#1a3a5a,#c8963e)","region":"seoul2","cost":"Free entry / PC ₩2–3k/hr","costZAR":"≈ Free + R22–32/hr","duration":"1–2 hrs","teaser":"Visit the global home of League of Legends esports — arena, museum, and legendary PC cafes.","desc":"LOL Park is Riot Games' official esports venue in Seoul — the home of the LCK (League of Legends Champions Korea) and the spiritual home of Korean gaming. The complex includes the main arena, player murals, a store, and the famous LoL Museum. Order food straight to your gaming desk at the adjacent PC Bang (cafe).","highlights":["LCK arena viewing (when matches run)","LoL Museum and player hall of fame","PC Bang next door — gaming at highest spec","Food & drink order directly to desk","Team merchandise store"],"tips":"Check the LCK match schedule (lck.kr) — if a match is on while you're there, the atmosphere is extraordinary. The PC Bang experience is uniquely Korean — you order ramen, snacks and drinks and they're brought to your station while you play. Open daily.","hours":"LOL Park: 10am – 10pm. PC Bangs: 24/7","address":"Jonggak area (check exact address), Jongno-gu / Mapo area","onItinerary":true,"needsBooking":false,"mapLink":"","link":"https://www.instagram.com/explore/tags/롤파크/","interest":["thrills"],"indoor":true},

  {"id":"a-starfield","neighbourhood":"gangnam","cat":"culture","name":"Starfield Library + Bongeunsa Temple","emoji":"📚","gradient":"linear-gradient(135deg,#2c3e50,#8e44ad)","region":"seoul2","cost":"Library free / Temple program ₩20k","costZAR":"≈ Free + R216","duration":"Half day","teaser":"13-metre bookshelves in a glass atrium, then a 1,200-year-old Buddhist temple across the street.","desc":"Starfield Library (별마당도서관) is inside COEX Mall in Gangnam — a stunning public space with 70,000 books under a soaring glass ceiling, completely free with no reservation. Then walk 3 minutes to Bongeunsa Temple (봉은사), a 794 AD Buddhist temple complex with a 28-metre Maitreya Buddha — a surreal contrast next to gleaming Gangnam skyscrapers.","highlights":["Library: 70,000 books, free entry, open daily","Bongeunsa Temple: founded 794 AD","28m Maitreya Buddha statue","Tea ceremony + lantern making (₩20–30k, book ahead)","COEX Mall: 300+ shops + Aquarium below"],"tips":"The library is open 10:30am–10pm daily and is always beautiful for photos. Bongeunsa Temple Life program (tea ceremony + lantern making) can be booked 1 week ahead on the temple website. COEX Mall is excellent as a monsoon backup day if it rains heavily.","hours":"Library: 10:30am–10pm. Temple: free, sunrise–sunset","address":"COEX Mall, Samseong-dong, Gangnam-gu, Seoul","onItinerary":true,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://english.visitseoul.net/attractions/Starfield-Library/ENP026558","interest":["culture"],"indoor":true},

  {"id":"a-lotteworld","neighbourhood":"songpa","cat":"family-fun","name":"Lotte World Adventure (Theme Park)","emoji":"🎢","gradient":"linear-gradient(135deg,#e74c3c,#f39c12)","region":"seoul2","cost":"₩42,000–67,000 day pass","costZAR":"≈ R454–724","duration":"Full day","teaser":"The world's largest indoor theme park — a full day of rides, parades, and an outdoor island.","desc":"Lotte World is Asia's largest indoor amusement park (and one of the largest in the world). The indoor Adventure section has rides for all intensity levels, an ice rink, and daily parades. Across the lake is Magic Island — an outdoor section with bigger thrill rides. Located in Jamsil, steps from Lotte World Tower.","highlights":["Indoor Adventure section (weather-proof)","Gyro Drop & French Revolution (big thrills)","Daily indoor parade + character meets","Ice skating rink inside","Magic Island outdoor section"],"tips":"Book tickets on Klook for 15–20% discount. Go on a weekday (Jul 7 or 8) to avoid weekend crowds. The indoor section is ideal for Korea's July rain. Combine with Seoul Sky observation deck at Lotte World Tower next door.","hours":"9:30am – 10pm (weekdays) / 9:30am – 11pm (weekends)","address":"Jamsil-dong, Songpa-gu, Seoul","onItinerary":false,"needsBooking":false,"mapLink":"https://adventure.lotteworld.com/eng/","link":"https://adventure.lotteworld.com/eng/","interest":["thrills"],"indoor":true,"expensive":true},

  {"id":"a-cinema","neighbourhood":"gangnam","cat":"family-fun","name":"Premium Cinema: CGV Tempur Beds / 4DX / ScreenX","emoji":"🎬","gradient":"linear-gradient(135deg,#16213e,#8e44ad)","region":"any","cost":"₩15,000–50,000","costZAR":"≈ R162–540","duration":"2–3 hrs","teaser":"Korean cinemas are a world apart — reclining bed seats, motion seats, wind, and 270° screens.","desc":"Korea's cinema technology is the most advanced in the world. CGV's Tempur Cinema has fully reclining motorized beds (like business class seats) with welcome drinks. 4DX has motion-synced seats with wind, rain, smoke, and scent effects. ScreenX uses three walls for a 270-degree panoramic screen. Unique Korean popcorn: garlic butter, caramel, cheese — and grilled squid.","highlights":["Tempur Cinema — motorized bed seats + welcome drink (₩40–50k)","4DX — motion seats + wind/rain effects (₩25–35k)","ScreenX — 3-wall panoramic screen (₩20–25k)","IMAX — standard huge screen (₩15–20k)","Korean flavored popcorn: garlic butter, caramel, cheese"],"tips":"CGV Yongsan (I'Park Mall) has all formats including Tempur. Check showtimes at cgv.co.kr. A new blockbuster is always showing. The Tempur experience is especially unique — book 2–3 days ahead as it sells out. Bring your Korean popcorn appetite.","hours":"Showtimes from 9am – midnight+","address":"CGV Yongsan (all formats) and major mall branches","onItinerary":true,"needsBooking":true,"mapLink":"https://www.cgv.co.kr/","link":"https://www.cgv.co.kr/","interest":["thrills"],"indoor":true},

  {"id":"a-seoulsky","neighbourhood":"songpa","cat":"family-fun","name":"Seoul Sky Observation Deck","emoji":"🌆","gradient":"linear-gradient(135deg,#1a3a5a,#5dade2)","region":"seoul2","cost":"₩31,000","costZAR":"≈ R335","duration":"1.5 hrs","teaser":"The 123rd-floor glass-floor deck of Lotte World Tower — Korea's tallest building.","desc":"Ride one of the world's fastest elevators to the 117th–123rd floors of Lotte World Tower in Jamsil. Glass-floored skywalk sections let you look 478m straight down, and the 360° views stretch across the entire metropolis. Best around sunset, when you get day and night views in one visit.","highlights":["Glass-floor Sky Deck (118F)","Double-deck elevator with media show","Sunset slot — day + night views","Seoul Sky café on top","Combine with Lotte World below"],"tips":"Clear days are critical — check the live weather webcam before booking. The sunset slots sell out first; book on Klook/official site for discounts. Combine with Lotte World Adventure or Seokchon Lake below.","hours":"10:30am – 10pm daily","address":"Lotte World Tower, Sincheon-dong, Songpa-gu, Seoul","interest":["thrills"],"indoor":true,"expensive":true,"mapLink":"https://naver.me/","link":"https://seoulsky.lotteworld.com/"},

  {"id":"a-coexaqua","neighbourhood":"gangnam","cat":"family-fun","name":"COEX Aquarium","emoji":"🐠","gradient":"linear-gradient(135deg,#16627e,#48c9b0)","region":"seoul2","cost":"₩33,000","costZAR":"≈ R356","duration":"2 hrs","teaser":"40,000 marine creatures and shark tunnels inside COEX Mall — the perfect monsoon backup.","desc":"Located inside COEX Mall in Gangnam, this is one of Seoul's largest aquariums: 40,000 creatures across 183 tanks, including a walk-through shark tunnel, manatees, and interactive feeding shows. Because it's fully indoors and connected to Starfield Library and the mall food courts, it's the ideal rainy-day anchor.","highlights":["Shark tunnel walk-through","Manatee tank","Feeding shows throughout the day","Inside COEX — pair with Starfield Library","Fully indoor — monsoon safe"],"tips":"Buy tickets on Klook/Trazy for 15–30% off the door price. Weekday mornings are quietest. Combine with Starfield Library and lunch in the COEX food hall for a full indoor day.","hours":"10am – 8pm daily (last entry 7pm)","address":"COEX Mall, Samseong-dong, Gangnam-gu, Seoul","interest":["thrills"],"indoor":true,"expensive":true,"mapLink":"https://naver.me/","link":"https://www.coexaqua.com/"},

  {"id":"a-hangangcruise","neighbourhood":"mapo","cat":"family-fun","name":"Han River Evening Cruise","emoji":"🚢","gradient":"linear-gradient(135deg,#1f3a5f,#7fb3d5)","region":"seoul1","cost":"₩16,000–30,000","costZAR":"≈ R175–325","duration":"1 hr","teaser":"Sail past illuminated bridges at dusk — live music cruises depart from Yeouido.","desc":"Board a cruise boat at Yeouido and sail along the Han River past illuminated bridges and the glowing skyline. The evening \"music cruise\" features live performances, and some sailings time their route to catch the Banpo Bridge Rainbow Fountain show.","highlights":["Banpo Bridge Rainbow Fountain (seasonal)","Live music on evening sailings","N Seoul Tower views from the water","Departs Yeouido pier","Indoor + outdoor decks"],"tips":"The 7:30pm music cruise is the popular one — book a day or two ahead in summer. Sit on the open top deck for photos; the breeze is a relief in July heat.","hours":"Sailings roughly 11:30am – 9:30pm (check schedule)","address":"Yeouido Hangang Park pier, Yeongdeungpo-gu, Seoul","interest":["culture","thrills"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/hangangcruise/"},

  {"id":"a-vr","neighbourhood":"hongdae","cat":"family-fun","name":"VR Arcade & Escape Room","emoji":"🎮","gradient":"linear-gradient(135deg,#4a148c,#7b1fa2)","region":"any","cost":"₩20,000–40,000","costZAR":"≈ R215–430","duration":"1–2 hrs","teaser":"Multi-floor VR zones and high-tech escape rooms in Hongdae and Gangnam.","desc":"Korea's game culture extends well beyond PC bangs: multi-floor VR arcades offer racing sims, horror experiences, and free-roam zones, while Seoul's escape room scene is among the world's best. Hongdae has the densest cluster — easy to slot in on a rainy afternoon or evening.","highlights":["Free-roam VR zones","Racing + flight simulators","Horror VR rooms (not for the faint-hearted)","Escape rooms — some have English support","Hongdae & Gangnam clusters"],"tips":"Check Naver reviews for the most up-to-date equipment. For escape rooms, book English-friendly themes in advance — walk-ins usually only get Korean-language rooms.","hours":"Most venues 12pm – 11pm","address":"Hongdae & Gangnam, Seoul","interest":["thrills"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.klook.com/en-US/search/?query=seoul%20vr"},

  {"id":"a-cooking","neighbourhood":"insadong","cat":"hands-on","name":"Korean Cooking Class & Market Tour","emoji":"🥘","gradient":"linear-gradient(135deg,#a04000,#e67e22)","region":"any","cost":"₩50,000–90,000","costZAR":"≈ R540–970","duration":"3 hrs","teaser":"Shop a local market with a chef, then learn to cook mandu, kimchi, or bulgogi yourself.","desc":"A guided experience that starts with a tour of a traditional market to buy fresh ingredients, then moves to a kitchen studio where a local chef teaches you to make classics — kimchi, mandu dumplings, bulgogi, or pajeon. You eat everything you make. One of the best-rated food experiences for travellers in Seoul.","highlights":["Market tour with ingredient shopping","Hands-on cooking with a chef","Menus: kimchi, mandu, bulgogi, pajeon","Recipes to take home","Small group sizes"],"tips":"Book ahead on Klook/Airbnb Experiences — popular classes fill a week out. Vegetarian menus are usually available if requested at booking. Go hungry.","hours":"Morning and afternoon sessions (varies by host)","address":"Various — most near Gwangjang or Mangwon markets, Seoul","interest":["foodie"],"indoor":true,"needsBooking":true,"expensive":true,"mapLink":"https://naver.me/","link":"https://www.klook.com/en-US/search/?query=seoul%20cooking%20class"},

  {"id":"a-yeonnam","neighbourhood":"yeonnam","cat":"culture","name":"Yeonnam-dong Forest Park & Café Crawl","emoji":"🌳","gradient":"linear-gradient(135deg,#27ae60,#a9dfbf)","region":"seoul1","cost":"Free (cafés vary)","costZAR":"Free to stroll","duration":"2 hrs","teaser":"Stroll Yeonnam's linear forest park and explore the hip café alleys of Yeonnam-dong.","desc":"Walk along the Gyeongui Line Forest Park (a beautiful linear park built on old railway tracks, called 'Yeontral Park') and discover the quiet, leafy alleyways of Yeonnam-dong. The neighborhood is packed with indie cafés, designer boutiques, and local bakeries. Perfect for a relaxed, slow morning.","highlights":["Gyeongui Line Forest Park Yeontral Park stroll","Explore Yeonnam-dong café alleys","Specialty bakeries and coffee shops","Designer boutiques & concept stores","Right next to Hongdae area"],"tips":"Go in the morning around 10am when it's quiet. Grab a coffee or scone at Cafe Layered Yeonnam and watch the local residents walk their dogs in the park. Walking distance from Hongdae station.","hours":"Daily (stalls and shops open ~11am)","address":"Yeonnam-dong, Mapo-gu, Seoul","interest":["culture","fashion"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/연남동/"},

  {"id":"a-ikseon","neighbourhood":"insadong","cat":"culture","name":"Ikseon-dong Hanok Café Alleys","emoji":"🍵","gradient":"linear-gradient(135deg,#8a5a3a,#c8963e)","region":"seoul1","cost":"Free (cafés vary)","costZAR":"Free to stroll","duration":"2 hrs","teaser":"Stroll Seoul's trendiest micro-hanok village — narrow alleys filled with aesthetic cafés, dessert bars, and local boutiques.","desc":"Ikseon-dong is one of Seoul's oldest hanok neighborhoods, dating back to the 1920s. Over the last decade, young creatives have transformed the traditional courtyard houses into a dense, maze-like cluster of modern cafés, soufflé pancake houses, independent boutiques, and vintage shops. No museums or historical lectures — just pure aesthetic exploration, photogenic lanes, and delicious treats.","highlights":["Aesthetic hanok-conversion cafes","Soha Salt Pond and soufflé pancake shops","Quaint, photogenic narrow alleyways","Boutique shopping & souvenir stalls","Near Insadong and Jongno 3-ga"],"tips":"Go early in the morning (around 10:30am) to beat the massive afternoon crowds. The alleys are very narrow, so they get packed by 1pm. Grab a signature salt coffee or traditional sweet treat.","hours":"Daily (most shops open 11am)","address":"Ikseon-dong, Jongno-gu, Seoul","interest":["culture","fashion"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/익선동/"},

  {"id":"a-dmz","neighbourhood":"gwanghwamun","cat":"culture","name":"DMZ Half-Day Guided Tour","emoji":"🪖","gradient":"linear-gradient(135deg,#2c3e50,#4a6b53)","region":"seoul1","cost":"₩60,000–100,000","costZAR":"≈ R650–1,080","duration":"7 hrs","teaser":"Stand at the border of North Korea — infiltration tunnels, Dora Observatory, and living history.","desc":"A guided coach tour to the Demilitarized Zone separating the two Koreas, typically including the Third Infiltration Tunnel, Dora Observatory (look into North Korea through telescopes), Imjingak Park, and the Unification Village. Sobering, fascinating, and consistently rated a trip highlight.","highlights":["Third Infiltration Tunnel","Dora Observatory — views into North Korea","Imjingak Park & Freedom Bridge","Licensed guide with historical context","Hotel pickup on most tours"],"tips":"Book weeks in advance and bring your physical passport — photocopies are not accepted. Tours can be cancelled at short notice depending on border conditions; keep your day flexible.","hours":"Departures ~7–8am, return mid-afternoon","address":"Departs central Seoul (tour pickup)","interest":["culture"],"indoor":false,"needsBooking":true,"expensive":true,"mapLink":"https://naver.me/","link":"https://www.klook.com/en-US/search/?query=DMZ%20tour%20seoul"},

  {"id":"a-natmuseum","neighbourhood":"insadong","cat":"culture","name":"National Museum of Korea","emoji":"🏺","gradient":"linear-gradient(135deg,#4d3319,#a0703c)","region":"seoul1","cost":"Free","costZAR":"","duration":"2 hrs","teaser":"Korea's premier museum — 300,000 relics and the serene Room of Quiet Contemplation. Free.","desc":"Korea's flagship museum in Yongsan houses over 300,000 artifacts spanning ancient kingdoms to modern art. The highlight is the \"Room of Quiet Contemplation\" — two gilt-bronze pensive Bodhisattva statues in a dark, meditative hall. Free entry, world-class, and air-conditioned.","highlights":["Room of Quiet Contemplation","Goryeo celadon ceramics","Silla gold crowns","Free entry — permanent halls","Excellent gift shop"],"tips":"Go straight to the Room of Quiet Contemplation on the 2nd floor before the crowds. The museum park outside is lovely at dusk. Closed on certain national holidays — check before going.","hours":"10am – 6pm (Wed & Sat until 9pm)","address":"Seobinggo-ro, Yongsan-gu, Seoul","interest":["culture"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.museum.go.kr/site/eng/home"},

  {"id":"a-deoksugung","neighbourhood":"gwanghwamun","cat":"culture","name":"Deoksugung Palace Night Stroll","emoji":"🏮","gradient":"linear-gradient(135deg,#1c2833,#7d6608)","region":"seoul2","cost":"₩1,000","costZAR":"≈ R11","duration":"1 hr","teaser":"The only palace open after dark — lantern-lit halls beside a famous stone wall walk.","desc":"Deoksugung is the only Seoul palace regularly open at night, when its wooden halls and unusual neoclassical stone buildings are beautifully illuminated. The adjacent Deoksugung Doldam-gil (stone wall road) is one of Seoul's most loved evening walks. Entry is a symbolic ₩1,000.","highlights":["Night illumination until 9pm","Doldam-gil stone wall walk","Mix of Korean + Western architecture","₩1,000 entry","Near City Hall station"],"tips":"Pair with dinner downtown — enter around 7:30pm as the lights come on. The Royal Guard ceremony also happens here at the main gate during the day. Closed Mondays.","hours":"9am – 9pm (closed Mon)","address":"Sejong-daero, Jung-gu, Seoul","interest":["culture"],"indoor":false,"closedDay":1,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/deoksugung/"},

  {"id":"a-uncemetery","neighbourhood":"busan-nampo","cat":"culture","name":"UN Memorial Cemetery & Busan Museum","emoji":"🕊️","gradient":"linear-gradient(135deg,#1b4f72,#5499c7)","region":"busan","cost":"Free","costZAR":"","duration":"2 hrs","teaser":"The world's only UN military cemetery — peaceful, moving, and minutes from your Busan hotel.","desc":"The only United Nations cemetery in the world, honouring soldiers from 22 nations who fell in the Korean War. Immaculately kept gardens, a moving Wall of Remembrance, and a daily flag-lowering ceremony. The Busan Museum next door adds local history context — and free hanbok try-on.","highlights":["Wall of Remembrance","Flag-lowering ceremony (afternoons)","Gardens + memorial hall","Busan Museum next door — free","Walking distance from Nam-gu hotel area"],"tips":"Dress respectfully — shoulders covered, no beachwear. It's in Nam-gu, very close to the Bonathree Hotel, so it pairs naturally with Oryukdo Skywalk on the same day.","hours":"9am – 5pm daily (museum closed Mon)","address":"UN Pyeonghwa-ro, Nam-gu, Busan","interest":["culture"],"indoor":false,"onItinerary":true,"mapLink":"https://naver.me/","link":"https://www.unmck.or.kr/eng/main/"},

  {"id":"a-xthesky","neighbourhood":"busan-haeundae","cat":"family-fun","name":"Haeundae X the Sky","emoji":"🏙️","gradient":"linear-gradient(135deg,#154360,#85c1e9)","region":"busan","cost":"₩27,000","costZAR":"≈ R290","duration":"1 hr","teaser":"The 100th-floor observatory directly above Haeundae Beach — with the world's highest Starbucks.","desc":"Busan X the Sky occupies the top floors of the 411m LCT Landmark Tower, right on Haeundae Beach. Floor-to-ceiling windows look over the beach arc, Gwangan Bridge, and on clear days as far as Tsushima. The 99th floor hosts the world's highest Starbucks.","highlights":["100F observation deck at 411m","Haeundae Beach + Gwangan Bridge views","World's highest Starbucks (99F)","Shocking glass-window \"Sky toilet\"","Sunset slots are spectacular"],"tips":"Go late afternoon and stay through sunset. Buy discounted tickets on Klook. Combine with the Sky Capsule and Haeundae Beach for a full day in the area.","hours":"10am – 9pm daily","address":"LCT Landmark Tower, Haeundae, Busan","interest":["thrills"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/busanxthesky/"},

  {"id":"a-huinnyeoul","neighbourhood":"busan-nampo","cat":"culture","name":"Huinnyeoul Culture Village Walk","emoji":"🏘️","gradient":"linear-gradient(135deg,#21618c,#aed6f1)","region":"busan","cost":"Free","costZAR":"","duration":"2 hrs","teaser":"Busan's \"Santorini\" — white cliff-side alleys, coastal caves, and tiny sea-view cafés on Yeongdo.","desc":"A former refugee settlement on the cliffs of Yeongdo Island, now a quietly beautiful village of white-washed alleys above the sea. Walk the coastal path, duck through the pedestrian tunnel, and stop at pocket-sized cafés with front-row ocean views. Far less crowded than Gamcheon.","highlights":["White cliff-side alleyways","Coastal walking path + tunnel","Tiny sea-view cafés","Film location for \"The Attorney\"","Quieter than Gamcheon Village"],"tips":"Wear good shoes — the steps down to the coastal path are steep. Go in the morning for soft light and empty alleys, then lunch at a seaside café. Combine with Momos Coffee on Yeongdo.","hours":"Always open (cafés ~10am – 8pm)","address":"Yeongseon-dong, Yeongdo-gu, Busan","interest":["culture","fashion"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/huinnyeoulculturevillage/"},

  {"id":"a-oryukdo","neighbourhood":"busan-oryukdo","cat":"culture","name":"Oryukdo Skywalk & Igidae Trail","emoji":"🌉","gradient":"linear-gradient(135deg,#1a5276,#48c9b0)","region":"busan","cost":"Free","costZAR":"","duration":"1–2 hrs","teaser":"A glass bridge over ocean cliffs facing the Oryukdo islets — then a dramatic coastal trail.","desc":"A horseshoe of glass jutting out over 35m sea cliffs, looking onto the Oryukdo islets where the East Sea officially begins. Free entry (shoe covers provided to protect the glass). The adjacent Igidae Coastal Trail serves up some of Busan's most dramatic shoreline scenery.","highlights":["Glass-floor skywalk over the cliffs","Oryukdo islets viewpoint","Igidae Coastal Trail (1–2 hrs)","Free entry","In Nam-gu — near the hotel"],"tips":"Very windy — hold onto hats and phones. Skip on rainy days (the glass closes in bad weather). The full Igidae trail to Dongsaengmal takes ~2 hours; turn back at any point.","hours":"9am – 6pm (skywalk)","address":"Yongho-dong, Nam-gu, Busan","interest":["culture","thrills"],"indoor":false,"onItinerary":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/oryukdo/"},

  {"id":"a-ddp","neighbourhood":"dongdaemun","cat":"culture","name":"Dongdaemun Design Plaza (DDP)","emoji":"🌀","gradient":"linear-gradient(135deg,#212f3d,#85929e)","region":"seoul2","cost":"Free to browse","costZAR":"","duration":"2 hrs","teaser":"Zaha Hadid's liquid-metal landmark — design exhibitions and a glowing LED rose garden at night.","desc":"Zaha Hadid's neofuturistic masterpiece flows like liquid metal through Dongdaemun. By day it hosts design exhibitions, markets, and the Design Museum; by night the LED rose garden and illuminated curves make it one of Seoul's best free photo spots. Surrounded by 24-hour fashion malls.","highlights":["Zaha Hadid architecture","LED rose garden (night)","Rotating design exhibitions","Dongdaemun night fashion malls nearby","Free to walk through"],"tips":"Come at blue hour for the best photos of the curves and the rose garden. The surrounding Dongdaemun wholesale malls (apM, Doota) stay open past midnight if you want late-night shopping.","hours":"Grounds always open; exhibitions 10am – 8pm","address":"Eulji-ro, Jung-gu, Seoul","interest":["culture","fashion"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/ddpseoul/"},

  {"id":"a-songdo","neighbourhood":"busan-songdo","cat":"family-fun","name":"Songdo Cable Car (Busan Air Cruise)","emoji":"🚠","gradient":"linear-gradient(135deg,#117864,#76d7c4)","region":"busan","cost":"₩20,000–28,000","costZAR":"≈ R215–300","duration":"2 hrs","teaser":"Glass-floor cabins gliding 86m above the sea between Songdo Beach and Amnam Park.","desc":"The Busan Air Cruise crosses 1.6km of open sea between Songdo Beach and Amnam Park, with \"Crystal Cruise\" cabins offering transparent floors 86m above the water. On the far side: coastal boardwalks, a dinosaur-themed park, and the Songdo Yonggung suspension bridge.","highlights":["Crystal (glass-floor) cabins","86m above open sea","Amnam Park coastal walk","Songdo Yonggung suspension bridge","Songdo Beach on the city side"],"tips":"Pay the small premium for the Crystal Cruise glass-floor cabin — it's the whole point. Buy a round trip but budget an hour to walk Amnam Park before returning.","hours":"9am – 8pm (later on summer weekends)","address":"Songdo Beach, Seo-gu, Busan","interest":["thrills"],"indoor":true,"onItinerary":true,"mapLink":"https://naver.me/","link":"https://www.busanaircruise.co.kr"},

  {"id":"a-bulguksa","neighbourhood":"gyeongju","cat":"culture","name":"Bulguksa Temple (Gyeongju Day Trip)","emoji":"🛕","gradient":"linear-gradient(135deg,#6e2c00,#ca6f1e)","region":"busan","cost":"₩6,000","costZAR":"≈ R65","duration":"Half day","teaser":"UNESCO World Heritage masterpiece of Silla Buddhist architecture — an easy day trip from Busan.","desc":"The crown jewel of Silla-era Buddhism and a UNESCO World Heritage Site, Bulguksa's stone terraces, bridges, and twin pagodas (Dabotap and Seokgatap) date to the 8th century. Gyeongju — \"the museum without walls\" — is reachable from Busan in under an hour by KTX or express bus.","highlights":["UNESCO World Heritage Site","Dabotap & Seokgatap pagodas","8th-century stone bridges","Lotus pond + temple gardens","Pairs with Seokguram Grotto up the mountain"],"tips":"Do Gyeongju as a full day from Busan: Bulguksa + Seokguram in the morning, Hwangridan-gil for lunch, Wolji Pond at night. KTX to Singyeongju takes ~30 min from Busan Station.","hours":"9am – 6pm (varies seasonally)","address":"Bulguksa-ro, Gyeongju (day trip from Busan)","interest":["culture"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/bulguksatemple/"},

  {"id":"a-seokguram","neighbourhood":"gyeongju","cat":"culture","name":"Seokguram Grotto & Stone Buddha","emoji":"🗿","gradient":"linear-gradient(135deg,#515a5a,#aab7b8)","region":"busan","cost":"₩6,000","costZAR":"≈ R65","duration":"2 hrs","teaser":"A monumental granite Buddha gazing over the East Sea — the pinnacle of Silla stonework.","desc":"High on Mount Toham above Bulguksa, this 8th-century granite grotto houses a 3.5m seated Buddha regarded as one of Asia's finest Buddhist sculptures, positioned to face the sunrise over the East Sea. A UNESCO World Heritage Site alongside Bulguksa.","highlights":["3.5m granite seated Buddha","UNESCO World Heritage Site","Mountain forest approach walk","Faces the East Sea sunrise","10 min drive / 1 hr hike above Bulguksa"],"tips":"The grotto is viewed through a glass screen — go early to avoid tour groups stacking up. The forest walk from the parking lot is shaded and lovely. Combine with Bulguksa below.","hours":"9am – 5:30pm (varies seasonally)","address":"Mount Toham, Gyeongju (day trip from Busan)","interest":["culture"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/seokguram/"},

  {"id":"a-wolji","neighbourhood":"gyeongju","cat":"culture","name":"Donggung Palace & Wolji Pond (Night)","emoji":"🌙","gradient":"linear-gradient(135deg,#154360,#f4d03f)","region":"busan","cost":"₩3,000","costZAR":"≈ R32","duration":"1.5 hrs","teaser":"Silla royal pavilions mirrored perfectly in a lantern-lit pond — Gyeongju's definitive night view.","desc":"The pleasure garden of the Silla crown princes, Wolji (\"moon pond\") is Korea's most photographed night scene: illuminated pavilions reflected without a ripple in the dark water. Go after sunset — daytime visits don't compare.","highlights":["Illuminated pavilions on the pond","Mirror reflections after dark","Silla royal palace site","Summer lotus fields nearby","Gyeongju's best night photo spot"],"tips":"Arrive 30 min before full dark to watch the lights come on. It gets busy on weekend nights — weekdays are calmer. End your Gyeongju day trip here before heading back to Busan.","hours":"9am – 10pm (last entry 9:30pm)","address":"Wolseong-dong, Gyeongju (day trip from Busan)","interest":["culture"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/woljipond/"},

  {"id":"a-leeum","neighbourhood":"hannam","cat":"culture","name":"Leeum Museum of Art","emoji":"🖼️","gradient":"linear-gradient(135deg,#17202a,#909497)","region":"seoul2","cost":"Free–₩15,000","costZAR":"≈ R0–160","duration":"2 hrs","teaser":"Samsung's world-class museum — national-treasure ceramics beside Rothko and Koons, in Hannam-dong.","desc":"Run by the Samsung Foundation, Leeum pairs a stunning collection of traditional Korean art (including national-treasure celadon) with blue-chip international contemporary work, in buildings by Mario Botta, Jean Nouvel, and Rem Koolhaas. The permanent collection is free; special exhibitions are ticketed.","highlights":["National-treasure Goryeo celadon","Contemporary wing — Rothko, Koons, Lee Bul","Architecture by Botta, Nouvel, Koolhaas","Permanent collection free (book online)","In Hannam-dong — pair with boutique shopping"],"tips":"Reserve timed-entry tickets on the website a few days ahead — walk-ins are limited. Closed Mondays. The neighbourhood (Hannam-dong) is full of designer boutiques and cafés for afterwards.","hours":"10am – 6pm (closed Mon)","address":"Itaewon-ro 55-gil, Hannam-dong, Yongsan-gu, Seoul","interest":["culture","fashion"],"indoor":true,"needsBooking":true,"closedDay":1,"mapLink":"https://naver.me/","link":"https://www.leeum.org/"},

  {"id":"a-hausnowhere","neighbourhood":"apgujeong","cat":"art","name":"Gentle Monster — Haus Nowhere","emoji":"🕶️","gradient":"linear-gradient(135deg,#1c1c1c,#c8963e)","region":"seoul2","cost":"Free (shopping optional)","costZAR":"","duration":"1.5 hrs","teaser":"Gentle Monster's immersive art-and-eyewear universe in Apgujeong — part gallery, part concept store.","desc":"Haus Nowhere is Gentle Monster's Apgujeong flagship concept store — an experience as much as a retail space. Rotating large-scale art installations occupy multiple floors alongside the eyewear collections and the Nudake dessert café. The installations are curated several times a year and you never know what you'll find. Even if you buy nothing, it's one of Seoul's most distinct spaces.","highlights":["Rotating art installations by contemporary artists","Gentle Monster eyewear collection","Tamburins fragrance annexe","Nudake dessert café on the upper floor","One of Seoul's most photographed interiors"],"tips":"Check Gentle Monster's Instagram to see the current installation theme before visiting. Combine with the broader Dosan Park shopping circuit. No charge to enter — just browse. Staff are used to photography.","hours":"11am – 9pm daily","address":"Apgujeong, Gangnam-gu, Seoul (Haus Dosan complex)","interest":["fashion","culture"],"indoor":true,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/gentlemonster/","logo":"https://upload.wikimedia.org/wikipedia/commons/b/b3/GENTLE_MONSTER_Logo_New_2.svg"},

  {"id":"a-seosomun-museum","neighbourhood":"myeongdong","cat":"culture","name":"Seosomun Shrine History Museum","emoji":"⛪","gradient":"linear-gradient(135deg,#1a1a2e,#16213e)","region":"seoul2","cost":"Free","costZAR":"Free","duration":"1.5 hrs","teaser":"Korea's most striking modern museum — commemorating Catholic martyrs in a dramatic underground space.","desc":"The Seosomun Shrine History Museum memorialises the thousands of Korean Catholics martyred at the Seosomun execution grounds during the Joseon Dynasty (especially during the 1800s persecutions). The architecture is extraordinary — a largely underground structure around a sunken courtyard, with the shrine garden above ground. One of Seoul's most architecturally significant and emotionally resonant spaces.","highlights":["Dramatic underground architecture","Martyrs' memorial exhibitions","Open-sky sunken courtyard","Free entry","Near Namdaemun Market — easy to combine"],"tips":"The museum is largely underground — the approach from street level is disorienting at first. Allow 1.5 hours to take in both the architectural space and the historical context. Free audio guides available.","hours":"9:30am – 6pm (closed Mondays)","address":"Chilpae-ro, Jung-gu, Seoul (Seosomun area)","interest":["culture"],"indoor":true,"closedDay":1,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/서소문역사박물관/"},

  {"id":"a-kompakt","neighbourhood":"itaewon","cat":"music","name":"Kompakt Record Bar (콤팩트 레코드 바)","emoji":"🎵","gradient":"linear-gradient(135deg,#1a1a2e,#4a4a8a)","region":"seoul1","cost":"₩5,000–10,000 (drinks)","costZAR":"≈ R54–108","duration":"1.5 hrs","teaser":"A vinyl bar in Itaewon that stocks the Kompakt Records catalogue — electronic music, drinks, and real sound.","desc":"Kompakt Record Bar is a rare thing: a bar and record shop dedicated to the Kompakt Records label catalogue (Cologne-based electronic music). Located in Itaewon/Haebangchon, it stocks vinyl from the Kompakt catalogue, plays records through a quality sound system, and serves drinks. A genuine destination for anyone who cares about electronic music.","highlights":["Full Kompakt catalogue vinyl for sale","Records played through quality sound system","Bar service alongside","Itaewon / Haebangchon location","International music crowd"],"tips":"Come in the evening when the bar atmosphere is alive. If you're into electronic music, check their Instagram for events — they occasionally host DJ nights. The stock changes, so a visit is always different.","hours":"6pm – midnight (check Instagram for days)","address":"Haebangchon / Itaewon area, Yongsan-gu, Seoul","interest":["culture","fashion"],"indoor":true,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/kompaktrecordbar/"},

  {"id":"a-say-kodak","neighbourhood":"seongsu","cat":"photography","name":"Say Kodak Film Camera Shop (세이 코닥)","emoji":"📷","gradient":"linear-gradient(135deg,#f5a623,#e74c3c)","region":"seoul1","cost":"₩15,000–200,000+","costZAR":"≈ R162–2,160","duration":"1 hr","teaser":"A Seongsu film photography specialist — buy a disposable Kodak or find a vintage film camera.","desc":"Say Kodak is a Seongsu film and analogue photography shop selling Kodak disposable cameras, 35mm film rolls, and curated vintage film cameras. Whether you want to shoot a roll for the trip (disposable from ₩15k) or find a working Olympus mju from ₩60k, this is the destination. Staff are knowledgeable and patient with beginners.","highlights":["Kodak disposable cameras from ₩15k","35mm colour and black-and-white film","Vintage film cameras (Olympus, Canon, Nikon)","Film drop-off and scanning service available","Prints ready in 3–5 days"],"tips":"A Kodak disposable is a genuinely fun way to document the trip with less screen time. Buy film here and shoot it through; drop it off at the shop or Naver Maps nearest photo lab for development. Photos arrive as digital scan + prints.","hours":"12pm – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion","culture"],"indoor":true,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/saykodak.kodak/"},

  {"id":"a-noirmood-space","neighbourhood":"apgujeong","cat":"art","name":"noirmood.8 — Cinema × Furniture × Couture Space","emoji":"🖤","gradient":"linear-gradient(135deg,#1c1c1c,#555555)","region":"seoul2","cost":"Free (browsing)","costZAR":"Free","duration":"1 hr","teaser":"A Dosan concept space that lives at the intersection of cinema, furniture, and fashion — one room, one mood.","desc":"noirmood.8 is a concept destination in the Dosan area that positions itself at the intersection of cinema, furniture, and couture. The space is more editorial environment than traditional retail — a slow, deliberate walk through a dark, carefully considered interior. Open daily 12–9pm. The experience rewards those who slow down and look carefully.","highlights":["Cinema-inspired editorial interiors","Furniture + fashion objects curated together","Dark, controlled lighting throughout","Dosan Park circuit location","Photography-friendly interior"],"tips":"Combine with the Haus Nowhere and Nudake visit in the same Dosan Park circuit. Visit in the afternoon when the editorial light is best. The atmosphere is the product — go in without expectations.","hours":"12pm – 9pm daily","address":"Dosan area, Apgujeong, Gangnam-gu, Seoul","interest":["fashion","culture"],"indoor":true,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://en.noirmood.com/?utm_source=ig&utm_medium=social&utm_content=link_in_bio","logo":"images/noirmood_logo.png"},

  {"id":"a-paper-plate","neighbourhood":"seongsu","cat":"art","name":"Paper Plate (페이퍼 플레이트) — Seongsu","emoji":"🍽️","gradient":"linear-gradient(135deg,#f0ebe3,#a09070)","region":"seoul1","cost":"Free (gallery) / varies (retail)","costZAR":"Free to browse","duration":"1 hr","teaser":"A Seongsu art-and-design space where objects, books, and small-run editions are treated as art objects.","desc":"Paper Plate is a small design and art concept space in Seongsu that curates printed matter, art editions, objects, and small-run design pieces. It operates somewhere between bookshop, gallery, and boutique — the curation is thoughtful and the selection changes regularly. A quiet counterpoint to Seongsu's louder cafés.","highlights":["Art books and zines","Small-run design objects","Curated printed matter","Quiet gallery atmosphere","Seongsu creative district location"],"tips":"Best for those interested in design, publishing, and visual art. You might spend 20 minutes or two hours depending on how deeply the curation speaks to you.","hours":"12pm – 7pm (check for closed days)","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["culture","fashion"],"indoor":true,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/paperplate/"},

  {"id":"a-hetras","neighbourhood":"seongsu","cat":"concept","name":"Hetras (헤트라스) — Seongsu","emoji":"🌀","gradient":"linear-gradient(135deg,#2c3e50,#8e44ad)","region":"seoul1","cost":"Free to browse / retail varies","costZAR":"Free","duration":"1 hr","teaser":"A Seongsu concept store blending fashion, furniture, and objects in a warm, gallery-like space.","desc":"Hetras is a Seongsu concept store that curates clothing, lifestyle objects, and furniture together in a cohesive editorial environment. The approach is slow retail — each item placed deliberately, the space designed to make you consider what you're looking at. A relaxed but refined browse.","highlights":["Fashion and lifestyle objects curated together","Gallery-like layout — not a typical shop","Warm, considered interior","Seongsu creative cluster location","Occasional pop-up installations"],"tips":"Worth a quick loop even if you're not buying — the curation gives ideas and the space is a break from noisier Seongsu retail. Best combined with nearby Sounds of Apple and Paper Plate.","hours":"12pm – 8pm (closed some Mondays)","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion","culture"],"indoor":true,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/hetras.official/"},

  {"id":"a-apgujeong-sanghoe","neighbourhood":"apgujeong","cat":"art","name":"Apgujeong Rodeo Concept Gallery Walk","emoji":"🎨","gradient":"linear-gradient(135deg,#1c2833,#e8daef)","region":"seoul2","cost":"Free","costZAR":"Free","duration":"1.5 hrs","teaser":"A self-guided walk through the small concept galleries and pop-up spaces of Apgujeong Rodeo Street.","desc":"Apgujeong's Rodeo Street (로데오거리) isn't just high-end boutiques — it contains a network of small concept galleries, pop-up exhibition spaces, and independent art rooms tucked between the larger stores. A slow walk reveals rotating exhibitions, independent designer showcases, and occasional art-meets-commerce collaborations. Free entry to almost all.","highlights":["Small concept galleries — free entry","Rotating pop-up installations","Independent designer showcases","Fashion-adjacent art presentations","Pairs perfectly with the Dosan Park circuit"],"tips":"Don't rely on a fixed itinerary here — the appeal is wandering and discovering. Combine with Haus Nowhere and the Dosan loop. Galleries open around 11am and most close by 8pm.","hours":"11am – 8pm (varies by space)","address":"Apgujeong Rodeo Street, Gangnam-gu, Seoul","interest":["fashion","culture"],"indoor":true,"onItinerary":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/압구정로데오/"},

  // ── BUSAN ACTIVITIES (added from YouTube research, June 2026) ──

  {"id":"a-gwangalli-beach","neighbourhood":"gwangalli","cat":"family-fun","name":"Gwangalli Beach + Drone Show (광안리)","emoji":"🌉","gradient":"linear-gradient(135deg,#0d2137,#1f618d)","region":"busan","cost":"Free","costZAR":"Free","duration":"2–3 hrs","teaser":"Gwangalli Beach at night — with a free weekly drone light show over the Diamond Bridge every Saturday.","desc":"광안리 (Gwangalli Beach) is Busan's chicest beach strip: lined with cafés, bars, and restaurants facing the iconic Gwangandaegyo suspension bridge (광안대교) — known as Diamond Bridge for its cable-lit glow at night. On Saturday evenings, hundreds of synchronized drones perform a light show over the water at 20:00 and 22:00 (summer times). The beach itself is smaller and more intimate than Haeundae, making it a more relaxed evening spot.","highlights":["Diamond Bridge cable light display","Free drone show every Saturday 8pm + 10pm","Cafés and bars right on the beachfront","Millak Raw Fish Town adjacent (seafood dinner)","Less crowded than Haeundae"],"tips":"Saturday night is the move — arrive by 7:30pm, grab a seat at a beachfront café, and watch the drone show. Check for weather cancellations on the Suyeong-gu official website. Summer 2026 show times: 20:00 and 22:00. The area has excellent café hopping after the show.","hours":"Beach: always open. Drone show: every Saturday 20:00 + 22:00 (March–Sept)","address":"Gwangan-dong, Suyeong-gu, Busan","interest":["culture","family-fun"],"indoor":false,"onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/광안리/"},

  {"id":"a-busan-x-the-sky","neighbourhood":"haeundae","cat":"family-fun","name":"Busan X the Sky (부산 엑스더스카이)","emoji":"🏙️","gradient":"linear-gradient(135deg,#0a0a1a,#f0b27a)","region":"busan","cost":"₩27,000–29,000 adults","costZAR":"≈ R291–313","duration":"1.5 hrs","teaser":"Busan's highest observatory on floors 98–100 — 360° views over Haeundae Beach, Gwangan Bridge, and the entire city.","desc":"부산 엑스더스카이 (Busan X the Sky) sits on the 98th, 99th and 100th floors of the LCT Landmark Tower in Haeundae — the tallest building in Busan. The observatory offers 360° panoramic views of Haeundae Beach, Gwangan Bridge, and the city skyline. Features include a glass-floor 'Shocking Bridge' section, a media art show, an in-observatory Starbucks on the 99th floor (reportedly the world's highest), and sky-high photo zones.","highlights":["360° views: Haeundae Beach + Gwangan Bridge","Glass-floor Shocking Bridge section","World's highest Starbucks (99F)","Media art show","Best at sunset for day-to-night transition"],"tips":"Book online via Klook or KKday for 10–15% discounts. Visit at sunset — you catch the golden hour view and then the city lights come on. Allow 1.5 hrs minimum. Combine with a Haeundae Beach walk before/after.","hours":"10am – 9pm daily (last entry 8:30pm)","address":"LCT Landmark Tower, Haeundae-gu, Busan","interest":["thrills","culture"],"indoor":true,"onItinerary":false,"needsBooking":true,"mapLink":"https://naver.me/","link":"https://xthesky.kr"},

  {"id":"a-spaland-centum","neighbourhood":"haeundae","cat":"family-fun","name":"Spa Land Centum City (스파랜드 센텀)","emoji":"🧖","gradient":"linear-gradient(135deg,#4a235a,#85c1e9)","region":"busan","cost":"₩26,000 adults (4 hrs)","costZAR":"≈ R281","duration":"3–5 hrs","teaser":"World-class jjimjilbang inside Shinsegae Centum City — 13 themed saunas, natural hot springs, and a 5-star spa experience.","desc":"스파랜드 (Spa Land) inside Shinsegae Centum City department store is considered one of the best jjimjilbang experiences in all of Korea. 13 thematic sauna rooms (Roman, Finnish, gem-stone, ice room, etc.), a full suite of indoor/outdoor natural hot spring baths at varying temperatures, relaxation rooms, a restaurant, and a café — all inside a spotless, beautifully designed facility. Entry includes pajamas and a towel. Your locker key doubles as an in-facility payment card.","highlights":["13 themed sauna rooms","Natural hot spring indoor + outdoor pools","Body scrub (seshin) service — book ahead","Pajamas + towel included","Attached to Shinsegae Centum City mall"],"tips":"Go on a weekday — significantly less crowded. Book the traditional Korean body scrub (때밀이 seshin) as soon as you arrive — slots fill fast. There are separate male/female bathing areas and a mixed-gender rest area. No photography in bathing areas. Great for a rainy day or a recovery day after heavy walking.","hours":"6am – midnight (last entry 11pm)","address":"Shinsegae Centum City, Centum 2-ro, Haeundae-gu, Busan","interest":["family-fun"],"indoor":true,"onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.shinsegae.com/store/main.do?storeCode=009"},

  {"id":"a-choryang-ibagu-gil","neighbourhood":"choryang","cat":"culture","name":"Choryang Ibagu-gil (초량 이바구길)","emoji":"🪜","gradient":"linear-gradient(135deg,#1a2733,#85929e)","region":"busan","cost":"Free","costZAR":"Free","duration":"1.5 hrs","teaser":"A 2km hillside walking trail through Busan's Korean War refugee history — the '168 Stairs' and a free monorail to the top.","desc":"초량 이바구길 means 'story path' in the Busan dialect. This 2km hillside trail in Choryang (Dong-gu, near Busan Station) winds through one of the neighbourhoods where Korean War refugees settled in the 1950s. Along the route: the steep '168 Stairs,' a free community monorail (free for residents/visitors), Ibagu Archive Center, the Yu Chi-hwan Postbox Observatory, and former Baekje Hospital. The trail overlooks Busan Port and connects directly to Taeseongdang bakery.","highlights":["168 Stairs — the iconic climb","Free community monorail","Yu Chi-hwan Postbox Observatory (views)","Ibagu Archive Center — war refugee history","Directly connects to Taeseongdang bakery"],"tips":"Take the monorail up and walk the 168 Steps down — much easier. Combine this with Taeseongdang and Bonjeon Gukbap for a full Choryang half-day itinerary right from Busan Station. Best on weekday mornings before tour groups arrive.","hours":"Always open; monorail ~9am – 6pm","address":"Choryang-dong, Dong-gu, Busan (5 min walk from Busan Station)","interest":["culture"],"indoor":false,"onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.visitbusan.net"},

  {"id":"a-taejongdae","neighbourhood":"yeongdo","cat":"culture","name":"Taejongdae Resort Park (태종대)","emoji":"⛰️","gradient":"linear-gradient(135deg,#1b4f72,#27ae60)","region":"busan","cost":"Free entry; Danubi Train ₩3,000","costZAR":"≈ Free + R32","duration":"2–3 hrs","teaser":"Dramatic sea cliffs, a historic lighthouse, and forested coastal paths on Yeongdo island — easily reached from central Busan.","desc":"태종대 (Taejongdae) is a large coastal park on Yeongdo island, southwest of Busan. The dramatic sea cliffs (up to 20m high), forested trails, and the 1906 Yeongdo Lighthouse make it one of Busan's best natural spots. Navigate the large park via the Danubi Train (다누비 열차) — a small diesel tram — which stops at the main viewpoints. The rocky coastal viewpoint faces open ocean toward Japan.","highlights":["Dramatic sea cliff viewpoints","Yeongdo Lighthouse (1906) — free entry","Danubi Train navigates the park","Dense forest walking trails","Views toward Tsushima Island (Japan)"],"tips":"The Danubi Train runs a loop (~40 min full circuit) with stops — you can get on/off at viewpoints. It doesn't run on Mondays or in heavy rain. Park entry is free. Take Bus 8 or 30 from Busan Station.","hours":"Park: daily. Danubi Train: 9am – 6pm (not Mondays)","address":"Yeongdo-gu, Busan","interest":["culture","thrills"],"indoor":false,"onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/태종대/"},

  {"id":"a-haedong-yonggungsa","neighbourhood":"gijang","cat":"culture","name":"Haedong Yonggungsa Temple (해동 용궁사)","emoji":"🛕","gradient":"linear-gradient(135deg,#0d3349,#f0b27a)","region":"busan","cost":"Free","costZAR":"Free","duration":"1.5 hrs","teaser":"One of Korea's only oceanfront Buddhist temples — perched on dramatic coastal cliffs facing the East Sea, stunning at sunrise.","desc":"해동 용궁사 (Haedong Yonggungsa) is extraordinary: a fully active Buddhist temple built directly onto coastal cliffs above the East Sea in Gijang-gun, northeast Busan. The approach down 108 steps (symbolising the 108 earthly desires) through zodiac animal statues, a golden pig rub-for-luck statue, and the cliff-side pagodas creates a dramatic atmosphere unlike any inland temple. The ocean crashes against the rocks below. Traditionally considered a place of wish-granting.","highlights":["Temple perched on ocean cliffs","108 Steps descent through zodiac statues","Golden pig — rub for good luck","Coastal pagoda with crashing waves below","Best at sunrise (5–7am) — fewest people"],"tips":"Sunrise visits are transformative and nearly empty. Regular daytime visits (10am–2pm) get very crowded with tour groups. Take Bus 181 from Haeundae Beach (~30 min) or Bus 189 from Busan Station. No entry fee — donations only.","hours":"4:30am – 7:00pm","address":"Gijang-gun, Busan (northeast coast)","interest":["culture"],"indoor":false,"onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.yonggungsa.org"},

  {"id":"a-jeonpo-cafe-street","neighbourhood":"seomyeon","cat":"family-fun","name":"Jeonpo Café Street (전포 카페거리)","emoji":"☕","gradient":"linear-gradient(135deg,#3b2314,#c8963e)","region":"busan","cost":"₩6,000–14,000 per drink","costZAR":"≈ R65–151","duration":"2 hrs","teaser":"Busan's hippest café district — a former hardware street transformed into a dense, creative cluster of independent coffee shops.","desc":"전포 카페거리 (Jeonpo Café Street, near Seomyeon, Busanjin-gu) is Busan's answer to Seoul's Seongsu: a formerly gritty hardware district that's been transformed into one of the country's most concentrated café strips. Dozens of independent cafés, brunch spots, design studios, and boutiques — each with its own aesthetic identity. Ideal for a slow morning or afternoon of café-hopping with no agenda.","highlights":["20+ independent cafés within walking distance","Wide variety of concepts: industrial, retro, minimalist","Brunch menus in several cafés","No tourist traps — neighbourhood vibe","Connects to Seomyeon subway hub"],"tips":"Go on a weekday morning for the most relaxed experience. The street evolves constantly — check Instagram for the newest spots. Starts around Jeonpo Station (Line 2) and extends down the alley. Walk slowly, look for small signage.","hours":"Most open 10am – 9pm","address":"Jeonpo-dong, Busanjin-gu, Busan (near Jeonpo Station, Line 2)","interest":["foodie","fashion"],"indoor":true,"onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/전포카페거리/"},

  {"id":"a-theclimb","neighbourhood":"hongdae","cat":"family-fun","name":"The Climb Bouldering Gym (Hongdae)","emoji":"🧗","gradient":"linear-gradient(135deg,#1f3a60,#2980b9)","region":"seoul1","cost":"₩22,000 day pass","costZAR":"≈ R238","duration":"2 hrs","teaser":"Seoul's premier bouldering gym — high-spec walls popular with local climber youth.","desc":"The Climb (더클림) is Korea's largest bouldering chain. High-spec bouldering walls, routes from beginner to expert, rental gear, foot-washing stations, and lockers. A great active local experience.","highlights":["Massive bouldering area","Rental shoes available","Foot-washing stations","Local climber community hub"],"tips":"Sign safety waiver (English available). Wear athletic clothes. Go weekday mornings to avoid evening crowds.","hours":"10am – 11pm daily","address":"Hongdae area, Mapo-gu, Seoul","interest":["thrills"],"indoor":true,"onItinerary":false,"needsBooking":false,"mapLink":"https://naver.me/","link":"https://theclimb.co.kr"},

  {"id":"a-mountaingym","neighbourhood":"myeongdong","cat":"culture","name":"Namsan Mountain Outdoor Gym","emoji":"🏋️","gradient":"linear-gradient(135deg,#2e7d32,#7f8c8d)","region":"seoul1","cost":"Free","costZAR":"Free","duration":"1 hr","teaser":"Korea's famous outdoor 'mountain gym' — heavy weights and rusty bars in Namsan forest.","desc":"A public outdoor weightlifting gym on Namsan Mountain. Older residents and hikers work out with heavy dumbbells surrounded by pine trees. A unique local slice-of-life.","highlights":["Outdoor weightlifting gym","Barbells, pull-up bars","Surrounded by forest trails","Popular with local elders"],"tips":"Free. Respect elders. Pair with Namsan hike. Bring water.","hours":"24/7","address":"Namsan Mountain Trail, Jung-gu, Seoul","interest":["culture"],"indoor":false,"onItinerary":false,"needsBooking":false,"mapLink":"","link":""}
];

const TD_SHOPPING = [
  {"id": "s-oy-myeong", "neighbourhood": "myeongdong", "cat": "beauty", "name": "Olive Young — Myeongdong Town Flagship", "emoji": "🌿", "gradient": "linear-gradient(135deg,#27ae60,#1e8449)", "region": "seoul1", "cost": "₩5,000–150,000+", "costZAR": "≈ R54–1,622", "duration": "1–2 hrs", "teaser": "The undisputed king of Korean beauty — two-floor flagship in the heart of Myeongdong.", "desc": "Olive Young (올리브영) is the national multi-brand beauty chain — Korea's equivalent of Sephora but bigger, fresher, and cheaper. The Myeongdong Town flagship is a 2-floor store with every major Korean skincare, haircare, and makeup brand (COSRX, Beauty of Joseon, Torriden, Laneige, Etude House, Mixsoon). English staff and tax refund kiosks on site.", "highlights": ["Skincare — COSRX, Beauty of Joseon, Torr iden", "Haircare — Ryo, Mise-en-scène", "Makeup — ROM&ND, CLIO, Etude House", "Health supplements and snack beauty crossovers", "Free samples at most counters + QR tax refund"], "tips": "Reddit travel community recommends stocking up on COSRX, Torriden, Beauty of Joseon, and Rom&nd. Bring your passport for an immediate tax refund on purchases over ₩15,000. Go before 11am or after 7pm to avoid long lines.", "hours": "10am – 10pm daily", "address": "Myeongdong 2-ga, Jung-gu, Seoul (main pedestrian street)", "mapLink": "https://naver.me/", "link": "https://global.oliveyoung.com", "interest": ["fashion"], "indoor": true, "logo": "https://upload.wikimedia.org/wikipedia/commons/0/0c/Olive_Young_Logo.svg"},

  {"id": "s-oy-hong", "neighbourhood": "hongdae", "cat": "beauty", "name": "Olive Young — Hongdae Flagship", "emoji": "🌱", "gradient": "linear-gradient(135deg,#1e8449,#52c41a)", "region": "seoul1", "cost": "₩5,000–100,000+", "costZAR": "≈ R54–1,080", "duration": "1 hr", "teaser": "High-tech, sleek Olive Young in the heart of the youth fashion district.", "desc": "The Hongdae Olive Young has a younger, more trend-forward product mix than Myeongdong — more indie brands, experimental skincare, and hair colour products. Less crowded than Myeongdong and closer to your Ahyeon accommodation (one subway stop). An excellent stop after Hongdae busking or shopping.", "highlights": ["Indie skincare brands — ISNTREE, Klairs, SKIN1004", "Color cosmetics — heavy on Gen-Z trends", "Nail products — nail art sets", "Hair care — extensive range", "Hygienic one-use makeup testers"], "tips": "Gen-Z focused branch with more indie and niche brands. Check the weekly rotating 1+1 offers and 50% off flyers (올영세일).", "hours": "10am – 10:30pm daily", "address": "Hongdae area, Mapo-gu, Seoul", "mapLink": "", "link": "https://global.oliveyoung.com", "interest": ["fashion"], "indoor": true, "logo": "https://upload.wikimedia.org/wikipedia/commons/0/0c/Olive_Young_Logo.svg"},

  {"id": "s-innisfree", "neighbourhood": "myeongdong", "cat": "beauty", "name": "Innisfree Flagship (이니스프리)", "emoji": "🍃", "gradient": "linear-gradient(135deg,#2d5016,#52c41a)", "region": "seoul1", "cost": "₩5,000–80,000", "costZAR": "≈ R54–865", "duration": "45 min", "teaser": "Jeju Island-inspired eco-beauty from Korea's most popular natural brand.", "desc": "Innisfree is Korea's flagship natural beauty brand, sourcing ingredients from Jeju Island (volcanic water, green tea, camellia oil). The flagships in Myeongdong and Hongdae are beautifully designed spaces. Their Green Tea Seed Serum, Perfect UV Protection SPF50, and No Sebum Mineral Powder are globally renowned.", "highlights": ["Green Tea Seed Serum — the #1 bestseller", "No Sebum Mineral Powder — cult status", "Jeju Volcanic Pore Clay Mask", "Camellia Oil Serum for hair", "Exclusive travel sets only in flagship"], "tips": "Best natural beauty products sourced from Jeju Island. The Green Tea Seed Serum and No Sebum Mineral Powder are cult favorites. Jeju cafe on site.", "hours": "10am – 10pm daily", "address": "Myeongdong and Hongdae, Seoul", "mapLink": "", "link": "https://www.innisfree.com", "interest": ["fashion"], "indoor": true, "logo": "https://upload.wikimedia.org/wikipedia/commons/4/45/Innisfree-logo.svg"},

  {"id":"s-kbeauty-clinic","neighbourhood":"apgujeong","cat":"beauty","name":"Gangnam K-Beauty Skin Treatment Clinic","emoji":"💉","gradient":"linear-gradient(135deg,#b04a8a,#8e44ad)","region":"seoul2","cost":"₩80,000–250,000","costZAR":"≈ R865–2,700","duration":"1.5–2 hrs","teaser":"Professional skin treatments in Gangnam — the world's cosmetic dermatology capital.","desc":"Gangnam is globally famous for its density of dermatology clinics and aesthetic medicine. For skin treatments: BB glow facial, hydrafacial, LED light therapy, chemical peels, and Botox are all available walk-in or same-day in many clinics. Prices are dramatically cheaper than South Africa. Many clinics have English-speaking consultants.","highlights":["BB Glow facial treatment — ₩80–120k","Hydrafacial deep clean — ₩120–180k","LED light therapy session","Aqua peel + brightening shot combo","Dr. Young and Jaen Clinic both English-friendly"],"tips":"Walk in to any clinic on Garosu-gil or near Apgujeong station and ask for an English consultation — most will accommodate. Expect no more than 15 minute wait. Results are impressive in 24hrs. Avoid sun immediately after.","hours":"By appointment / walk-in, Mon–Sat 10am–7pm","address":"Gangnam-gu, Seoul (Garosu-gil, Apgujeong area)","mapLink":"","link":"https://enyaanclinic.com/","interest":["fashion"],"indoor":true,"expensive":true,"logo":"images/eyaan_logo.webp"},

  {"id":"s-hongdaevintage","neighbourhood":"hongdae","cat":"fashion","name":"Hongdae Vintage Alley — Overview","emoji":"🧥","gradient":"linear-gradient(135deg,#4a4a8a,#6c3483)","region":"seoul1","cost":"₩15,000–100,000+","costZAR":"≈ R162–1,080","duration":"2–3 hrs","teaser":"Seoul's best cluster of vintage and thrift stores — all within a few blocks of each other.","desc":"The Hongdae area (Mapo-gu) contains Seoul's densest cluster of curated vintage and secondhand fashion stores. The main ones to target: Vintage Santa (basement megastore), Page One (premium curated), Omnipeople (Americana + workwear), and Beautiful Store (charity thrift). Most are within 5–10 minutes walk of each other.","highlights":["Vintage Santa — massive basement store","Page One Vintage — premium curated coats & jackets","Omnipeople Trend — Americana workwear, graphic tees","Beautiful Store (아름다운가게) — charity thrift","Hit 3–4 stores in one afternoon"],"tips":"Weekday afternoons are less crowded. Vintage Santa has the most volume but requires digging. Page One has better curation but higher prices. Omnipeople is excellent for men's collegiate and workwear. All take card.","hours":"Most: noon – 9pm (Mon–Sun)","address":"Hongdae area, Mapo-gu, Seoul","mapLink":"","link":"https://www.instagram.com/explore/tags/홍대빈티지/","interest":["fashion"],"indoor":true},

  {"id":"s-vintagesanta","neighbourhood":"hongdae","cat":"fashion","name":"Vintage Santa (빈티지산타)","emoji":"🎿","gradient":"linear-gradient(135deg,#c0392b,#4a4a8a)","region":"seoul1","cost":"₩10,000–80,000","costZAR":"≈ R108–865","duration":"1 hr","teaser":"A massive underground vintage megastore — hoodies, flight jackets, 90s sneakers, retro streetwear.","desc":"Vintage Santa is the volume king of Hongdae vintage — a basement store packed floor-to-ceiling with secondhand clothing from Japan, the USA, and Europe. Military jackets, Levi's denim, college hoodies, vintage Nikes and Adidas. The selection changes daily as new stock arrives. Prices are honest and haggling is sometimes possible.","highlights":["Military field jackets — ₩25–60k","Vintage Levi's 501 denim — ₩30–80k","College sweatshirts — ₩15–40k","Vintage sneakers (Nike, Adidas, New Balance)","New stock arrives mid-week"],"tips":"Go on a weekday — new stock typically hits Wednesday–Thursday. Bring cash as a backup (card is accepted but machines sometimes fail). The basement layout can feel overwhelming — give yourself 45 minutes to properly dig. Staff are friendly even with limited English.","hours":"1pm – 10pm (Mon–Sun)","address":"Hongdae area, Mapo-gu (near Hongik University station)","mapLink":"https://www.cdbd.in/vintagesanta1029/vsh","link":"https://www.cdbd.in/vintagesanta1029/vsh","interest":["fashion"],"indoor":true,"logo":"images/vintagesanta_logo.png"},

  {"id":"s-ewha","neighbourhood":"hongdae","cat":"fashion","name":"Ewha University Shopping Streets (이화여대)","emoji":"🛍️","gradient":"linear-gradient(135deg,#b04a8a,#4a4a8a)","region":"seoul1","cost":"₩5,000–80,000","costZAR":"≈ R54–865","duration":"2 hrs","teaser":"Student fashion heaven — affordable boutiques, cosmetics, and cafés just 10 minutes from Ahyeon.","desc":"The streets surrounding Ewha Womans University (이화여자대학교) in Sinchon are one of Seoul's best areas for affordable student fashion. Boutiques selling trendy but cheap clothing, independent cosmetic shops, Korean hair accessory stores, and dozens of cafés fill every alley. Very close to your Ahyeon accommodation.","highlights":["Boutique clothing from ₩15k","Hair accessories and headbands","Independent cosmetic shops","Street snacks along the main avenue","Ewha campus architecture is also beautiful"],"tips":"Visit on a Tuesday–Thursday afternoon when university students are around and stock is freshest. The main Ewha shopping street runs from the subway exit toward the university gate. Prices are negotiable at smaller standalone boutiques (not chains).","hours":"Most shops: 11am – 9pm daily","address":"Sinchon / Ewha area, Mapo-gu, Seoul","mapLink":"","link":"https://www.instagram.com/explore/tags/이화여대/","interest":["fashion"],"indoor":false},

  {"id":"s-dongdaemun","neighbourhood":"dongdaemun","cat":"fashion","name":"Dongdaemun Fashion District (24-Hour)","emoji":"🌙","gradient":"linear-gradient(135deg,#16213e,#e74c3c)","region":"seoul1","cost":"₩10,000–100,000+","costZAR":"≈ R108–1,080","duration":"2–4 hrs","teaser":"The city that never sleeps for fashion — wholesale markets and retail towers open until 5am.","desc":"Dongdaemun is the world's most prolific fashion district, producing and selling more garments per night than almost anywhere on Earth. The wholesale markets (Dongdaemun Market, Pyeonghwa Market) open at 8pm and run till 5am. For retail, Doota Mall, Migliore, and Hello apM are open from noon. The DDP (Zaha Hadid building) is next door for a contrast.","highlights":["Wholesale markets: 8pm – 5am (min orders apply)","Doota Mall — multi-floor retail fashion tower","Hello apM — youth streetwear, closes 5am","Fabric and accessories market in the basement","DDP Zaha Hadid building — photo stop"],"tips":"The wholesale markets technically require minimum quantities (12 pcs/style) but individual tourists can sometimes buy single items — ask politely. The retail malls (Doota, Hello apM) have no minimum. Great for late-night fashion hunting after 10pm.","hours":"Retail: noon – 5am. Wholesale: 8pm – 5am","address":"Dongdaemun-gu, Seoul (Dongdaemun History & Culture Park station)","mapLink":"","link":"https://www.instagram.com/explore/tags/동대문/","interest":["fashion"],"indoor":true},

  {"id":"s-gukjevintage","neighbourhood":"busan-nampo","cat":"fashion","name":"Gukje Market Vintage Alley (국제시장)","emoji":"🎽","gradient":"linear-gradient(135deg,#3a6b8a,#4a4a8a)","region":"busan","cost":"₩2,000–20,000","costZAR":"≈ R22–216","duration":"1–2 hrs","teaser":"Busan's legendary vintage alley — piles of secondhand clothing at bargain-bin prices.","desc":"Gukje Market in Nampo-dong, Busan contains an alley of secondhand clothing vendors where garments are piled high on tables. The system is simple: dig through the pile, find something you like, negotiate a price (usually ₩2,000–10,000 per piece). Stock is genuinely mixed — a combination of mass imports and genuine vintage finds.","highlights":["Piled table system — dig for gems","Prices from ₩2k per piece","Curated vintage stores on the same street","Goyu Vintage and Cut-a-dash for better curation","Adjacent Gukje Market for household goods"],"tips":"Go with patience and low expectations — you might find something incredible or nothing. The curated stores (Goyu Vintage, Cut-a-dash) on the same Gwangbok-ro strip offer better quality at higher prices. Combine with Jagalchi Market fish market and BIFF Square hotteok.","hours":"10am – 8pm (most vendors)","address":"Nampo-dong, Jung-gu, Busan (near BIFF Square)","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/국제시장/","interest":["fashion"],"indoor":true},

  {"id": "s-daiso", "cat": "unique", "name": "Daiso (다이소) — Korea's ₩1,000 Store", "emoji": "🎁", "gradient": "linear-gradient(135deg,#e74c3c,#f1c40f)", "region": "any", "cost": "₩1,000–5,000", "costZAR": "≈ R11–54", "duration": "45 min", "teaser": "Korea's beloved discount store — insanely good value for travel supplies, gifts, and unique finds.", "desc": "Daiso is Japan-inspired but uniquely Korean — a discount store where most items are ₩1,000–5,000 and the quality is often surprisingly high. Essentials for tourists: compact umbrellas (₩3k), rechargeable fans, travel-size organizers, Korean skincare samples, cute stationery, phone accessories. An essential stop for cheap souvenirs.", "highlights": ["Rechargeable portable fan — ₩5k (essential for July heat)", "Compact umbrella (₩3k)", "Korean-themed stationery and gifts", "Makeup organizers and travel bottles", "Seasonal items — currently summer specials"], "tips": "Incredible value discount store. Highly recommended on Reddit for portable neck fans, compact umbrellas, travel organizers, and VT Reedle Shot skincare samples.", "hours": "9am – 10pm daily", "address": "Myeongdong (flagship, 7 floors), Hongdae, everywhere", "mapLink": "", "link": "https://www.daisomall.co.kr", "interest": [], "indoor": true, "logo": "https://upload.wikimedia.org/wikipedia/commons/3/35/DAISO_logo.png"},

  {"id": "s-artbox", "cat": "unique", "name": "Artbox (아트박스)", "emoji": "✏️", "gradient": "linear-gradient(135deg,#f39c12,#e74c3c)", "region": "any", "cost": "₩1,000–30,000", "costZAR": "≈ R11–324", "duration": "45 min", "teaser": "Korea's beloved stationery and lifestyle brand — characters, kawaii, design objects, and gifts.", "desc": "Artbox is the Korean stationery and design lifestyle brand with beautifully designed goods at low prices: notebooks, planners, pens, phone cases, mugs, figurines, and character merchandise. It's bright, cheerful, and overwhelming in the best way. The flagship in Hongdae is the mothership; branches in most malls.", "highlights": ["Character notebooks + planners — ₩4–15k", "Korean mascot character merchandise", "Acrylic desk organizers", "Polaroid-style photo accessories", "Seasonal gift boxes"], "tips": "The ultimate stationery and cute character merchandise shop. Excellent place for flat-packable gifts and cute notebooks.", "hours": "11am – 10pm daily", "address": "Hongdae (flagship), Myeongdong, Sinchon", "mapLink": "", "link": "https://www.artbox.co.kr", "interest": [], "indoor": true, "logo": "https://www.artbox.co.kr/fo/images/common/logo_poom_126x47.png"},

  {"id":"s-ssamziegil","cat":"unique","name":"Insadong Ssamziegil (인사동 쌈지길)","emoji":"🏮","gradient":"linear-gradient(135deg,#c8963e,#8e44ad)","region":"seoul1","cost":"₩2,000–50,000","costZAR":"≈ R22–540","duration":"1.5 hrs","teaser":"A spiral open-air courtyard of indie galleries, craft shops, and artisanal Korean goods.","desc":"Ssamziegil in Insadong is a stunning open courtyard mall where independent artists and craftspeople sell handmade ceramics, traditional hanji paper goods, prints, wooden crafts, and traditional tea. The architecture spirals upward around a courtyard. Also home to Café Bora (Instagrammable purple matcha). The best place in Seoul for authentic, non-mass-produced souvenirs.","highlights":["Handmade ceramics and pottery","Hanji (한지) traditional paper goods","Calligraphy prints and artwork","Traditional tea set souvenirs","Café Bora purple soft-serve is here"],"tips":"This is the place for meaningful gifts to take back to South Africa — quality handmade Korean crafts, not cheap mass-produced trinkets. The courtyard itself is beautiful to walk even if you don't buy anything. Combine with a walk through Insadong's main street for tea houses and street food.","hours":"10am – 8:30pm daily","address":"Insadong-gil, Insadong, Jongno-gu, Seoul","mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/쌈지길/","interest":["culture","fashion"],"indoor":false},

  {"id": "s-coex", "cat": "unique", "name": "COEX Underground Mall", "emoji": "🏙️", "gradient": "linear-gradient(135deg,#2c3e50,#3498db)", "region": "seoul2", "cost": "Varies by store", "costZAR": "Varies", "duration": "2–4 hrs", "teaser": "Asia's largest underground shopping mall — 300+ shops, cinema, Starfield Library, and aquarium.", "desc": "COEX (Convention and Exhibition) contains a massive underground shopping city in Gangnam with 300+ shops across multiple zones. It includes the famous Starfield Library (free), COEX Aquarium, multiple food courts, a CGV cinema, and brand outlets. Completely weatherproof — the perfect monsoon day plan. Connected via underground passage to Bongeunsa Temple.", "highlights": ["Starfield Library — free, stunning", "COEX Aquarium — 40,000 marine creatures", "CGV Cinema — all formats including ScreenX", "Major retail stores: H&M, Zara, Adidas", "Extensive food court with Korean + international"], "tips": "Huge underground mall in Gangnam. Houses the stunning Starfield Library, CGV cinema, and COEX Aquarium. Perfect rainy day hideout.", "hours": "Mall: 10:30am – 10pm. Some restaurants later", "address": "Samseong-dong, Gangnam-gu, Seoul", "mapLink": "https://naver.me/", "link": "https://www.starfield.co.kr/coexmall/", "interest": [], "indoor": true, "logo": "https://upload.wikimedia.org/wikipedia/commons/a/a3/CGV_logo.svg"},

  {"id": "s-f1963books", "cat": "unique", "name": "Yes24 Secondhand Bookshop at F1963 (Busan)", "emoji": "📖", "gradient": "linear-gradient(135deg,#3e2723,#6d4c41)", "region": "busan", "cost": "₩1,000–20,000", "costZAR": "≈ R11–216", "duration": "1 hr", "teaser": "A beautiful secondhand bookshop inside Busan's converted wire factory cultural complex.", "desc": "Inside F1963 (the famous converted wire factory in Suyeong-gu, Busan), Yes24 operates a large secondhand bookshop in a beautiful warehouse space with exposed brick and high ceilings. Mostly Korean-language books, but a good English section exists. The real draw is the atmosphere — browsing old books in a light-filled industrial space beside Terarosa cafe.", "highlights": ["Secondhand Korean books from ₩1k", "English language section", "Design and art books in good condition", "Beautiful industrial warehouse setting", "Terarosa specialty coffee next door"], "tips": "A spacious, light-filled secondhand bookshop inside a converted wire factory next to Terarosa cafe in Busan. Great atmosphere for reading.", "hours": "10am – 9pm daily", "address": "F1963, 20 Gurak-ro 123beon-gil, Suyeong-gu, Busan", "mapLink": "http://www.f1963.org", "link": "http://www.f1963.org", "interest": ["culture"], "indoor": true, "logo": "https://image.yes24.com/sysimage/renew/header/logo_yes24.png"},

  {"id": "s-lotteduty", "cat": "unique", "name": "Lotte Duty Free / Shinsegae Department Store", "emoji": "🏬", "gradient": "linear-gradient(135deg,#c8963e,#1a3a5a)", "region": "seoul1", "cost": "Varies — premium brands", "costZAR": "Varies", "duration": "1–2 hrs", "teaser": "Tax-free premium shopping for international travellers — Korean luxury at significant discounts.", "desc": "Lotte Duty Free (Myeongdong) and Shinsegae Department Store (Myeongdong) offer international brands at duty-free prices for departure — you pick up purchases at the airport. Korean cosmetics brands in duty free are particularly good value (Sulwhasoo, History of Whoo, The History of Joseon). Shinsegae B2 basement food hall is also one of Seoul's best.", "highlights": ["Sulwhasoo — premium Korean beauty (duty-free)", "Korean whisky + soju sets", "K-pop merchandise at some branches", "Shinsegae B2 food hall — exceptional", "Tax refund on general shopping ₩15k+ with passport"], "tips": "Perfect for buying premium luxury skincare like Sulwhasoo at tax-free prices. Purchase in-store with passport and boarding pass, collect at airport.", "hours": "Lotte Duty Free: 9:30am – 9pm. Shinsegae: 10:30am – 8pm", "address": "Myeongdong, Jung-gu, Seoul", "mapLink": "", "link": "https://eng.lottedutyfree.com", "interest": ["fashion"], "indoor": true, "logo": "https://upload.wikimedia.org/wikipedia/commons/b/bb/Lotte_Logo_%282017%29.svg"},

  {"id":"s-kpop","neighbourhood":"myeongdong","cat":"unique","name":"K-Pop Merch Run (Myeongdong / Hongdae)","emoji":"🎤","gradient":"linear-gradient(135deg,#6c3483,#d2b4de)","region":"any","cost":"₩10,000–60,000","costZAR":"≈ R108–650","duration":"1 hr","teaser":"Official albums, photocards, and lightsticks at the multi-floor flagship merch stores.","desc":"Multi-floor official K-pop retail: albums, lightsticks, photocards, and exclusive merch. The Myeongdong Underground Shopping Center has the widest album + photocard selection at fair prices; Hongdae's flagship stores (and the Line Friends / BT21 shops) cover the rest. Music Korea and Synnara are the trusted official outlets.","highlights":["Albums with store-exclusive photocards","Official lightsticks","Myeongdong Underground Center — best prices","Line Friends / BT21 flagship (Hongdae)","Tax refund over ₩15,000 with passport"],"tips":"Buy albums from official retailers (Music Korea, Synnara) so purchases count toward charts. The underground arcade at Myeongdong station is cheaper than street-level tourist shops.","hours":"Most stores 10am – 10pm","address":"Myeongdong & Hongdae, Seoul","interest":["fashion"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/kpopmerch/"},

  {"id":"s-namdaemun","neighbourhood":"myeongdong","cat":"unique","name":"Namdaemun Market Souvenir Run","emoji":"🛍️","gradient":"linear-gradient(135deg,#9c640c,#f8c471)","region":"seoul2","cost":"₩2,000–30,000","costZAR":"≈ R22–325","duration":"2 hrs","teaser":"Seoul's biggest traditional market — wholesale prices on tableware, ginseng, socks, and souvenirs.","desc":"Korea's largest traditional market (600+ years old) is the smart place for gifts: metal chopstick sets, Hanji paper goods, ginseng products, character socks by the dozen, and kitchenware at wholesale prices. The hotteok and kalguksu alleys keep you fed while you haggle.","highlights":["Metal chopstick + spoon gift sets","Korean socks — ₩1,000 each","Ginseng & honey products","Kitchenware alley (brassware, stoneware)","Kalguksu + hotteok alleys for lunch"],"tips":"Gentle haggling is expected for multiples (\"Discount if I buy five?\"). Most stalls close by early evening and many close Sundays — go on a weekday morning.","hours":"Most stalls 9am – 6pm (many closed Sun)","address":"Namdaemun-ro, Jung-gu, Seoul","interest":["culture","foodie"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/namdaemunmarket/"},

  {"id":"s-seongsu","neighbourhood":"seongsu","cat":"unique","name":"Seongsu Salt Bread & Silver Shopping","emoji":"🥨","gradient":"linear-gradient(135deg,#7d6608,#f7dc6f)","region":"seoul1","cost":"₩3,000–30,000","costZAR":"≈ R32–325","duration":"1–2 hrs","teaser":"Seoul's coolest district: warm sogeum-ppang bakeries between minimalist silver jewellery ateliers.","desc":"Seongsu-dong — converted warehouses, sneaker flagships, and two local obsessions: sogeum-ppang (salt bread: buttery, flaky rolls with crunchy salt) from specialist bakeries, and independent silver jewellery studios where pieces start around ₩20,000. Browse, snack, repeat.","highlights":["Salt bread fresh from the oven","Independent silver ateliers","Warehouse-conversion flagship stores","Pop-up culture — something new weekly","Pairs with Noah Cityhouse café"],"tips":"Salt bread is best within an hour of baking — follow the butter smell. Many jewellery studios do same-day engraving. Weekday afternoons beat weekend crowds.","hours":"Most shops 11am – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion","foodie"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/seongsudong/"},

  {"id":"s-hannam","neighbourhood":"hannam","cat":"fashion","name":"Hannam-dong Boutiques & Fragrance Houses","emoji":"👜","gradient":"linear-gradient(135deg,#283747,#85929e)","region":"seoul1","cost":"Varies","costZAR":"","duration":"2 hrs","teaser":"Seoul's quiet-luxury hill: niche perfume houses, minimalist designers, and hidden concept stores.","desc":"Hannam-dong is where Seoul's fashion insiders actually shop: Tamburins and Nonfiction perfume flagships, minimalist Korean designers, curated vintage, and concept stores tucked into hillside streets. Less flashy than Apgujeong, far more interesting — and Leeum Museum anchors the same neighbourhood.","highlights":["Nonfiction + Tamburins fragrance flagships","Korean minimalist designer boutiques","Concept stores & curated vintage","Leeum Museum in the same district","Quiet café courtyards between shops"],"tips":"Start at Hangangjin station exit 3 and wander downhill. Fragrance houses give generous testers — decide over a coffee before committing. Most shops open ~11am.","hours":"Most boutiques 11am – 8pm","address":"Hannam-dong, Yongsan-gu, Seoul","interest":["fashion"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/한남동/"},

  {"id": "s-dosan", "neighbourhood": "apgujeong", "cat": "fashion", "name": "Dosan Park & Apgujeong Luxury Crawl", "emoji": "🕶️", "gradient": "linear-gradient(135deg,#1c2833,#aeb6bf)", "region": "seoul2", "cost": "Varies — premium", "costZAR": "", "duration": "2 hrs", "teaser": "Streetwear flagships, designer boutiques, and the prettiest retail architecture in Gangnam.", "desc": "The blocks around Dosan Park hold Seoul's most photogenic retail: Ader Error, Gentle Monster's Haus Dosan (part store, part art installation), multi-brand boutiques, and dessert cafés engineered for Instagram. Even committed non-shoppers enjoy this as an architecture walk.", "highlights": ["Haus Dosan — Gentle Monster / Tamburins / Nudake", "Ader Error flagship", "Multi-brand boutiques (BOON THE SHOP)", "Nudake — the dramatic dessert café", "Dosan Park itself for a breather"], "tips": "Gentle Monster's multi-floor concept store combining futuristic eyewear showrooms, kinetic art exhibitions, Tamburins, and Nudake café.", "hours": "Most stores 11am – 8pm", "address": "Dosan Park, Apgujeong, Gangnam-gu, Seoul", "interest": ["fashion"], "indoor": true, "expensive": true, "mapLink": "https://naver.me/", "link": "https://www.gentlemonster.com", "logo": "https://upload.wikimedia.org/wikipedia/commons/b/b3/GENTLE_MONSTER_Logo_New_2.svg"},

  {"id": "s-tamburins", "neighbourhood": "apgujeong", "cat": "beauty", "name": "Tamburins Flagship — Haus Dosan", "emoji": "🌷", "gradient": "linear-gradient(135deg,#5b2c6f,#d2b4de)", "region": "seoul2", "cost": "₩20,000–90,000", "costZAR": "≈ R215–970", "duration": "1 hr", "teaser": "Korea's artiest fragrance brand — kinetic installations and cult hand creams.", "desc": "Tamburins sits at the intersection of perfume and gallery: sculptural flagship spaces, kinetic art installations, and the cult shell-shaped hand creams and \"egg\" perfume balms that K-celebrities made famous. The Dosan flagship inside Haus Dosan is the one to see.", "highlights": ["Shell hand creams — the cult item", "Egg perfume balms", "Full fragrance line with testers", "Kinetic art installations", "Gift-wrapping is exceptional"], "tips": "Aesthetic high-end fragrance brand owned by Gentle Monster. The shell-shaped hand creams and solid perfume eggs are cult favorites. Incredible artistic space.", "hours": "11am – 8pm daily", "address": "Haus Dosan, Apgujeong, Gangnam-gu, Seoul", "interest": ["fashion"], "indoor": true, "expensive": true, "mapLink": "https://naver.me/", "link": "https://www.tamburins.com", "logo": "https://logo.clearbit.com/tamburins.com"},

  {"id":"s-hwangridan","neighbourhood":"gyeongju","cat":"unique","name":"Hwangridan-gil Hanok Street (Gyeongju)","emoji":"🏮","gradient":"linear-gradient(135deg,#6e2c00,#edbb99)","region":"busan","cost":"Free to browse","costZAR":"","duration":"2–3 hrs","teaser":"Gyeongju's trendiest street — hanok cafés, craft shops, and photo booths beside ancient royal tombs.","desc":"On the Gyeongju day trip, Hwangridan-gil is the lunch-and-browse anchor: a street of preserved hanok houses converted into chic cafés, craft boutiques, dessert shops, and retro photo studios — all in the shadow of the giant Daereungwon royal tomb mounds. Rent a hanbok here too if you skipped Seoul.","highlights":["Hanok cafés & dessert shops","Craft + souvenir boutiques","Daereungwon tomb mounds next door","Retro photo studios","10-cheong bread (Gyeongju bread) shops"],"tips":"Buy Gyeongju's famous red-bean \"Hwangnam bread\" here — boxes travel well. Streets get busy after 1pm; arrive before noon for lunch without queues.","hours":"Most shops 11am – 9pm","address":"Hwangnam-dong, Gyeongju (day trip from Busan)","interest":["culture","fashion"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/황리단길/"},

  {"id": "s-anderson-bell", "neighbourhood": "seongsu", "cat": "fashion", "name": "Anderson Bell — Seoul (앤더슨벨)", "emoji": "🧥", "gradient": "linear-gradient(135deg,#1a1a2e,#3498db)", "region": "seoul1", "cost": "₩80,000–400,000+", "costZAR": "≈ R865–4,320", "duration": "1 hr", "teaser": "The Korean menswear and womenswear brand that went global — sharp tailoring meets athletic-inspired design.", "desc": "Anderson Bell is one of Korea's best-known contemporary fashion exports — a Seoul-based label mixing athletic and tailored references with a distinctive graphic identity. The brand has dressed K-pop artists and been stocked at Ssense and Dover Street Market internationally. The Seoul flagship is the place to see the full collection in person.", "highlights": ["Menswear and womenswear collections", "Athletic-tailored hybrid pieces", "Graphic logo pieces and outerwear", "Seoul flagship full collection", "Stocked internationally at SSENSE, DSM"], "tips": "High-end contemporary Korean streetwear label blending sharp Scandinavian tailoring with street culture. Highly sought after globally.", "hours": "11am – 8pm (check for closed days)", "address": "Seongsu or Hongdae, Seoul (check current flagship location)", "interest": ["fashion"], "indoor": true, "expensive": true, "mapLink": "https://naver.me/", "link": "https://anderssonbell.com", "logo": "https://anderssonbell.com/enm/images/logo.png"},

  {"id": "s-wooyoungmi", "neighbourhood": "apgujeong", "cat": "fashion", "name": "Wooyoungmi — Seoul", "emoji": "👔", "gradient": "linear-gradient(135deg,#1c1c2e,#85929e)", "region": "seoul2", "cost": "₩150,000–800,000+", "costZAR": "≈ R1,620–8,640", "duration": "1 hr", "teaser": "Korea's most respected tailoring house — heritage menswear with precision, restraint, and unmistakable quality.", "desc": "Wooyoungmi is South Korea's most internationally acclaimed menswear designer — a house built on precision tailoring, elevated fabrics, and a quiet confidence that doesn't need logos. The Seoul flagship in Gangnam presents the full collection across seasonal lookbooks. If you have a budget for one Korean fashion purchase, this is the house to take seriously.", "highlights": ["Precision tailored suits and outerwear", "Elevated fabrics — wool, cotton, silk", "Full seasonal collection in flagship", "Women's line (Wooyoungmi Woman) also available", "Internationally stocked — exclusive pieces in Seoul"], "tips": "Korea's premier luxury menswear tailoring house. Famous for oversized architectural cuts and precision details. Quiet luxury at its finest.", "hours": "11am – 8pm (Mon–Sat)", "address": "Gangnam-gu, Seoul (Cheongdam / Apgujeong area)", "interest": ["fashion"], "indoor": true, "expensive": true, "mapLink": "https://naver.me/", "link": "https://www.wooyoungmi.com", "logo": "images/wooyoungmi_logo_2.svg"},

  {"id": "s-juunj", "neighbourhood": "apgujeong", "cat": "fashion", "name": "Juun.J — Apgujeong", "emoji": "🕶️", "gradient": "linear-gradient(135deg,#1c1c1c,#4a235a)", "region": "seoul2", "cost": "₩200,000–1,000,000+", "costZAR": "≈ R2,160–10,800", "duration": "1 hr", "teaser": "Korea's most avant-garde high-fashion house — Juun.J has shown at Paris and dressed world stages.", "desc": "Juun.J (정욱준) is South Korea's answer to Rick Owens and the Japanese avant-garde — deconstructed tailoring, oversized proportions, and a dark, architectural aesthetic. The designer has shown at Paris Fashion Week and dressed artists from BTS to international celebrities. The Apgujeong flagships represents the full extent of the Juun.J vision.", "highlights": ["Deconstructed tailoring and outerwear", "Oversized architectural silhouettes", "Paris Fashion Week pedigree", "Full menswear and womenswear", "One-of-a-kind Seoul fashion experience"], "tips": "Avant-garde high-fashion house by designer Jung Wook-jun. Known for deconstructed shapes, military aesthetics, and dramatic outerwear.", "hours": "11am – 8pm", "address": "Apgujeong, Gangnam-gu, Seoul", "interest": ["fashion"], "indoor": true, "expensive": true, "mapLink": "https://naver.me/", "link": "https://www.juunj.com", "logo": "https://logo.clearbit.com/juunj.com"},

  {"id": "s-nomanual", "neighbourhood": "seongsu", "cat": "fashion", "name": "NOMANUAL (노메뉴얼) — Seongsu", "emoji": "🔣", "gradient": "linear-gradient(135deg,#2c3e50,#7f8c8d)", "region": "seoul1", "cost": "₩40,000–200,000+", "costZAR": "≈ R432–2,160", "duration": "1 hr", "teaser": "A Seongsu-bred Korean streetwear label with a global cult — minimal identity, maximal craft.", "desc": "NOMANUAL is a Seoul streetwear label that has built serious international recognition through consistency and craft. The branding is deliberately ambiguous — the label is notable partly for what it doesn't say. The pieces are quality-driven with a focus on silhouette and material over logo placement. The Seongsu flagship is compact and confident.", "highlights": ["Graphic and logo-free streetwear", "Quality fabric focus", "Confident minimal branding", "Small capsule drops", "International following — hard to buy outside Korea"], "tips": "Minimalist and quality-driven streetwear label popular with local creatives. Known for capsule drops and silhouette-forward designs.", "hours": "12pm – 8pm (check for days open)", "address": "Seongsu-dong, Seongdong-gu, Seoul", "interest": ["fashion"], "indoor": true, "mapLink": "https://naver.me/", "link": "https://nomanual-official.com", "logo": "images/nomanual_logo.svg"},

  {"id":"s-aoesak","neighbourhood":"seongsu","cat":"fashion","name":"Aoesak (아오삭) — Seongsu","emoji":"🧣","gradient":"linear-gradient(135deg,#3d2b1f,#c8963e)","region":"seoul1","cost":"₩30,000–150,000","costZAR":"≈ R324–1,620","duration":"45 min","teaser":"A curated Seongsu boutique with a selection of Korean indie fashion and seasonal pieces.","desc":"Aoesak is a small, well-curated fashion boutique in Seongsu carrying a selection of emerging Korean brands and independent labels. The edit is thoughtful — interesting pieces that you wouldn't find in the big malls — with a focus on wearable but considered clothing. Staff are friendly and used to international visitors.","highlights":["Curated selection of Korean indie brands","Seasonal pieces with distinct identity","Wearable-but-interesting edit","Compact boutique format","Seongsu neighbourhood location"],"tips":"Great for discovering Korean independent labels you wouldn't encounter in a mall or larger store. Prices are reasonable for the curation quality.","hours":"12pm – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion"],"indoor":true,"mapLink":"https://naver.me/","link":"https://aoesak.com/?utm_source=ig&utm_medium=social&utm_content=link_in_bio","logo":"<span class=\"brand-text-logo aoesak-wordmark\">AOESAK</span>"},

  {"id":"s-atn","neighbourhood":"seongsu","cat":"fashion","name":"ATN — Seongsu","emoji":"🧥","gradient":"linear-gradient(135deg,#1c2833,#5dade2)","region":"seoul1","cost":"₩50,000–250,000","costZAR":"≈ R540–2,700","duration":"45 min","teaser":"An emerging Korean brand with a distinct identity — worth a stop if you're doing the Seongsu fashion circuit.","desc":"ATN is a Seongsu-area Korean clothing brand occupying that space between streetwear and contemporary — carefully made pieces with a clear visual identity. The shop itself is well-designed and the pieces reward closer inspection. Fits naturally into a Seongsu afternoon alongside Anderson Bell and Nomanual.","highlights":["Contemporary Korean fashion pieces","Considered design with clear identity","Quality construction","Seongsu creative district location","Part of the Seoul indie fashion conversation"],"tips":"Combine with Nomanual, Aoesak, and Anderson Bell for a proper Seongsu independent fashion afternoon. Check Instagram for any current drop or collaboration.","hours":"12pm – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/atn_official/"},

  {"id":"s-aitissu","neighbourhood":"seongsu","cat":"fashion","name":"AITISSU (아이티슈) — Seongsu","emoji":"🎀","gradient":"linear-gradient(135deg,#f7d6e0,#c0392b)","region":"seoul1","cost":"₩20,000–80,000","costZAR":"≈ R216–865","duration":"45 min","teaser":"A Seongsu feminine fashion concept — delicate, considered pieces in a beautiful small space.","desc":"AITISSU is a Seongsu fashion space with a distinctly feminine, soft aesthetic — delicate pieces, thoughtful styling, and a considered edit of clothing and accessories. The space itself is beautifully designed. A good stop for anyone looking for Korean contemporary feminine fashion outside the mainstream.","highlights":["Feminine contemporary Korean pieces","Beautiful shop interior","Accessories and clothing together","Considered, non-mainstream edit","Seongsu aesthetic location"],"tips":"A quieter, more intimate boutique experience than the larger Seongsu stores. Worth a look on any Seongsu fashion day.","hours":"12pm – 8pm","address":"Seongsu-dong, Seongdong-gu, Seoul","interest":["fashion"],"indoor":true,"mapLink":"https://naver.me/","link":"https://www.atiissu.com/kr/ko?utm_medium=social&utm_content=link_in_bio&utm_source=ig","logo":"images/aitissu_logo.svg"},

  {"id":"s-itaewon-antique","neighbourhood":"itaewon","cat":"unique","name":"Itaewon Antique Furniture Street (IAF)","emoji":"🪑","gradient":"linear-gradient(135deg,#4a3728,#967259)","region":"seoul1","cost":"₩20,000–2,000,000+","costZAR":"≈ R216–21,600","duration":"1.5 hrs","teaser":"A forgotten gem — Itaewon's old antique furniture row, now a neighbourhood of genuine curiosities.","desc":"Before Itaewon became the international nightlife district, it had a long-established antique furniture market. The IAF (Itaewon Antiques Area) on the hill above the main strip still contains dealers selling Korean antique furniture (Joseon dynasty chests, lacquerware, celadon), vintage Western pieces, and miscellaneous curiosities. Prices range from reasonable to serious. You'll find dealers who've been here 30+ years alongside newer vintage operators.","highlights":["Joseon-era wooden furniture (bandaji chests)","Antique Korean celadon and brassware","Vintage Western items and curiosities","Haggling expected on most pieces","Best antique neighbourhood in Seoul"],"tips":"Saturday mornings see most dealers open. Take photos of pieces you like — the dealers are used to this. Haggling is expected; start at 60–70% of asking price and negotiate from there. Small porcelain and brassware pieces travel well.","hours":"Most dealers: 11am – 6pm (many closed Mondays)","address":"Itaewon-ro antique area, Yongsan-gu, Seoul","interest":["culture","fashion"],"indoor":false,"mapLink":"https://naver.me/","link":"https://www.instagram.com/explore/tags/이태원앤틱/"}
];

